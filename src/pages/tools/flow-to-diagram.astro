---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Flow Register → Diagrams"
  description="Upload an Excel/CSV flow register and rebuild it as Mermaid and draw.io diagrams, split into application, database, and technology layers that share the same hops."
  mainClass="max-w-5xl"
>
  <article class="tool">
    <header class="thead">
      <p class="kick">Tools · Extract &amp; Analyze</p>
      <h1>Flow Register → Diagrams</h1>
      <p class="sub">
        The reverse pipeline. Upload an Excel or CSV <strong>flow register</strong> (the kind
        the <a href="/tools/diagram-pipeline/">Diagram Pipeline</a> exports) and rebuild it as
        diagrams — split into three layers that share the same hops:
        <strong>application</strong>, <strong>database</strong>, and <strong>technology platform</strong>.
        Every layer comes back as editable Mermaid and a draw.io file.
      </p>
      <a class="back" href="/tools/">Back to all tools</a>
    </header>

    <!-- INPUT -->
    <section class="step">
      <h2 class="step-h"><span class="n">1</span> Upload flow register</h2>
      <p class="hint">
        Needs at least <code>From Application</code> and <code>To Application</code> columns;
        <code>Interface Mechanism</code>, <code>From/To Database</code>, and
        <code>From/To Platform</code> are used when present. Parsed entirely in your browser.
      </p>
      <div class="drop" id="drop">
        <input type="file" id="file" accept=".xlsx,.xls,.csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv" />
        <div class="dl">Select a .xlsx, .xls, or .csv file</div>
        <div class="ds">The flow register / hops sheet.</div>
      </div>
      <div class="row">
        <label class="field" id="sheetWrap" hidden>
          <span>Sheet</span>
          <select id="sheet"></select>
        </label>
        <span class="status" id="status">Waiting for a file.</span>
      </div>
      <div class="summary" id="summary" hidden></div>
    </section>

    <!-- OUTPUT -->
    <section class="step" id="output" hidden>
      <div class="out-head">
        <h2 class="step-h"><span class="n">2</span> Diagrams</h2>
        <div class="row tight">
          <button class="btn" id="dlCombined">Download all 3 as one .drawio ↧</button>
          <button class="btn" id="openCombined">Open all in diagrams.net ↗</button>
        </div>
      </div>

      <div class="tabs" id="tabs">
        <button class="tab active" data-layer="application">Application <span class="badge" id="b-application"></span></button>
        <button class="tab" data-layer="database">Database <span class="badge" id="b-database"></span></button>
        <button class="tab" data-layer="technology">Technology <span class="badge" id="b-technology"></span></button>
      </div>

      <p class="layer-note" id="layerNote"></p>

      <div class="grid2">
        <div class="col">
          <div class="row tight">
            <button class="btn sm" id="render">↻ Render</button>
            <button class="btn sm" id="copyM">Copy</button>
            <button class="btn sm" id="dlM">Download .mmd</button>
            <button class="btn sm" id="dlD">Download .drawio</button>
            <button class="btn sm" id="openD">diagrams.net ↗</button>
          </div>
          <textarea id="code" class="code" spellcheck="false"></textarea>
        </div>
        <div class="col">
          <h3 class="sub-h">Preview</h3>
          <div id="preview" class="preview"></div>
        </div>
      </div>
    </section>
  </article>

  <script is:inline>
    const $ = (id) => document.getElementById(id);
    let _mermaid = null, _xlsx = null;
    let workbook = null, layers = null, active = 'application';
    // layers = { application:{graph, code, skipped}, database:{...}, technology:{...} }

    async function mermaidLib() {
      if (!_mermaid) {
        _mermaid = (await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')).default;
        _mermaid.initialize({ startOnLoad: false, securityLevel: 'loose', theme: 'default' });
      }
      return _mermaid;
    }
    function loadXlsx() {
      return new Promise((res, rej) => {
        if (window.XLSX) return res(window.XLSX);
        const s = document.createElement('script');
        s.src = 'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js';
        s.onload = () => res(window.XLSX); s.onerror = () => rej(new Error('Could not load the spreadsheet library.'));
        document.head.appendChild(s);
      });
    }

    // ---------- column mapping ----------
    const COL_SYNONYMS = {
      fromApp: ['fromapplication', 'fromapp', 'sourceapplication', 'sourceapp', 'from', 'source'],
      interface: ['interfacemechanism', 'interface', 'mechanism', 'protocol', 'connection'],
      toApp: ['toapplication', 'toapp', 'targetapplication', 'targetapp', 'to', 'target', 'destination'],
      fromDb: ['fromdatabase', 'fromdb', 'sourcedatabase'],
      fromPlat: ['fromplatform', 'fromtechnologyplatform', 'fromtech', 'sourceplatform'],
      toDb: ['todatabase', 'todb', 'targetdatabase'],
      toPlat: ['toplatform', 'totechnologyplatform', 'totech', 'targetplatform'],
    };
    const norm = (s) => String(s ?? '').toLowerCase().replace(/[^a-z0-9]/g, '');
    function mapColumns(headerRow) {
      const normed = headerRow.map(norm); const idx = {};
      for (const [key, syns] of Object.entries(COL_SYNONYMS)) {
        let found = -1;
        for (const syn of syns) { const i = normed.indexOf(syn); if (i !== -1) { found = i; break; } }
        idx[key] = found;
      }
      return idx;
    }
    function parseHops(aoa) {
      if (!aoa || !aoa.length) return null;
      let headerIdx = -1, idx = null;
      for (let i = 0; i < Math.min(aoa.length, 5); i++) {
        const m = mapColumns(aoa[i] || []);
        if (m.fromApp !== -1 && m.toApp !== -1) { headerIdx = i; idx = m; break; }
      }
      if (headerIdx === -1) return null;
      const get = (row, key) => (idx[key] === -1 ? '' : String(row[idx[key]] ?? '').trim());
      const hops = [];
      for (let r = headerIdx + 1; r < aoa.length; r++) {
        const row = aoa[r] || [];
        const fromApp = get(row, 'fromApp'), toApp = get(row, 'toApp');
        if (!fromApp && !toApp) continue;
        hops.push({ fromApp, toApp, interface: get(row, 'interface'), fromDb: get(row, 'fromDb'), toDb: get(row, 'toDb'), fromPlat: get(row, 'fromPlat'), toPlat: get(row, 'toPlat') });
      }
      return { hops, columns: idx };
    }

    // ---------- build 3 layered graphs ----------
    function buildLayer(hops, fromKey, toKey, shape) {
      const labelToId = new Map(), nodes = new Map(), seenEdge = new Set(), edges = [];
      let missing = 0, self = 0;
      const idFor = (label) => {
        if (!labelToId.has(label)) { const id = 'n' + labelToId.size; labelToId.set(label, id); nodes.set(id, { id, label, shape }); }
        return labelToId.get(label);
      };
      for (const h of hops) {
        const from = h[fromKey], to = h[toKey];
        if (from) idFor(from); if (to) idFor(to);
        if (!from || !to) { missing++; continue; }
        if (from === to) { self++; continue; }
        const fid = idFor(from), tid = idFor(to);
        const key = fid + ' ' + tid + ' ' + (h.interface || '');
        if (seenEdge.has(key)) continue;
        seenEdge.add(key);
        edges.push({ from: fid, to: tid, label: h.interface || '' });
      }
      return { direction: 'LR', nodes, edges, skipped: { missing, self } };
    }
    function buildLayerGraphs(hops) {
      return {
        application: buildLayer(hops, 'fromApp', 'toApp', 'rect'),
        database: buildLayer(hops, 'fromDb', 'toDb', 'cylinder'),
        technology: buildLayer(hops, 'fromPlat', 'toPlat', 'hexagon'),
      };
    }

    // ---------- graph -> Mermaid ----------
    function escMermaid(s) { return String(s).replace(/"/g, "'").replace(/[\[\]{}()<>|]/g, ' ').replace(/\s+/g, ' ').trim(); }
    const MERMAID_SHAPE = { rect: (l) => `["${l}"]`, cylinder: (l) => `[("${l}")]`, hexagon: (l) => `{{"${l}"}}` };
    function toMermaid(graph) {
      const lines = ['flowchart ' + (graph.direction || 'LR')];
      for (const [id, n] of graph.nodes) lines.push(`  ${id}${(MERMAID_SHAPE[n.shape] || MERMAID_SHAPE.rect)(escMermaid(n.label))}`);
      for (const e of graph.edges) { const lbl = e.label ? `|"${escMermaid(e.label)}"|` : ''; lines.push(`  ${e.from} -->${lbl} ${e.to}`); }
      return lines.join('\n');
    }

    // ---------- layered layout (cycle-safe) + draw.io ----------
    function layout(graph) {
      const { nodes, edges, direction } = graph;
      const ids = [...nodes.keys()];
      const preds = new Map(ids.map((id) => [id, []]));
      for (const e of edges) { if (nodes.has(e.from) && nodes.has(e.to)) preds.get(e.to).push(e.from); }
      const rank = new Map(), onStack = new Set();
      const rankOf = (id) => {
        if (rank.has(id)) return rank.get(id);
        if (onStack.has(id)) return 0;
        onStack.add(id); let r = 0;
        for (const p of preds.get(id) || []) r = Math.max(r, rankOf(p) + 1);
        onStack.delete(id); rank.set(id, r); return r;
      };
      for (const id of ids) rankOf(id);
      const byRank = new Map();
      for (const id of ids) { const r = rank.get(id); if (!byRank.has(r)) byRank.set(r, []); byRank.get(r).push(id); }
      const NW = 170, NH = 60, GX = 80, GY = 60;
      const horizontal = direction === 'LR' || direction === 'RL';
      const pos = new Map();
      for (const [r, list] of byRank) list.forEach((id, idx) => {
        const along = idx * (horizontal ? (NH + GY) : (NW + GX));
        const across = r * (horizontal ? (NW + GX) : (NH + GY));
        pos.set(id, { x: (horizontal ? across : along) + 40, y: (horizontal ? along : across) + 40, w: NW, h: NH });
      });
      return pos;
    }
    const SHAPE_STYLE = {
      rect: 'rounded=0;whiteSpace=wrap;html=1;',
      cylinder: 'shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;',
      hexagon: 'shape=hexagon;whiteSpace=wrap;html=1;',
    };
    function xmlEscape(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
    function graphCells(graph, pos) {
      const { nodes, edges } = graph; const cells = [];
      for (const [id, n] of nodes) {
        const p = pos.get(id) || { x: 40, y: 40, w: 170, h: 60 };
        const style = SHAPE_STYLE[n.shape] || SHAPE_STYLE.rect;
        cells.push(`        <mxCell id="${id}" value="${xmlEscape(n.label)}" style="${style}" vertex="1" parent="1">\n          <mxGeometry x="${Math.round(p.x)}" y="${Math.round(p.y)}" width="${p.w}" height="${p.h}" as="geometry" />\n        </mxCell>`);
      }
      edges.forEach((e, idx) => {
        if (!nodes.has(e.from) || !nodes.has(e.to)) return;
        const style = 'edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;';
        cells.push(`        <mxCell id="e_${idx}" value="${xmlEscape(e.label || '')}" style="${style}" edge="1" parent="1" source="${e.from}" target="${e.to}">\n          <mxGeometry relative="1" as="geometry" />\n        </mxCell>`);
      });
      return cells.join('\n');
    }
    function diagramPage(graph, name, id) {
      return `  <diagram id="${id}" name="${name}">\n    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">\n      <root>\n        <mxCell id="0" />\n        <mxCell id="1" parent="0" />\n${graphCells(graph, layout(graph))}\n      </root>\n    </mxGraphModel>\n  </diagram>`;
    }
    function layerDrawio(graph, name) {
      return `<mxfile host="app.diagrams.net" agent="flow-to-diagram" version="24.0.0">\n${diagramPage(graph, name, 'layer')}\n</mxfile>\n`;
    }
    function combinedDrawio() {
      const pages = [];
      for (const [name, l] of Object.entries(layers)) {
        if (l.graph.nodes.size === 0) continue;
        pages.push(diagramPage(l.graph, name[0].toUpperCase() + name.slice(1), 'layer-' + name));
      }
      return `<mxfile host="app.diagrams.net" agent="flow-to-diagram" version="24.0.0">\n${pages.join('\n')}\n</mxfile>\n`;
    }

    // ---------- file handling ----------
    function selFile(f) {
      $('status').textContent = 'Reading ' + f.name + '…';
      const reader = new FileReader();
      reader.onload = async (ev) => {
        try {
          const XLSX = await loadXlsx();
          workbook = XLSX.read(new Uint8Array(ev.target.result), { type: 'array' });
          const sel = $('sheet'); sel.innerHTML = '';
          workbook.SheetNames.forEach((nm) => { const o = document.createElement('option'); o.value = nm; o.textContent = nm; sel.appendChild(o); });
          // prefer a sheet that parses; bias toward one named "Hops"
          const preferred = workbook.SheetNames.find((n) => /hop/i.test(n)) || workbook.SheetNames[0];
          sel.value = preferred; $('sheetWrap').hidden = workbook.SheetNames.length < 2;
          useSheet(preferred);
        } catch (e) { $('status').textContent = 'Error: ' + (e.message || e); }
      };
      reader.onerror = () => { $('status').textContent = 'Could not read the file.'; };
      reader.readAsArrayBuffer(f);
    }
    function useSheet(name) {
      const XLSX = window.XLSX;
      const aoa = XLSX.utils.sheet_to_json(workbook.Sheets[name], { header: 1, blankrows: false, defval: '' });
      const parsed = parseHops(aoa);
      if (!parsed || !parsed.hops.length) {
        $('output').hidden = true; $('summary').hidden = false;
        $('summary').innerHTML = `Couldn't find <code>From Application</code> / <code>To Application</code> columns in sheet “${name}”. Pick another sheet or check the headers.`;
        $('status').textContent = 'No usable rows.';
        return;
      }
      layers = buildLayerGraphs(parsed.hops);
      for (const l of Object.values(layers)) l.code = toMermaid(l.graph);
      $('status').textContent = `Parsed ${parsed.hops.length} hop${parsed.hops.length === 1 ? '' : 's'} from “${name}”.`;
      $('summary').hidden = false;
      $('summary').innerHTML = summaryHtml(parsed.hops.length);
      $('output').hidden = false;
      for (const k of ['application', 'database', 'technology']) {
        $('b-' + k).textContent = layers[k].graph.edges.length;
      }
      showLayer(active);
    }
    function summaryHtml(n) {
      const a = layers.application.graph, d = layers.database.graph, t = layers.technology.graph;
      return `<strong>${n}</strong> hops → ` +
        `<strong>${a.nodes.size}</strong> applications / <strong>${a.edges.length}</strong> flows · ` +
        `<strong>${d.nodes.size}</strong> databases / <strong>${d.edges.length}</strong> flows · ` +
        `<strong>${t.nodes.size}</strong> platforms / <strong>${t.edges.length}</strong> flows.`;
    }

    // ---------- layer tabs ----------
    function skippedNote(l) {
      const s = l.graph.skipped, bits = [];
      if (s.missing) bits.push(`${s.missing} hop${s.missing === 1 ? '' : 's'} skipped (one end unmapped)`);
      if (s.self) bits.push(`${s.self} self-loop${s.self === 1 ? '' : 's'} skipped (both ends identical)`);
      return bits.join(' · ');
    }
    function showLayer(key) {
      active = key;
      document.querySelectorAll('.tab').forEach((t) => t.classList.toggle('active', t.dataset.layer === key));
      $('code').value = layers[key].code;
      const note = skippedNote(layers[key]);
      $('layerNote').textContent = note || '';
      $('layerNote').hidden = !note;
      render();
    }
    document.querySelectorAll('.tab').forEach((t) => t.addEventListener('click', () => showLayer(t.dataset.layer)));

    async function render() {
      const code = $('code').value.trim(); if (!code) { $('preview').innerHTML = ''; return; }
      // keep edits for the active layer
      if (layers && layers[active]) layers[active].code = code;
      try { const mer = await mermaidLib(); const { svg } = await mer.render('m' + Math.random().toString(36).slice(2), code); $('preview').innerHTML = svg; }
      catch (e) { $('preview').innerHTML = `<div class="err">Diagram didn't parse — edit the code and re-render.<br><small>${(e.message || e).toString().replace(/</g, '&lt;').slice(0, 200)}</small></div>`; }
    }

    // ---------- buttons ----------
    function download(content, name, type) {
      const blob = new Blob([content], { type }); const a = document.createElement('a');
      a.href = URL.createObjectURL(blob); a.download = name; a.click(); setTimeout(() => URL.revokeObjectURL(a.href), 15000);
    }
    function openDrawio(xml) { window.open('https://app.diagrams.net/?title=flow.drawio#R' + encodeURIComponent(xml), '_blank', 'noopener,noreferrer'); }

    $('render').addEventListener('click', render);
    $('copyM').addEventListener('click', async () => { try { await navigator.clipboard.writeText($('code').value); $('status').textContent = 'Mermaid copied.'; } catch { $('status').textContent = 'Copy failed.'; } });
    $('dlM').addEventListener('click', () => download($('code').value, active + '-flow.mmd', 'text/plain'));
    $('dlD').addEventListener('click', () => download(layerDrawio(layers[active].graph, active[0].toUpperCase() + active.slice(1)), active + '-flow.drawio', 'application/xml'));
    $('openD').addEventListener('click', () => openDrawio(layerDrawio(layers[active].graph, active)));
    $('dlCombined').addEventListener('click', () => download(combinedDrawio(), 'flow-layers.drawio', 'application/xml'));
    $('openCombined').addEventListener('click', () => openDrawio(combinedDrawio()));

    // ---------- input wiring ----------
    $('file').addEventListener('change', (e) => { const f = e.target.files?.[0]; if (f) selFile(f); });
    $('sheet').addEventListener('change', (e) => useSheet(e.target.value));
    const dz = $('drop');
    dz.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('drag'); });
    dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
    dz.addEventListener('drop', (e) => { e.preventDefault(); dz.classList.remove('drag'); const f = e.dataTransfer?.files?.[0]; if (f) selFile(f); });
  </script>
</BaseLayout>

<style>
  .tool { max-width: 1000px; margin: 0 auto; }
  .thead { margin-bottom: 18px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; }
  .kick { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-subtle); font-weight: 600; }
  .thead h1 { margin-top: 4px; font-size: 28px; line-height: 1.15; }
  .sub { margin-top: 8px; font-size: 14px; color: var(--color-fg-muted); max-width: 72ch; }
  .sub a { color: var(--color-accent); }
  .back { display: inline-block; margin-top: 10px; color: var(--color-fg-muted); text-decoration: none; font-size: 12px; border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 10px; }
  .back:hover { color: var(--color-fg); border-color: var(--color-accent); }

  .step { border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-bg-elevated); padding: 16px; margin-bottom: 16px; }
  .step-h { font-size: 15px; font-weight: 600; display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
  .step-h .n { display: inline-grid; place-items: center; width: 22px; height: 22px; border-radius: 999px; background: var(--color-accent); color: var(--color-accent-fg); font-size: 12px; font-weight: 700; }
  .sub-h { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-fg-muted); margin-bottom: 8px; }
  .hint { font-size: 12.5px; color: var(--color-fg-muted); margin: 6px 0 12px; line-height: 1.5; }
  .hint code, .summary code { font-family: var(--font-mono); font-size: 11px; background: var(--color-bg); padding: 1px 4px; border-radius: 4px; border: 1px solid var(--color-border); }

  .drop { border: 2px dashed var(--color-border); border-radius: 12px; padding: 22px; text-align: center; position: relative; margin-bottom: 12px; cursor: pointer; background: var(--color-bg); }
  .drop.drag { border-color: var(--color-accent); }
  .drop input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .dl { font-size: 14px; font-weight: 600; } .ds { font-size: 12px; color: var(--color-fg-muted); }

  .field { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--color-fg-muted); }
  .field select { background: var(--color-bg); border: 1px solid var(--color-border); color: var(--color-fg); border-radius: 8px; padding: 6px 8px; font-size: 13px; }
  .status { font-size: 12px; color: var(--color-fg-muted); }
  .summary { margin-top: 10px; font-size: 13px; color: var(--color-fg); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 8px; padding: 10px 12px; line-height: 1.6; }

  .out-head { display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
  .tabs { display: flex; gap: 6px; border-bottom: 1px solid var(--color-border); margin-bottom: 12px; flex-wrap: wrap; }
  .tab { border: 1px solid transparent; border-bottom: none; background: transparent; color: var(--color-fg-muted); padding: 8px 14px; font-size: 13px; cursor: pointer; border-radius: 8px 8px 0 0; display: inline-flex; align-items: center; gap: 7px; }
  .tab:hover { color: var(--color-fg); }
  .tab.active { color: var(--color-fg); background: var(--color-bg); border-color: var(--color-border); font-weight: 600; margin-bottom: -1px; }
  .badge { font-size: 11px; min-width: 18px; text-align: center; background: var(--color-border); color: var(--color-fg-muted); border-radius: 999px; padding: 0 6px; }
  .tab.active .badge { background: var(--color-accent); color: var(--color-accent-fg); }
  .layer-note { font-size: 12px; color: var(--color-fg-muted); margin-bottom: 10px; font-style: italic; }

  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .col { min-width: 0; }
  .code { width: 100%; min-height: 320px; resize: vertical; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-bg); color: var(--color-fg); padding: 12px; font-family: var(--font-mono); font-size: 13px; line-height: 1.5; }
  .preview { min-height: 320px; border: 1px solid var(--color-border); border-radius: 10px; background: #fff; padding: 12px; overflow: auto; display: grid; place-items: center; }
  .preview :global(svg) { max-width: 100%; height: auto; }
  .err { color: #b94a48; font-size: 13px; text-align: center; }

  .row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-top: 4px; }
  .row.tight { margin-bottom: 8px; margin-top: 0; }
  .btn { border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-fg); border-radius: 8px; padding: 9px 12px; font-size: 13px; cursor: pointer; }
  .btn.sm { padding: 4px 9px; font-size: 11.5px; }
  .btn:hover { border-color: var(--color-accent); }

  @media (max-width: 760px) { .grid2 { grid-template-columns: 1fr; } }
</style>
