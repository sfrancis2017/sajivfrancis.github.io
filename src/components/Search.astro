---
// Pagefind-backed search modal. Triggered by header button, "/" key, or Cmd/Ctrl+K.
// Pagefind UI is loaded via a plain script src tag (the recommended Pagefind
// integration pattern) — more reliable than dynamic ES imports.
//
// In dev mode, the /pagefind/ index does not exist (it is generated by
// pagefind --site dist during the production build), so the script will
// 404 and the modal will show a fallback message. Production builds work.
---

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" is:inline />

<dialog
  id="search-dialog"
  class="bg-[var(--color-bg-elevated)] text-[var(--color-fg)] backdrop:bg-black/50 backdrop:backdrop-blur-sm w-full max-w-2xl mx-auto mt-[10vh] rounded-lg border border-[var(--color-border)] shadow-xl p-0"
>
  <form method="dialog" class="flex justify-end p-2">
    <button
      type="submit"
      class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] text-sm px-3 py-1"
      aria-label="Close search"
    >
      Esc ✕
    </button>
  </form>
  <div id="pagefind-root" class="p-4 pt-0">
    <div id="pagefind-fallback" class="text-sm text-[var(--color-fg-muted)] hidden">
      Search index not available (this is normal in <code>npm run dev</code>;
      run <code>npm run build &amp;&amp; npm run preview</code> to test locally).
    </div>
  </div>
</dialog>

<script src="/pagefind/pagefind-ui.js" is:inline></script>

<script>
  declare global {
    interface Window {
      PagefindUI?: any;
    }
  }

  let initialized = false;

  function initPagefind() {
    if (initialized) return;
    if (!window.PagefindUI) {
      // Script failed to load (likely dev mode — show fallback)
      document.getElementById('pagefind-fallback')?.classList.remove('hidden');
      return;
    }
    initialized = true;
    new window.PagefindUI({
      element: '#pagefind-root',
      showSubResults: true,
      showImages: false,
      resetStyles: false,
      translations: { placeholder: 'Search writing...' },
    });
  }

  function openSearch() {
    const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
    if (!dialog) return;
    initPagefind();
    dialog.showModal();
    // Focus the input after the UI mounts
    requestAnimationFrame(() => {
      const input = dialog.querySelector<HTMLInputElement>('input[type="text"]');
      input?.focus();
    });
  }

  document.getElementById('search-trigger')?.addEventListener('click', openSearch);

  document.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement | null;
    const isTyping =
      target &&
      (target.tagName === 'INPUT' ||
        target.tagName === 'TEXTAREA' ||
        target.isContentEditable);
    if (isTyping) return;
    if (e.key === '/' || ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k')) {
      e.preventDefault();
      openSearch();
    }
  });

  document.getElementById('search-dialog')?.addEventListener('click', (e) => {
    const dialog = e.currentTarget as HTMLDialogElement;
    if (e.target === dialog) dialog.close();
  });
</script>

<style is:global>
  /* Style the Pagefind UI to match editorial palette */
  #pagefind-root .pagefind-ui {
    --pagefind-ui-scale: 0.95;
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-fg);
    --pagefind-ui-background: var(--color-bg-elevated);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-fg-subtle);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-sans);
  }
</style>
