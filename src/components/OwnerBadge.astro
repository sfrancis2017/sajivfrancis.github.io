---
// Site-wide owner-mode indicator — a round icon button that matches the chat
// launcher (same size/shape/colours) and stacks directly above it in the
// bottom-right corner, so the two read as a coordinated pair on every page
// (and on mobile). Like the chat icon it uses --color-fg / --color-bg, so it
// INVERTS with the theme: dark button on a light page, light button on a dark
// page. Owner mode turns it green.
//
// sajivfrancis.com is GitHub Pages (no Cloudflare Access here), so "owner" =
// presence of an owner token in localStorage: 'write-token' (CHAT_TOKEN —
// writing + PDF) and/or 'tools-access-token' (TOOLS_TOKEN — tools). One sign-in
// (?token=both) fetches both. State stays in sync across tabs via `storage`.
---

<button
  type="button"
  id="owner-badge"
  class="owner-badge"
  data-owner="0"
  hidden
  aria-label="Owner sign-in"
>
  <!-- signed-out: user icon -->
  <svg class="ob-ic ob-in" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="8" r="4" /><path d="M4 21v-1a8 8 0 0 1 16 0v1" />
  </svg>
  <!-- owner: log-out icon -->
  <svg class="ob-ic ob-out" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" x2="9" y1="12" y2="12" />
  </svg>
</button>

<style>
  /* Mirrors the chat launcher's CSS exactly (bottom-6 right-6 z-30 h-14 w-14
     rounded-full bg-fg text-bg shadow-lg). It shares the SAME bottom anchor as
     the chat icon and is lifted by a constant transform, so the gap between the
     two never drifts (even when the mobile address bar hides and the viewport
     changes). Inverts with the theme just like the chat icon. */
  .owner-badge {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    transform: translateY(-4.25rem); /* sit just above the 3.5rem chat button */
    z-index: 30;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    border: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: var(--color-fg);
    color: var(--color-bg);
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    transition: opacity 0.15s ease;
  }
  .owner-badge:hover { opacity: 0.9; }
  /* Owner mode → green, unmistakable on both themes. */
  .owner-badge[data-owner='1'] { background: #16a34a; color: #fff; }
  .owner-badge .ob-out { display: none; }
  .owner-badge[data-owner='1'] .ob-in { display: none; }
  .owner-badge[data-owner='1'] .ob-out { display: block; }
</style>

<script is:inline>
  (function () {
    const CHAT_KEY = 'write-token';
    const TOOLS_KEY = 'tools-access-token';
    const HANDOFF = 'https://chat.sajivfrancis.com/admin/api/sso-handoff?token=both&redirect=';
    const LOGOUT = 'https://sajivfrancis.cloudflareaccess.com/cdn-cgi/access/logout?returnTo=';
    const RETURN_VIA = 'https://chat.sajivfrancis.com/sso-return?to=';

    // Capture tokens handed back in the URL fragment after the Access SSO.
    const h = location.hash || '';
    const chat = h.match(/(?:^#|&)chat-token=([^&]+)/);
    const tools = h.match(/(?:^#|&)tools-token=([^&]+)/);
    if (chat || tools) {
      try {
        if (chat) localStorage.setItem(CHAT_KEY, decodeURIComponent(chat[1]));
        if (tools) localStorage.setItem(TOOLS_KEY, decodeURIComponent(tools[1]));
      } catch (e) {}
      history.replaceState(null, '', location.pathname + location.search);
    }

    const btn = document.getElementById('owner-badge');
    if (!btn) return;

    function isOwner() {
      return !!(localStorage.getItem(CHAT_KEY) || localStorage.getItem(TOOLS_KEY));
    }
    function render() {
      const owner = isOwner();
      btn.dataset.owner = owner ? '1' : '0';
      btn.setAttribute('aria-label', owner ? 'Owner mode — sign out' : 'Owner sign-in');
      btn.title = owner
        ? 'Signed in as owner. Click to sign out everywhere (chat, trading, tools, writing).'
        : 'Sign in with Cloudflare Access to unlock owner features (writing, PDF, tools).';
      btn.hidden = false;
    }

    btn.addEventListener('click', function () {
      if (isOwner()) {
        if (!confirm('Sign out of owner mode everywhere (chat, trading, tools, writing)?\nThis ends the shared session on this device.')) return;
        try { localStorage.removeItem(CHAT_KEY); localStorage.removeItem(TOOLS_KEY); } catch (e) {}
        const ret = RETURN_VIA + encodeURIComponent(location.origin + location.pathname);
        location.href = LOGOUT + encodeURIComponent(ret);
      } else {
        location.href = HANDOFF + encodeURIComponent(location.href);
      }
    });

    // Live cross-tab sync: a sign-in/out in another tab updates this badge.
    window.addEventListener('storage', function (e) {
      if (e.key === CHAT_KEY || e.key === TOOLS_KEY || e.key === null) render();
    });

    render();
  })();
</script>
