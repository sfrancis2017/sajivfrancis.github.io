---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroVideo from '@/components/HeroVideo.astro';

// Section teaser — paste the CDN URL from the video pipeline here (slug: tools).
const heroVideo = 'https://sajiv-videos.sfo3.cdn.digitaloceanspaces.com/videos/tools/1781662308618.mp4';

// Tools are grouped by category so the page stays legible as it grows.
// `where` flags processing locality: 'browser' (private) or 'server'.
const tools = [
  { title: 'PDF Merge', href: '/tools/pdf-merge/', category: 'Organize', where: 'browser',
    desc: 'Combine multiple PDFs into one, reordered in any sequence.' },
  { title: 'PDF Splitter', href: '/tools/pdf-splitter/', category: 'Organize', where: 'browser',
    desc: 'Split a single PDF into fixed-size chunks or custom page ranges.' },
  { title: 'PDF Compressor', href: '/tools/pdf-compressor/', category: 'Organize', where: 'browser',
    desc: 'Reduce PDF size with quality presets and a split fallback.' },
  { title: 'Organize Pages', href: '/tools/pdf-organize/', category: 'Organize', where: 'browser',
    desc: 'Reorder, rotate, and delete pages in a visual grid, then export.' },
  { title: 'Images → PDF', href: '/tools/image-to-pdf/', category: 'Organize', where: 'browser',
    desc: 'Combine JPG/PNG images into one PDF with page-size and margin options.' },

  { title: 'PDF → Images', href: '/tools/pdf-to-images/', category: 'Convert', where: 'browser',
    desc: 'Export each page of a PDF as a high-resolution PNG or JPG.' },

  { title: 'Watermark PDF', href: '/tools/pdf-watermark/', category: 'Edit & Annotate', where: 'browser',
    desc: 'Stamp text like “CONFIDENTIAL” across pages — diagonal or tiled, with opacity control.' },
  { title: 'Page Numbers & Bates', href: '/tools/pdf-number/', category: 'Edit & Annotate', where: 'browser',
    desc: 'Add page numbers (Page X of Y) or sequential Bates numbering for legal/discovery.' },

  { title: 'Markdown → PDF & Word', href: '/tools/markdown-convert/', category: 'Convert', where: 'browser',
    desc: 'Convert Markdown to PDF or Word — Mermaid diagrams and Plotly charts render precisely as images.' },

  { title: 'OCR — Extract Text', href: '/tools/ocr/', category: 'Extract & Analyze', where: 'browser',
    desc: 'Pull editable text out of images or scanned PDFs (Tesseract). Copy, edit, or download as .txt/.md.' },
  { title: 'Image → Mermaid', href: '/tools/image-to-mermaid/', category: 'Extract & Analyze', where: 'server',
    desc: 'Turn a picture of a diagram into editable Mermaid code with vision AI — rendered live.' },
  { title: 'PowerPoint → Markdown', href: '/tools/pptx-to-markdown/', category: 'Convert', where: 'browser',
    desc: 'Extract slide titles, bullets, and notes from a .pptx into reusable Markdown.' },

  { title: 'Sign PDF', href: '/tools/pdf-sign/', category: 'Sign & Secure', where: 'browser',
    desc: 'Draw, type, or upload a signature and place it on a PDF. Signatures stay on your device.' },

  { title: 'Architecture Writer', href: '/tools/architecture-writer/', category: 'Architecture', where: 'browser',
    desc: 'Generate and score architecture writeups with a rubric-based draft workflow.' },
  { title: 'Diagram Pipeline', href: '/tools/diagram-pipeline/', category: 'Architecture', where: 'server',
    desc: 'Chain a diagram from image → Mermaid → draw.io → an Excel flow register of every hop, app, and interface.' },
  { title: 'Flow Register → Diagrams', href: '/tools/flow-to-diagram/', category: 'Architecture', where: 'browser',
    desc: 'Reverse pipeline: upload an Excel/CSV flow register and rebuild Mermaid + draw.io, split into application, database, and technology layers.' },

  { title: 'Word Art / Banner', href: '/tools/word-art/', category: 'Create', where: 'server',
    desc: 'Turn text, a URL, or a document into a styled word-cloud banner for blog posts and whitepapers.' },
  { title: 'Map Maker', href: '/tools/map-maker/', category: 'Create', where: 'browser',
    desc: 'Outline → mind map, concept map, or system map. Generates Mermaid that drops into docs, whitepapers, or the chat.' },
  { title: 'Diff — Compare Text', href: '/tools/diff/', category: 'Extract & Analyze', where: 'browser',
    desc: 'Side-by-side or unified diff for code, Markdown, prompts, or ADR revisions — entirely in your browser.' },
];

const CATEGORY_ORDER = ['Organize', 'Convert', 'Create', 'Edit & Annotate', 'Sign & Secure', 'Extract & Analyze', 'Architecture'];
const grouped = CATEGORY_ORDER
  .map((category) => ({ category, items: tools.filter((t) => t.category === category) }))
  .filter((g) => g.items.length > 0);
---

<BaseLayout
  title="Tools"
  description="Browser-first document and architecture tools. Files are processed locally — nothing is uploaded."
  mainClass="max-w-4xl"
>
  <HeroVideo src={heroVideo} class="max-w-3xl mb-8" />

  <article>
    <header class="mb-10">
      <p class="text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] font-semibold">Toolkit</p>
      <h1 class="mt-2 text-3xl md:text-4xl font-semibold tracking-tight leading-tight">Tools</h1>
      <p class="mt-3 text-base text-[var(--color-fg-muted)] max-w-2xl">
        Browser-first utilities for document-heavy work. Tools marked
        <span class="badge-inline">🔒 In your browser</span> process files locally on your device — nothing is uploaded.
      </p>
    </header>

    {grouped.map((group) => (
      <section class="mb-9">
        <h2 class="cat-title">{group.category}</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {group.items.map((tool) => (
            <a href={tool.href} class="tool-card no-underline hover:no-underline">
              <p class="tool-badge">{tool.where === 'browser' ? '🔒 In your browser' : '☁ Server'}</p>
              <h3 class="mt-2 text-lg font-semibold text-[var(--color-fg)]">{tool.title}</h3>
              <p class="mt-2 text-sm text-[var(--color-fg-muted)] leading-relaxed">{tool.desc}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </article>
</BaseLayout>

<style>
  .cat-title {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-fg-subtle);
    font-weight: 700;
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-border);
  }
  .tool-card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-elevated);
    padding: 18px;
    transition: border-color 180ms ease, transform 180ms ease;
  }
  .tool-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .tool-badge {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .badge-inline {
    display: inline-block;
    font-size: 12px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0 7px;
    white-space: nowrap;
  }
</style>
