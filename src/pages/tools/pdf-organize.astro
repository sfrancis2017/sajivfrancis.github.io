---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Organize PDF Pages" description="Reorder, rotate, and delete PDF pages in a visual grid — entirely in your browser." mainClass="max-w-4xl">
  <article class="tool">
    <header class="thead">
      <p class="kick">Tools · Organize</p>
      <h1>Organize Pages</h1>
      <p class="sub">Reorder, rotate, or delete pages in a visual grid, then export. Nothing is uploaded.</p>
      <a class="back" href="/tools/">Back to all tools</a>
    </header>

    <div class="drop" id="drop"><input type="file" id="file" accept=".pdf,application/pdf" /><div class="dl">Select a PDF</div><div class="ds">Processing runs locally in your browser.</div></div>

    <div class="status" id="status">Select a PDF to begin.</div>
    <div class="pgrid" id="grid"></div>
    <button class="btn primary" id="go" disabled>Apply &amp; download</button>
  </article>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script is:inline>
    const $ = (id) => document.getElementById(id);
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    let srcBytes = null, pages = []; // pages: {orig, rot, thumb}

    async function load(file) {
      srcBytes = new Uint8Array(await file.arrayBuffer());
      $('status').textContent = 'Rendering thumbnails…';
      const doc = await pdfjsLib.getDocument({ data: srcBytes.slice() }).promise;
      pages = [];
      for (let p = 1; p <= doc.numPages; p++) {
        const page = await doc.getPage(p);
        const vp = page.getViewport({ scale: 0.35 });
        const cv = document.createElement('canvas'); cv.width = vp.width; cv.height = vp.height;
        await page.render({ canvasContext: cv.getContext('2d'), viewport: vp }).promise;
        pages.push({ orig: p - 1, rot: 0, thumb: cv.toDataURL('image/png') });
      }
      $('go').disabled = false; render();
      $('status').textContent = `${pages.length} pages. Reorder, rotate, or delete, then export.`;
    }
    function render() {
      const g = $('grid'); g.innerHTML = '';
      pages.forEach((pg, i) => {
        const c = document.createElement('div'); c.className = 'pcard';
        c.innerHTML = `<div class="pthumb"><img src="${pg.thumb}" style="transform:rotate(${pg.rot}deg)" alt="page ${pg.orig + 1}"></div>
          <div class="pn">Pg ${pg.orig + 1}</div>
          <div class="pc"><button class="ib" data-a="l" data-i="${i}" ${i === 0 ? 'disabled' : ''} title="Move left">←</button>
          <button class="ib" data-a="rot" data-i="${i}" title="Rotate">↻</button>
          <button class="ib dgr" data-a="del" data-i="${i}" title="Delete">✕</button>
          <button class="ib" data-a="r" data-i="${i}" ${i === pages.length - 1 ? 'disabled' : ''} title="Move right">→</button></div>`;
        g.appendChild(c);
      });
      $('go').disabled = pages.length === 0;
    }
    $('grid').addEventListener('click', (e) => {
      const b = e.target.closest('button[data-a]'); if (!b) return;
      const i = +b.dataset.i, a = b.dataset.a;
      if (a === 'del') pages.splice(i, 1);
      else if (a === 'rot') pages[i].rot = (pages[i].rot + 90) % 360;
      else if (a === 'l' && i > 0) [pages[i - 1], pages[i]] = [pages[i], pages[i - 1]];
      else if (a === 'r' && i < pages.length - 1) [pages[i + 1], pages[i]] = [pages[i], pages[i + 1]];
      render();
      $('status').textContent = `${pages.length} pages.`;
    });
    $('file').addEventListener('change', (e) => { const f = e.target.files?.[0]; if (f) load(f); });
    const dz = $('drop');
    dz.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('drag'); });
    dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
    dz.addEventListener('drop', (e) => { e.preventDefault(); dz.classList.remove('drag'); const f = e.dataTransfer?.files?.[0]; if (f) load(f); });

    $('go').addEventListener('click', async () => {
      if (!pages.length) return; $('go').disabled = true; $('status').textContent = 'Building PDF…';
      try {
        const src = await PDFLib.PDFDocument.load(srcBytes);
        const out = await PDFLib.PDFDocument.create();
        const copied = await out.copyPages(src, pages.map((p) => p.orig));
        copied.forEach((page, i) => {
          const base = page.getRotation().angle || 0;
          page.setRotation(PDFLib.degrees((base + pages[i].rot) % 360));
          out.addPage(page);
        });
        const bytes = await out.save();
        const a = document.createElement('a'); a.href = URL.createObjectURL(new Blob([bytes], { type: 'application/pdf' })); a.download = 'organized.pdf'; a.click();
        setTimeout(() => URL.revokeObjectURL(a.href), 20000);
        $('status').textContent = 'Done — organized PDF downloaded.';
      } catch (err) { $('status').textContent = 'Error: ' + (err.message || err); } finally { $('go').disabled = false; }
    });
  </script>
</BaseLayout>

<style>
  .tool { max-width: 820px; margin: 0 auto; }
  .thead { margin-bottom: 14px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; }
  .kick { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-subtle); font-weight: 600; }
  .thead h1 { margin-top: 4px; font-size: 28px; line-height: 1.15; }
  .sub { margin-top: 8px; font-size: 14px; color: var(--color-fg-muted); }
  .back { display: inline-block; margin-top: 10px; color: var(--color-fg-muted); text-decoration: none; font-size: 12px; border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 10px; }
  .back:hover { color: var(--color-fg); border-color: var(--color-accent); }
  .drop { border: 2px dashed var(--color-border); border-radius: 12px; padding: 22px; text-align: center; position: relative; margin-bottom: 12px; cursor: pointer; background: var(--color-bg-elevated); }
  .drop.drag { border-color: var(--color-accent); } .drop input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .dl { font-size: 14px; font-weight: 600; } .ds { font-size: 12px; color: var(--color-fg-muted); }
  .status { min-height: 20px; font-size: 12px; color: var(--color-fg-muted); margin: 8px 0; }
  .pgrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(124px, 1fr)); gap: 12px; margin-bottom: 14px; }
  .pcard { border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-bg-elevated); padding: 8px; text-align: center; }
  .pthumb { height: 130px; display: grid; place-items: center; overflow: hidden; background: #fff; border-radius: 6px; }
  .pthumb img { max-width: 100%; max-height: 100%; transition: transform 150ms ease; }
  .pn { font-size: 11px; color: var(--color-fg-muted); font-family: var(--font-mono); margin: 6px 0 4px; }
  .pc { display: flex; justify-content: center; gap: 3px; }
  .ib { width: 26px; height: 26px; border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-fg); border-radius: 6px; cursor: pointer; font-size: 12px; }
  .ib:hover:not(:disabled) { border-color: var(--color-accent); } .ib:disabled { opacity: 0.3; } .dgr:hover { border-color: #b94a48; color: #b94a48; }
  .btn { border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-fg); border-radius: 8px; padding: 9px 12px; font-size: 13px; cursor: pointer; }
  .primary { background: var(--color-accent); border-color: var(--color-accent); color: var(--color-accent-fg); font-weight: 600; } .primary:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
