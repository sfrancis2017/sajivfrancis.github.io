---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="PowerPoint to Markdown" description="Extract the text and outline of a .pptx into clean, reusable Markdown — in your browser." mainClass="max-w-4xl">
  <article class="tool">
    <header class="thead">
      <p class="kick">Tools · Convert</p>
      <h1>PowerPoint → Markdown</h1>
      <p class="sub">Pull the slide titles, bullets, and notes out of a <code>.pptx</code> into reusable Markdown. Pipe it into the Markdown → PDF/Word tool. Nothing is uploaded.</p>
      <a class="back" href="/tools/">Back to all tools</a>
    </header>

    <div class="drop" id="drop"><input type="file" id="file" accept=".pptx,application/vnd.openxmlformats-officedocument.presentationml.presentation" /><div class="dl">Select a .pptx file</div><div class="ds">Processing runs locally in your browser.</div></div>

    <div class="opts" id="opts" style="display:none;">
      <label class="chk"><input type="checkbox" id="notes" checked /> Include speaker notes</label>
      <button class="btn primary" id="go">Convert</button>
    </div>

    <div class="status" id="status">Select a .pptx to begin.</div>

    <div class="panel" id="outwrap" hidden>
      <h2>Markdown <span class="pill" id="chars"></span></h2>
      <textarea id="out" class="out" spellcheck="false"></textarea>
      <div class="row"><button class="btn" id="copy">Copy</button><button class="btn" id="dl">Download .md</button></div>
    </div>
  </article>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script is:inline>
    const $ = (id) => document.getElementById(id);
    let file = null;
    const numOf = (n) => parseInt((n.match(/(\d+)\.xml$/) || [])[1] || '0', 10);

    function sel(f) { file = f; $('opts').style.display = 'flex'; $('status').textContent = 'Ready: ' + f.name; }
    $('file').addEventListener('change', (e) => { const f = e.target.files?.[0]; if (f) sel(f); });
    const dz = $('drop');
    dz.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('drag'); });
    dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
    dz.addEventListener('drop', (e) => { e.preventDefault(); dz.classList.remove('drag'); const f = e.dataTransfer?.files?.[0]; if (f) sel(f); });

    function slideText(xml) {
      const doc = new DOMParser().parseFromString(xml, 'application/xml');
      const shapes = doc.getElementsByTagName('p:sp');
      let title = '', bullets = [];
      for (const sp of shapes) {
        const ph = sp.getElementsByTagName('p:ph')[0];
        const phType = ph ? (ph.getAttribute('type') || 'body') : '';
        for (const p of sp.getElementsByTagName('a:p')) {
          let text = '';
          for (const t of p.getElementsByTagName('a:t')) text += t.textContent;
          text = text.replace(/\s+/g, ' ').trim();
          if (!text) continue;
          const pPr = p.getElementsByTagName('a:pPr')[0];
          const lvl = pPr ? parseInt(pPr.getAttribute('lvl') || '0', 10) : 0;
          if ((phType === 'title' || phType === 'ctrTitle') && !title) title = text;
          else bullets.push({ text, lvl: Math.max(0, lvl) });
        }
      }
      return { title, bullets };
    }
    function notesText(xml) {
      const doc = new DOMParser().parseFromString(xml, 'application/xml');
      let out = [];
      for (const t of doc.getElementsByTagName('a:t')) { const s = t.textContent.trim(); if (s) out.push(s); }
      return out.join(' ').replace(/\s+/g, ' ').trim();
    }

    $('go').addEventListener('click', async () => {
      if (!file) return; $('go').disabled = true; $('status').textContent = 'Reading slides…';
      try {
        const zip = await JSZip.loadAsync(file);
        const slides = Object.keys(zip.files).filter((n) => /^ppt\/slides\/slide\d+\.xml$/.test(n)).sort((a, b) => numOf(a) - numOf(b));
        if (!slides.length) { $('status').textContent = 'No slides found — is this a .pptx?'; $('go').disabled = false; return; }
        let md = '';
        try { const core = await zip.file('docProps/core.xml')?.async('string'); const t = core && core.match(/<dc:title>([^<]*)<\/dc:title>/); if (t && t[1].trim()) md += `# ${t[1].trim()}\n\n`; } catch {}
        const wantNotes = $('notes').checked;
        for (let i = 0; i < slides.length; i++) {
          const { title, bullets } = slideText(await zip.file(slides[i]).async('string'));
          md += `## ${title || 'Slide ' + (i + 1)}\n\n`;
          for (const b of bullets) md += `${'  '.repeat(b.lvl)}- ${b.text}\n`;
          if (bullets.length) md += '\n';
          if (wantNotes) {
            const nf = zip.file(`ppt/notesSlides/notesSlide${i + 1}.xml`);
            if (nf) { const n = notesText(await nf.async('string')); if (n) md += `> **Notes:** ${n}\n\n`; }
          }
        }
        $('out').value = md.trim();
        $('outwrap').hidden = false;
        $('chars').textContent = `${slides.length} slides · ${$('out').value.length.toLocaleString()} chars`;
        $('status').textContent = `Done — ${slides.length} slides.`;
      } catch (err) { $('status').textContent = 'Error: ' + (err.message || err); } finally { $('go').disabled = false; }
    });

    $('copy').addEventListener('click', async () => { try { await navigator.clipboard.writeText($('out').value); $('status').textContent = 'Copied.'; } catch { $('status').textContent = 'Copy failed.'; } });
    $('dl').addEventListener('click', () => { const blob = new Blob([$('out').value], { type: 'text/markdown' }); const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = (file?.name || 'slides').replace(/\.pptx$/i, '') + '.md'; a.click(); setTimeout(() => URL.revokeObjectURL(a.href), 15000); });
  </script>
</BaseLayout>

<style>
  .tool { max-width: 760px; margin: 0 auto; }
  .thead { margin-bottom: 14px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; }
  .kick { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-subtle); font-weight: 600; }
  .thead h1 { margin-top: 4px; font-size: 28px; line-height: 1.15; }
  .sub { margin-top: 8px; font-size: 14px; color: var(--color-fg-muted); }
  .sub code { font-family: var(--font-mono); font-size: 12px; background: var(--color-bg-elevated); padding: 1px 5px; border-radius: 4px; }
  .back { display: inline-block; margin-top: 10px; color: var(--color-fg-muted); text-decoration: none; font-size: 12px; border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 10px; }
  .back:hover { color: var(--color-fg); border-color: var(--color-accent); }
  .drop { border: 2px dashed var(--color-border); border-radius: 12px; padding: 22px; text-align: center; position: relative; margin-bottom: 12px; cursor: pointer; background: var(--color-bg-elevated); }
  .drop.drag { border-color: var(--color-accent); } .drop input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .dl { font-size: 14px; font-weight: 600; } .ds { font-size: 12px; color: var(--color-fg-muted); }
  .opts { display: flex; align-items: center; gap: 14px; margin-bottom: 10px; }
  .chk { font-size: 13px; color: var(--color-fg-muted); display: inline-flex; align-items: center; gap: 6px; }
  .status { min-height: 20px; font-size: 12px; color: var(--color-fg-muted); margin-bottom: 8px; }
  .panel { background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: 12px; padding: 14px; }
  .panel h2 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-fg-muted); margin-bottom: 10px; display: flex; gap: 8px; align-items: center; }
  .pill { text-transform: none; font-size: 11px; border: 1px solid var(--color-border); border-radius: 999px; padding: 1px 8px; font-family: var(--font-mono); }
  .out { width: 100%; min-height: 320px; resize: vertical; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-bg); color: var(--color-fg); padding: 12px; font-family: var(--font-mono); font-size: 13px; line-height: 1.5; margin-bottom: 10px; }
  .row { display: flex; gap: 8px; }
  .btn { border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-fg); border-radius: 8px; padding: 9px 12px; font-size: 13px; cursor: pointer; }
  .btn:hover { border-color: var(--color-accent); } .primary { background: var(--color-accent); border-color: var(--color-accent); color: var(--color-accent-fg); font-weight: 600; } .primary:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
