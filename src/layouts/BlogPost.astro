---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import YouTube from '@/components/mdx/YouTube.astro';
import Cusdis from '@/components/Cusdis.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import PostNav from '@/components/PostNav.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { tagToSlug, buildPostUrl } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime?: number;
  headings?: Heading[];
  prev?: CollectionEntry<'blog'> | null;
  next?: CollectionEntry<'blog'> | null;
}

const { post, readingTime, headings = [], prev = null, next = null } = Astro.props;
const { title, subtitle, description, pubDate, updatedDate, tags, videoUrl, coverImage } = post.data;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });

const venueLabel =
  post.data.publishMode === 'venue-first' && post.data.venueName
    ? `Originally published in ${post.data.venueName}`
    : null;

// Canonical URL for share intents — must be absolute so X / LinkedIn
// crawl the right OG metadata.
const postUrl = new URL(buildPostUrl(post), Astro.site).toString();
const shareText = `${title} — by Sajiv Francis`;
const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(postUrl)}`;
const linkedInShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`;
---

<BaseLayout title={title} description={description} ogImage={coverImage}>
  <ReadingProgress />
  <TableOfContents headings={headings} />

  <Breadcrumbs
    crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Writing', href: '/blog/' },
      { label: title },
    ]}
  />

  <article class="prose dark:prose-invert max-w-none prose-headings:tracking-tight prose-headings:scroll-mt-24 prose-a:text-[var(--color-accent)] prose-a:underline prose-a:underline-offset-2 prose-img:rounded-md prose-img:border prose-img:border-[var(--color-border)] prose-pre:border prose-pre:border-[var(--color-border)] prose-code:before:content-none prose-code:after:content-none">
    <header class="not-prose mb-10 pb-8 border-b border-[var(--color-border)]">
      <div class="flex flex-wrap items-center gap-2 text-sm text-[var(--color-fg-subtle)] uppercase tracking-wider">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {readingTime != null && <span aria-hidden="true">·</span>}
        {readingTime != null && <span>{readingTime} min read</span>}
        {venueLabel && <span aria-hidden="true">·</span>}
        {venueLabel && <span class="normal-case tracking-normal">{venueLabel}</span>}
      </div>

      <h1 class="mt-4 text-4xl md:text-5xl font-semibold tracking-tight leading-[1.1]">
        {title}
      </h1>

      {
        subtitle && (
          <p class="mt-3 text-xl text-[var(--color-fg-muted)] leading-snug">{subtitle}</p>
        )
      }

      {
        description && (
          <p class="mt-4 text-base text-[var(--color-fg-muted)]">{description}</p>
        )
      }

      {
        tags.length > 0 && (
          <ul class="mt-5 flex flex-wrap gap-2 text-xs text-[var(--color-fg-subtle)]">
            {tags.map((tag) => (
              <li>
                <a
                  href={`/blog/tag/${tagToSlug(tag)}/`}
                  class="px-2 py-0.5 border border-[var(--color-border)] rounded-sm hover:border-[var(--color-fg-muted)] no-underline"
                >
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      coverImage && (
        <figure class="not-prose mb-10 -mt-2">
          <img
            src={coverImage}
            alt={post.data.coverAlt ?? ''}
            class="w-full aspect-[2/1] object-cover rounded-md border border-[var(--color-border)]"
            loading="eager"
            decoding="async"
          />
          {post.data.coverAlt && (
            <figcaption class="mt-2 text-xs text-[var(--color-fg-subtle)] italic">
              {post.data.coverAlt}
            </figcaption>
          )}
        </figure>
      )
    }

    {
      videoUrl && (
        <div class="not-prose mb-8">
          <YouTube url={videoUrl} title={title} />
        </div>
      )
    }

    <slot />

    {
      updatedDate && (
        <p class="mt-12 pt-6 border-t border-[var(--color-border)] text-sm text-[var(--color-fg-subtle)] not-prose">
          Updated {formatDate(updatedDate)}.
        </p>
      )
    }

    <PostNav prev={prev} next={next} />

    <section class="mt-12 pt-8 border-t border-[var(--color-border)] not-prose print-hide" aria-label="Share this post">
      <div class="flex items-center gap-3 flex-wrap">
        <span class="text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] font-semibold">
          Share this →
        </span>
        <a
          href={twitterShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg-muted)] text-[var(--color-fg)] no-underline hover:no-underline"
          aria-label="Share on X"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          Post on X
        </a>
        <a
          href={linkedInShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg-muted)] text-[var(--color-fg)] no-underline hover:no-underline"
          aria-label="Share on LinkedIn"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
          LinkedIn
        </a>
        <button
          type="button"
          data-share-copy={postUrl}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg-muted)] text-[var(--color-fg)] cursor-pointer"
          aria-label="Copy link"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
          <span data-share-copy-label>Copy link</span>
        </button>
      </div>
    </section>

    <footer class="mt-12 pt-8 border-t border-[var(--color-border)] not-prose flex items-center justify-between gap-4">
      <a href="/blog/" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] no-underline">
        ← All writing
      </a>
      <button
        type="button"
        data-print-trigger
        class="print-hide text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] underline-offset-2 hover:underline inline-flex items-center gap-1.5"
        aria-label="Print or save as PDF"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="6 9 6 2 18 2 18 9" />
          <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
          <rect x="6" y="14" width="12" height="8" />
        </svg>
        Print / PDF
      </button>
    </footer>
  </article>

  <Cusdis
    pageId={post.slug}
    pageUrl={postUrl}
    pageTitle={title}
  />
</BaseLayout>

<script>
  document
    .querySelector('[data-print-trigger]')
    ?.addEventListener('click', () => window.print());

  // Copy-link share button
  const copyBtn = document.querySelector<HTMLButtonElement>('[data-share-copy]');
  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.dataset.shareCopy;
    const label = copyBtn.querySelector<HTMLElement>('[data-share-copy-label]');
    if (!url) return;
    try {
      await navigator.clipboard.writeText(url);
      const original = label?.textContent ?? 'Copy link';
      if (label) label.textContent = '✓ Copied';
      setTimeout(() => {
        if (label) label.textContent = original;
      }, 1500);
    } catch {
      // Clipboard API can fail under some permissions — show URL in a prompt
      window.prompt('Copy this URL:', url);
    }
  });
</script>

<script>
  // Lazy-render Mermaid diagrams. The mermaid bundle (~600KB) is only
  // imported when a post actually contains a ```mermaid block, so
  // diagram-free posts pay zero cost.
  //
  // Astro renders fenced code through Shiki, which emits
  // `<pre data-language="mermaid">...</pre>` — the language goes on the
  // <pre> as a data attribute, not as `class="language-mermaid"` on the
  // inner <code>. We select on the data attribute and grab the raw
  // text via .textContent (strips Shiki's syntax-highlight spans).
  const initialBlocks = document.querySelectorAll(
    'pre[data-language="mermaid"]'
  );

  if (initialBlocks.length > 0) {
    const { default: mermaid } = await import('mermaid');

    const isDark = () =>
      document.documentElement.dataset.theme === 'dark';

    function configure() {
      mermaid.initialize({
        startOnLoad: false,
        theme: isDark() ? 'dark' : 'default',
        securityLevel: 'strict',
        fontFamily: 'Inter, ui-sans-serif, system-ui, sans-serif',
      });
    }

    async function renderAll() {
      const targets = document.querySelectorAll<HTMLElement>(
        'pre[data-language="mermaid"], .mermaid-rendered'
      );
      for (const el of targets) {
        const source =
          el.getAttribute('data-source') ?? el.textContent ?? '';
        const id = 'mermaid-' + Math.random().toString(36).slice(2, 10);
        try {
          const { svg } = await mermaid.render(id, source);
          const wrapper = document.createElement('div');
          wrapper.className = 'mermaid-rendered';
          wrapper.setAttribute('data-source', source);
          wrapper.innerHTML = svg;
          // Append an expand button. Dense architecture diagrams scale
          // down too far to read on the post page; clicking opens a
          // fullscreen modal with the SVG at natural size + pan/zoom.
          const expandBtn = document.createElement('button');
          expandBtn.type = 'button';
          expandBtn.className = 'mermaid-expand';
          expandBtn.setAttribute('aria-label', 'Expand diagram');
          expandBtn.title = 'Expand diagram';
          expandBtn.innerHTML =
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>';
          expandBtn.addEventListener('click', () => openMermaidModal(wrapper));
          wrapper.appendChild(expandBtn);
          el.replaceWith(wrapper);
        } catch (err) {
          console.warn('Mermaid render failed:', err);
        }
      }
    }

    // ---- Fullscreen expand modal ---------------------------------------
    // One modal shared across every diagram on the page. Cloning the SVG
    // (rather than moving it) means the inline copy stays in place.
    function ensureMermaidModal(): HTMLElement {
      let modal = document.getElementById('mermaid-modal');
      if (modal) return modal;
      modal = document.createElement('div');
      modal.id = 'mermaid-modal';
      modal.className = 'mermaid-modal';
      modal.setAttribute('role', 'dialog');
      modal.setAttribute('aria-modal', 'true');
      modal.setAttribute('aria-label', 'Diagram fullscreen view');
      modal.hidden = true;
      modal.innerHTML = `
        <div class="mermaid-modal-backdrop" data-close></div>
        <div class="mermaid-modal-panel">
          <button type="button" class="mermaid-modal-close" data-close aria-label="Close">×</button>
          <div class="mermaid-modal-svg"></div>
        </div>
      `;
      document.body.appendChild(modal);
      modal.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.dataset && target.dataset.close !== undefined) closeMermaidModal();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal!.hidden) closeMermaidModal();
      });
      return modal;
    }

    function openMermaidModal(source: HTMLElement) {
      const modal = ensureMermaidModal();
      const slot = modal.querySelector('.mermaid-modal-svg') as HTMLElement;
      const svg = source.querySelector('svg');
      if (!svg) return;
      slot.innerHTML = '';
      const clone = svg.cloneNode(true) as SVGElement;
      // Strip width/height caps so the SVG renders at intrinsic size
      // inside the modal's scrollable container.
      clone.removeAttribute('width');
      clone.removeAttribute('height');
      clone.removeAttribute('style');
      slot.appendChild(clone);
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function closeMermaidModal() {
      const modal = document.getElementById('mermaid-modal');
      if (!modal) return;
      modal.hidden = true;
      document.body.style.overflow = '';
    }

    configure();
    await renderAll();

    // Re-render diagrams when the user toggles theme so colors match
    new MutationObserver((muts) => {
      if (muts.some((m) => m.attributeName === 'data-theme')) {
        configure();
        renderAll();
      }
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }
</script>
