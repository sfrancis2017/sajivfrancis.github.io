---
// Owner-mode indicator for /tools/* pages.
//
// sajivfrancis.com is served by GitHub Pages (no Cloudflare Access on this
// origin), so "owner mode" = presence of the TOOLS owner token in localStorage
// ('tools-access-token'), bootstrapped via the Access SSO handoff on
// chat.sajivfrancis.com. This badge makes that state VISIBLE (you flagged there
// was no way to tell if you're signed in) and offers one-click sign-in /
// sign-out. It's purely a convenience + status surface — the actual gating is
// the TOOLS_TOKEN check on the tools-api owner endpoints.
---

<div id="tools-owner-badge" class="tools-owner-badge" data-owner="0" hidden>
  <button type="button" id="tools-owner-action" class="tools-owner-action" aria-live="polite"></button>
</div>

<style>
  .tools-owner-badge {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    z-index: 50;
  }
  .tools-owner-action {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font: inherit;
    font-size: 0.8rem;
    line-height: 1;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, currentColor 25%, transparent);
    background: var(--color-bg, #fff);
    color: var(--color-fg-muted, #555);
    cursor: pointer;
    box-shadow: 0 2px 10px -4px rgba(0, 0, 0, 0.3);
    opacity: 0.7;
    transition: opacity 0.15s, color 0.15s, border-color 0.15s;
  }
  .tools-owner-action:hover { opacity: 1; }
  /* Owner-mode: green accent so it's unmistakable you're elevated. */
  .tools-owner-badge[data-owner='1'] .tools-owner-action {
    color: #15803d;
    border-color: color-mix(in srgb, #15803d 45%, transparent);
    opacity: 0.9;
  }
  :global([data-theme='dark']) .tools-owner-action {
    background: #1a1a1a;
    color: #aaa;
  }
  :global([data-theme='dark']) .tools-owner-badge[data-owner='1'] .tools-owner-action {
    color: #4ade80;
  }
</style>

<script is:inline>
  (function () {
    const KEY = 'tools-access-token';
    const HANDOFF = 'https://chat.sajivfrancis.com/admin/api/sso-handoff?token=tools&redirect=';
    const LOGOUT = 'https://sajivfrancis.cloudflareaccess.com/cdn-cgi/access/logout?returnTo=';

    // If we just returned from the Access handoff, capture the token from the
    // URL fragment (it never reached the server) and strip the hash.
    const m = (location.hash || '').match(/(?:^#|&)owner-token=([^&]+)/);
    if (m) {
      try { localStorage.setItem(KEY, decodeURIComponent(m[1])); } catch (e) {}
      history.replaceState(null, '', location.pathname + location.search);
    }

    const badge = document.getElementById('tools-owner-badge');
    const btn = document.getElementById('tools-owner-action');
    if (!badge || !btn) return;

    function render() {
      const owner = !!localStorage.getItem(KEY);
      badge.dataset.owner = owner ? '1' : '0';
      btn.textContent = owner ? '● Owner mode — sign out' : '🔑 Owner sign-in';
      btn.title = owner
        ? 'Signed in as owner. Click to sign out everywhere (chat, trading, tools, writing).'
        : 'Sign in with Cloudflare Access to use owner tools without pasting a token.';
      badge.hidden = false;
    }

    btn.addEventListener('click', function () {
      if (localStorage.getItem(KEY)) {
        if (!confirm('Sign out of owner mode everywhere (chat, trading, tools, writing)?\nThis ends the shared session on this device.')) return;
        localStorage.removeItem(KEY);
        location.href = LOGOUT + encodeURIComponent(location.origin + location.pathname);
      } else {
        location.href = HANDOFF + encodeURIComponent(location.href);
      }
    });

    render();
  })();
</script>
