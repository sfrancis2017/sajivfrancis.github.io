---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Search from '@/components/Search.astro';
import ChatLauncher from '@/components/ChatLauncher.astro';

interface Props {
  title?: string;
  description?: string;
  /**
   * Tailwind max-width class for <main>. Defaults to `max-w-3xl` (prose width).
   * Pages that need more horizontal room (e.g. /lab/* tools) can pass `max-w-6xl` etc.
   */
  mainClass?: string;
  /**
   * Open Graph image path (absolute URL or root-relative). Defaults to the
   * site-wide social card so shares on LinkedIn / X always have a preview.
   * Per-post images can be passed in for richer previews.
   */
  ogImage?: string;
}

const {
  title = 'Sajiv Francis',
  description = 'Enterprise Architect writing about the intersection of AI and architecture practice.',
  mainClass = 'max-w-3xl',
  ogImage = '/img/blog-image.png',
} = Astro.props;
const ogImageUrl = new URL(ogImage, Astro.site).toString();

const fullTitle = title === 'Sajiv Francis' ? title : `${title} — Sajiv Francis`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Inter variable font -->
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{fullTitle}</title>

    <!-- Theme: read from cross-subdomain cookie first (so docs / chat /
         main stay in sync), fall back to localStorage, then to system
         preference. Set BEFORE paint to avoid a flash. Forward-syncs
         whichever source won so the next visit is fast. -->
    <script is:inline>
      (function () {
        const m = document.cookie.match(/(?:^|;\s*)theme=(light|dark)/);
        const cookieTheme = m ? m[1] : null;
        const localTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = cookieTheme || localTheme || (prefersDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
        if (cookieTheme !== theme) {
          document.cookie =
            'theme=' + theme + '; Domain=.sajivfrancis.com; Path=/; Max-Age=31536000; SameSite=Lax; Secure';
        }
        if (localTheme !== theme) {
          try { localStorage.setItem('theme', theme); } catch (_) {}
        }
      })();
    </script>

    <!-- Analytics: GoatCounter (privacy-friendly, no cookies) -->
    <script
      is:inline
      data-goatcounter="https://sajivfrancis.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class:list={['flex-1 w-full mx-auto px-6 py-12', mainClass]}>
      <slot />
    </main>
    <Footer />
    <Search />
    <ChatLauncher />
  </body>
</html>
