---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="PDF Merge"
  description="Combine multiple PDFs into one in-browser. Reorder pages, nothing is uploaded."
  mainClass="max-w-4xl"
>
  <article class="splitter-page">
    <header class="splitter-head">
      <p class="splitter-kicker">Tools</p>
      <h1>PDF Merge</h1>
      <p class="splitter-subtitle">Combine multiple PDFs into a single file, in the order you choose.</p>
      <a class="back-link" href="/tools/">Back to all tools</a>
    </header>

    <div class="drop-zone" id="drop-zone">
      <input type="file" id="file-input" accept=".pdf,application/pdf" multiple />
      <div class="drop-label">Select PDFs (or drag them here)</div>
      <div class="drop-sub">No upload. Add files in any order, then reorder below. Processing runs locally in your browser.</div>
    </div>

    <div class="settings" id="list-settings" style="display:none;">
      <h2>Files to merge <span id="file-count" class="count-pill"></span></h2>
      <ol class="file-list" id="file-list"></ol>
      <div class="list-actions">
        <button class="btn" id="clear-all">Clear all</button>
        <span class="help" id="list-help"></span>
      </div>
      <label class="field" style="margin-top:12px;">
        <span>Output file name</span>
        <input type="text" id="out-name" value="merged.pdf" />
      </label>
    </div>

    <div class="status" id="status">Select two or more PDFs to begin.</div>

    <button class="btn btn-primary" id="merge-btn" disabled>Merge PDFs</button>

    <div class="summary" id="summary">
      <div class="summary-title" id="summary-title">Ready</div>
      <div class="summary-meta" id="summary-meta"></div>
      <div class="summary-actions">
        <button class="btn btn-primary" id="download-merged">Download merged PDF</button>
      </div>
    </div>
  </article>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
  <script is:inline>
    const $ = (id) => document.getElementById(id);

    // Each entry: { id, file, pages|null, error|null }
    let items = [];
    let mergedBlob = null;
    let uid = 0;

    const fmtSize = (n) => (n / 1024 / 1024).toFixed(n < 1024 * 1024 ? 2 : 1) + ' MB';

    async function readPageCount(file) {
      try {
        const bytes = new Uint8Array(await file.arrayBuffer());
        const doc = await PDFLib.PDFDocument.load(bytes, { ignoreEncryption: true });
        return doc.getPageCount();
      } catch (e) {
        return null; // unreadable / encrypted
      }
    }

    function renderList() {
      const list = $('file-list');
      list.innerHTML = '';
      items.forEach((it, i) => {
        const li = document.createElement('li');
        li.className = 'file-row' + (it.error ? ' file-row-error' : '');
        li.innerHTML = `
          <span class="file-idx">${i + 1}</span>
          <span class="file-meta">
            <span class="file-name">${it.file.name.replace(/</g, '&lt;')}</span>
            <span class="file-sub">${it.error ? '⚠ ' + it.error : (it.pages == null ? 'reading…' : it.pages + ' page' + (it.pages === 1 ? '' : 's')) + ' · ' + fmtSize(it.file.size)}</span>
          </span>
          <span class="file-ctrls">
            <button type="button" class="icon-btn" data-act="up" data-id="${it.id}" title="Move up" aria-label="Move up" ${i === 0 ? 'disabled' : ''}>↑</button>
            <button type="button" class="icon-btn" data-act="down" data-id="${it.id}" title="Move down" aria-label="Move down" ${i === items.length - 1 ? 'disabled' : ''}>↓</button>
            <button type="button" class="icon-btn icon-btn-danger" data-act="remove" data-id="${it.id}" title="Remove" aria-label="Remove">✕</button>
          </span>`;
        list.appendChild(li);
      });

      $('list-settings').style.display = items.length ? '' : 'none';
      $('file-count').textContent = items.length ? `${items.length}` : '';
      const totalPages = items.reduce((a, b) => a + (b.pages || 0), 0);
      const usable = items.filter((it) => !it.error).length;
      $('list-help').textContent = items.length ? `${totalPages} pages across ${usable} usable file${usable === 1 ? '' : 's'}.` : '';
      $('merge-btn').disabled = usable < 2;
      $('status').textContent =
        usable < 2 ? 'Add at least two readable PDFs to merge.' : `Ready to merge ${usable} files.`;
      $('summary').classList.remove('visible');
    }

    async function addFiles(fileList) {
      const incoming = Array.from(fileList).filter(
        (f) => f.name.toLowerCase().endsWith('.pdf') || f.type === 'application/pdf'
      );
      if (!incoming.length) {
        $('status').textContent = 'No PDF files detected in that selection.';
        return;
      }
      for (const file of incoming) {
        // skip exact duplicates (same name + size)
        if (items.some((it) => it.file.name === file.name && it.file.size === file.size)) continue;
        const entry = { id: ++uid, file, pages: null, error: null };
        items.push(entry);
      }
      renderList();
      // read page counts lazily, refresh as they resolve
      await Promise.all(
        items
          .filter((it) => it.pages == null && !it.error)
          .map(async (it) => {
            const pages = await readPageCount(it.file);
            if (pages == null) it.error = 'Could not read (encrypted or corrupt PDF)';
            else it.pages = pages;
          })
      );
      renderList();
    }

    async function mergePdfs() {
      const out = await PDFLib.PDFDocument.create();
      let pageTotal = 0;
      for (const it of items) {
        if (it.error) continue;
        const bytes = new Uint8Array(await it.file.arrayBuffer());
        const src = await PDFLib.PDFDocument.load(bytes, { ignoreEncryption: true });
        const pages = await out.copyPages(src, src.getPageIndices());
        for (const p of pages) out.addPage(p);
        pageTotal += pages.length;
      }
      const finalBytes = await out.save();
      return { blob: new Blob([finalBytes], { type: 'application/pdf' }), pageTotal };
    }

    // ---- events --------------------------------------------------------
    $('file-input').addEventListener('change', (e) => {
      if (e.target.files?.length) addFiles(e.target.files);
      e.target.value = '';
    });

    $('file-list').addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-act]');
      if (!btn) return;
      const id = Number(btn.dataset.id);
      const i = items.findIndex((it) => it.id === id);
      if (i < 0) return;
      const act = btn.dataset.act;
      if (act === 'remove') items.splice(i, 1);
      else if (act === 'up' && i > 0) [items[i - 1], items[i]] = [items[i], items[i - 1]];
      else if (act === 'down' && i < items.length - 1) [items[i + 1], items[i]] = [items[i], items[i + 1]];
      renderList();
    });

    $('clear-all').addEventListener('click', () => {
      items = [];
      renderList();
    });

    const dropZone = $('drop-zone');
    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag'));
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag');
      if (e.dataTransfer?.files?.length) addFiles(e.dataTransfer.files);
    });

    $('merge-btn').addEventListener('click', async () => {
      const usable = items.filter((it) => !it.error);
      if (usable.length < 2) return;
      $('merge-btn').disabled = true;
      $('status').textContent = 'Merging PDFs…';
      try {
        const { blob, pageTotal } = await mergePdfs();
        mergedBlob = blob;
        $('summary-title').textContent = 'Merged PDF ready';
        $('summary-meta').textContent = `${usable.length} files · ${pageTotal} pages · ${fmtSize(blob.size)}`;
        $('summary').classList.add('visible');
        $('status').textContent = 'Done. Download your merged PDF below.';
      } catch (error) {
        $('status').textContent = `Error: ${error.message || 'Failed to merge PDFs.'}`;
      } finally {
        $('merge-btn').disabled = items.filter((it) => !it.error).length < 2;
      }
    });

    $('download-merged').addEventListener('click', () => {
      if (!mergedBlob) return;
      let name = ($('out-name').value || 'merged.pdf').trim();
      if (!name.toLowerCase().endsWith('.pdf')) name += '.pdf';
      const link = document.createElement('a');
      link.href = URL.createObjectURL(mergedBlob);
      link.download = name;
      link.click();
      setTimeout(() => URL.revokeObjectURL(link.href), 20000);
    });
  </script>
</BaseLayout>

<style>
  .splitter-page { max-width: 700px; margin: 0 auto; }
  .splitter-head { margin-bottom: 14px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; }
  .splitter-kicker { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-subtle); font-weight: 600; }
  .splitter-head h1 { margin-top: 4px; font-size: 28px; line-height: 1.15; letter-spacing: -0.02em; }
  .splitter-subtitle { margin-top: 8px; font-size: 14px; color: var(--color-fg-muted); }
  .back-link { display: inline-block; margin-top: 10px; color: var(--color-fg-muted); text-decoration: none; font-size: 12px; border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 10px; }
  .back-link:hover { color: var(--color-fg); border-color: var(--color-accent); }

  .drop-zone { border: 2px dashed var(--color-border); border-radius: 12px; padding: 22px; text-align: center; position: relative; margin-bottom: 12px; transition: border-color 0.15s, background 0.15s; cursor: pointer; background: var(--color-bg-elevated); }
  .drop-zone.drag { border-color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 8%, var(--color-bg-elevated)); }
  .drop-zone input { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; }
  .drop-label { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
  .drop-sub { font-size: 12px; color: var(--color-fg-muted); }

  .settings { background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: 12px; padding: 14px; margin-bottom: 12px; }
  .settings h2 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-fg-muted); margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
  .count-pill { text-transform: none; letter-spacing: 0; font-size: 11px; color: var(--color-fg); border: 1px solid var(--color-border); border-radius: 999px; padding: 1px 8px; }

  .file-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .file-row { display: flex; align-items: center; gap: 10px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 8px; padding: 8px 10px; }
  .file-row-error { border-color: #b94a48; }
  .file-idx { flex: 0 0 auto; width: 22px; height: 22px; display: grid; place-items: center; font-size: 11px; font-family: var(--font-mono); color: var(--color-fg-muted); border: 1px solid var(--color-border); border-radius: 6px; }
  .file-meta { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
  .file-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .file-sub { font-size: 11px; color: var(--color-fg-muted); font-family: var(--font-mono); }
  .file-ctrls { flex: 0 0 auto; display: flex; gap: 4px; }
  .icon-btn { width: 28px; height: 28px; display: grid; place-items: center; border: 1px solid var(--color-border); background: var(--color-bg-elevated); color: var(--color-fg); border-radius: 6px; cursor: pointer; font-size: 13px; }
  .icon-btn:hover:not(:disabled) { border-color: var(--color-accent); }
  .icon-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .icon-btn-danger:hover:not(:disabled) { border-color: #b94a48; color: #b94a48; }

  .list-actions { display: flex; align-items: center; gap: 12px; margin-top: 10px; }

  .field { display: flex; flex-direction: column; gap: 5px; }
  .field span { font-size: 12px; color: var(--color-fg-muted); }
  .field input { width: 100%; background: var(--color-bg); border: 1px solid var(--color-border); color: var(--color-fg); border-radius: 8px; padding: 8px 10px; font-size: 13px; font-family: var(--font-sans); }

  .help { font-size: 12px; color: var(--color-fg-muted); line-height: 1.45; }
  .status { min-height: 20px; font-size: 12px; color: var(--color-fg-muted); margin-bottom: 8px; }

  .summary { background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: 12px; padding: 12px; margin-top: 12px; display: none; }
  .summary.visible { display: block; }
  .summary-title { color: #2f7a4d; font-size: 14px; font-weight: 600; margin-bottom: 7px; }
  :root[data-theme='dark'] .summary-title { color: #78d69c; }
  .summary-meta { font-family: var(--font-mono); font-size: 12px; color: var(--color-fg-muted); line-height: 1.5; margin-bottom: 10px; }
  .summary-actions { display: flex; gap: 8px; flex-wrap: wrap; }

  .btn { border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-fg); border-radius: 8px; padding: 9px 12px; font-size: 13px; font-family: var(--font-sans); cursor: pointer; }
  .btn:hover { border-color: var(--color-accent); }
  .btn-primary { background: var(--color-accent); border-color: var(--color-accent); color: var(--color-accent-fg); font-weight: 600; }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

  @media (max-width: 640px) {
    .splitter-head h1 { font-size: 24px; }
  }
</style>
