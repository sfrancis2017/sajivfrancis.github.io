---
import { getCollection, type CollectionEntry } from 'astro:content';
import BlogPost from '@/layouts/BlogPost.astro';
import { getAdjacentPosts } from '@/lib/utils';
import fs from 'node:fs';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => {
    const date = post.data.pubDate;
    const year = date.getUTCFullYear();
    const month = String(date.getUTCMonth() + 1).padStart(2, '0');
    const day = String(date.getUTCDate()).padStart(2, '0');
    const cleanSlug = post.slug.replace(/^\d{4}-\d{2}-\d{2}-/, '');
    return {
      params: { slug: `${year}/${month}/${day}/${cleanSlug}` },
      props: { post, allPosts: posts },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  allPosts: CollectionEntry<'blog'>[];
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await post.render();

const wordCount = post.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const { prev, next } = getAdjacentPosts(post, allPosts);

// Build-time Download-PDF: show the button when a PDF exists for this post's slug
// (generated by scripts/build-pdfs.mjs → public/pdf/blog/YYYY/MM/DD/slug.pdf).
const d = post.data.pubDate;
const pdfSlug = `blog/${d.getUTCFullYear()}/${String(d.getUTCMonth() + 1).padStart(2, '0')}/${String(d.getUTCDate()).padStart(2, '0')}/${post.slug.replace(/^\d{4}-\d{2}-\d{2}-/, '')}`;
let pdfHref: string | null = null;
try {
  const mf = JSON.parse(fs.readFileSync('public/pdf/manifest.json', 'utf8'));
  if (Array.isArray(mf.slugs) && mf.slugs.includes(pdfSlug)) pdfHref = `/pdf/${pdfSlug}.pdf`;
} catch { /* no manifest (local build) — no button */ }
---

<BlogPost post={post} readingTime={readingTime} headings={headings} prev={prev} next={next} pdfHref={pdfHref}>
  <Content />
</BlogPost>
