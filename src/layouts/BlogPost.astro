---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import YouTube from '@/components/mdx/YouTube.astro';
import { tagToSlug } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime?: number;
}

const { post, readingTime } = Astro.props;
const { title, subtitle, description, pubDate, updatedDate, tags, videoUrl, coverImage, coverAlt } =
  post.data;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const venueLabel =
  post.data.publishMode === 'venue-first' && post.data.venueName
    ? `Originally published in ${post.data.venueName}`
    : null;
---

<BaseLayout title={title} description={description}>
  <ReadingProgress />

  <article class="prose dark:prose-invert max-w-none prose-headings:tracking-tight prose-a:text-[var(--color-accent)] prose-a:underline prose-a:underline-offset-2 prose-img:rounded-md prose-img:border prose-img:border-[var(--color-border)] prose-pre:border prose-pre:border-[var(--color-border)] prose-code:before:content-none prose-code:after:content-none">
    <header class="not-prose mb-10 pb-8 border-b border-[var(--color-border)]">
      <div class="flex flex-wrap items-center gap-2 text-sm text-[var(--color-fg-subtle)] uppercase tracking-wider">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {readingTime != null && <span aria-hidden="true">·</span>}
        {readingTime != null && <span>{readingTime} min read</span>}
        {venueLabel && <span aria-hidden="true">·</span>}
        {venueLabel && <span class="normal-case tracking-normal">{venueLabel}</span>}
      </div>

      <h1 class="mt-4 text-4xl md:text-5xl font-semibold tracking-tight leading-[1.1]">
        {title}
      </h1>

      {
        subtitle && (
          <p class="mt-3 text-xl text-[var(--color-fg-muted)] leading-snug">
            {subtitle}
          </p>
        )
      }

      {
        description && (
          <p class="mt-4 text-base text-[var(--color-fg-muted)]">{description}</p>
        )
      }

      {
        tags.length > 0 && (
          <ul class="mt-5 flex flex-wrap gap-2 text-xs text-[var(--color-fg-subtle)]">
            {tags.map((tag) => (
              <li>
                <a
                  href={`/blog/tag/${tagToSlug(tag)}/`}
                  class="px-2 py-0.5 border border-[var(--color-border)] rounded-sm hover:border-[var(--color-fg-muted)] no-underline"
                >
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      videoUrl && (
        <div class="not-prose mb-8">
          <YouTube url={videoUrl} title={title} />
        </div>
      )
    }

    <slot />

    {
      updatedDate && (
        <p class="mt-12 pt-6 border-t border-[var(--color-border)] text-sm text-[var(--color-fg-subtle)] not-prose">
          Updated {formatDate(updatedDate)}.
        </p>
      )
    }

    <footer class="mt-16 pt-8 border-t border-[var(--color-border)] not-prose">
      <a href="/blog/" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] no-underline">
        ← All writing
      </a>
    </footer>
  </article>
</BaseLayout>
