---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sajiv Francis"
  description="Enterprise Architect writing about the intersection of AI and architecture practice."
>
  <section class="space-y-6">
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight leading-[1.1]">
      Sajiv Francis
    </h1>
    <p class="text-lg leading-relaxed text-[var(--color-fg-muted)]">
      Enterprise Architect at a Fortune 50 technology company, leading AI
      programmes at the intersection of enterprise systems, cloud architecture,
      and large language models. TOGAF 10 certified, Stanford AI-Driven
      Leadership. Background in NLP, document intelligence, and enterprise SAP
      ecosystems.
    </p>
    <p class="text-base text-[var(--color-fg-muted)]">
      Writing about the future of architecture practice at the intersection of
      AI and organisational design.
    </p>
  </section>

  <section class="mt-16 pt-12 border-t border-[var(--color-border)]">
    <h2 class="text-sm uppercase tracking-widest text-[var(--color-fg-subtle)] mb-6">
      Recent Writing
    </h2>
    <p class="text-[var(--color-fg-muted)]">
      Posts coming soon. <a href="/blog/" class="underline">View archive</a>.
    </p>
  </section>

  <section class="mt-16 pt-12 border-t border-[var(--color-border)]">
    <h2 class="text-sm uppercase tracking-widest text-[var(--color-fg-subtle)] mb-6">
      Find Me
    </h2>
    <ul class="space-y-2 text-[var(--color-fg-muted)]">
      <li>
        <a href="https://github.com/sfrancis2017" target="_blank" rel="noopener noreferrer">
          GitHub
        </a>
      </li>
      <li>
        <a
          href="https://www.linkedin.com/in/sajiv-francis"
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn
        </a>
      </li>
      <li>
        <a href="https://docs.sajivfrancis.com/" target="_blank" rel="noopener noreferrer">
          Docs (SAP &amp; engineering knowledge base)
        </a>
      </li>
    </ul>
  </section>
</BaseLayout>
