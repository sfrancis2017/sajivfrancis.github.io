---
// Floating launcher → the Wall Street Intelligence terminal. The terminal itself is
// owner-gated (TRADING_TOKEN), so this is safe to show publicly — visitors can open it
// but see no data without the token.
const TRADING_URL = 'https://trading.sajivfrancis.com';
---

<a
  class="trading-launcher"
  href={TRADING_URL}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Open the trading terminal"
  title="Wall Street Intelligence Terminal"
>
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor"
       stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M3 3v18h18" />
    <path d="M7 14l4-4 3 3 5-6" />
  </svg>
  <span>Trading</span>
</a>

<style>
  .trading-launcher {
    position: fixed;
    bottom: 22px;
    right: 22px;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 18px;
    border-radius: 999px;
    background: #0f1217;
    color: #f5a623;
    border: 1px solid #2a3346;
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 13px;
    letter-spacing: 0.03em;
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.28);
    transition: transform 0.15s ease, box-shadow 0.15s ease, color 0.15s ease;
  }
  .trading-launcher:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.38);
    color: #ffce6b;
  }
  .trading-launcher svg { flex-shrink: 0; }

  @media (max-width: 600px) {
    .trading-launcher { padding: 12px; }
    .trading-launcher span { display: none; }
  }
</style>
