---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Flow Register → Diagrams"
  description="Upload an Excel/CSV flow register and rebuild it as Mermaid and draw.io diagrams — split into application, database, and technology layers, and by node type (strategy, objective, people, projects) that share the same hops."
  mainClass="max-w-5xl"
>
  <article class="tool">
    <header class="thead">
      <p class="kick">Tools · Architecture</p>
      <h1>Flow Register → Diagrams</h1>
      <p class="sub">
        The reverse pipeline. Upload an Excel or CSV <strong>flow register</strong> (the kind
        the <a href="/tools/diagram-pipeline/">Diagram Pipeline</a> exports) and rebuild it as
        diagrams that share the same hops. If the register has a <code>Type</code> column it
        splits by node type — a clean <strong>application</strong> map, plus
        <strong>strategy/objective</strong>, <strong>people</strong>, and <strong>project</strong>
        layers — alongside <strong>database</strong> and <strong>technology</strong> projections.
        Every layer is editable Mermaid and a draw.io file.
      </p>
      <a class="back" href="/tools/">Back to all tools</a>
    </header>

    <!-- INPUT -->
    <section class="step">
      <h2 class="step-h"><span class="n">1</span> Upload flow register</h2>
      <p class="hint">
        Needs at least <code>From Application</code> and <code>To Application</code> columns;
        <code>From/To Type</code>, <code>Interface Mechanism</code>, <code>From/To Database</code>,
        and <code>From/To Platform</code> are used when present. Parsed entirely in your browser.
      </p>
      <div class="drop" id="drop">
        <input type="file" id="file" accept=".xlsx,.xls,.csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv" />
        <div class="dl">Select a .xlsx, .xls, or .csv file</div>
        <div class="ds">The flow register / hops sheet.</div>
      </div>
      <div class="row">
        <label class="field" id="sheetWrap" hidden>
          <span>Sheet</span>
          <select id="sheet"></select>
        </label>
        <span class="status" id="status">Waiting for a file.</span>
      </div>
      <div class="summary" id="summary" hidden></div>
    </section>

    <!-- OUTPUT -->
    <section class="step" id="output" hidden>
      <div class="out-head">
        <h2 class="step-h"><span class="n">2</span> Diagrams</h2>
        <div class="row tight">
          <label class="field">
            <span>Colour scheme</span>
            <select id="scheme">
              <option value="archimate">ArchiMate</option>
              <option value="togaf">TOGAF</option>
              <option value="azure">Azure</option>
              <option value="none">None</option>
            </select>
          </label>
          <button class="btn" id="dlCombined">Download all as one .drawio ↧</button>
          <button class="btn" id="openCombined">Open all in diagrams.net ↗</button>
        </div>
      </div>

      <div class="tabs" id="tabs"></div>
      <p class="layer-note" id="layerNote"></p>

      <div class="grid2">
        <div class="col">
          <div class="row tight">
            <button class="btn sm" id="render">↻ Render</button>
            <button class="btn sm" id="copyM">Copy</button>
            <button class="btn sm" id="dlM">Download .mmd</button>
            <button class="btn sm" id="dlD">Download .drawio</button>
            <button class="btn sm" id="openD">diagrams.net ↗</button>
          </div>
          <textarea id="code" class="code" spellcheck="false"></textarea>
        </div>
        <div class="col">
          <h3 class="sub-h">Preview</h3>
          <div id="preview" class="preview"></div>
        </div>
      </div>
    </section>
  </article>

  <script is:inline>
    const $ = (id) => document.getElementById(id);
    let _mermaid = null, _xlsx = null;
    let workbook = null, layerList = [], active = null, scheme = 'archimate';

    async function mermaidLib() {
      if (!_mermaid) {
        _mermaid = (await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')).default;
        _mermaid.initialize({ startOnLoad: false, securityLevel: 'loose', theme: 'default' });
      }
      return _mermaid;
    }
    function loadXlsx() {
      return new Promise((res, rej) => {
        if (window.XLSX) return res(window.XLSX);
        const s = document.createElement('script');
        s.src = 'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js';
        s.onload = () => res(window.XLSX); s.onerror = () => rej(new Error('Could not load the spreadsheet library.'));
        document.head.appendChild(s);
      });
    }

    // ---------- column mapping (incl. From/To Type) ----------
    const COL_SYNONYMS = {
      fromApp: ['fromapplication', 'fromapp', 'sourceapplication', 'sourceapp', 'from', 'source'],
      fromType: ['fromtype', 'sourcetype', 'fromnodetype'],
      interface: ['interfacemechanism', 'interface', 'mechanism', 'protocol', 'connection'],
      toApp: ['toapplication', 'toapp', 'targetapplication', 'targetapp', 'to', 'target', 'destination'],
      toType: ['totype', 'targettype', 'tonodetype'],
      fromDb: ['fromdatabase', 'fromdb', 'sourcedatabase'],
      fromPlat: ['fromplatform', 'fromtechnologyplatform', 'fromtech', 'sourceplatform'],
      toDb: ['todatabase', 'todb', 'targetdatabase'],
      toPlat: ['toplatform', 'totechnologyplatform', 'totech', 'targetplatform'],
    };
    const norm = (s) => String(s ?? '').toLowerCase().replace(/[^a-z0-9]/g, '');
    function mapColumns(headerRow) {
      const normed = headerRow.map(norm); const idx = {};
      for (const [key, syns] of Object.entries(COL_SYNONYMS)) {
        let found = -1;
        for (const syn of syns) { const i = normed.indexOf(syn); if (i !== -1) { found = i; break; } }
        idx[key] = found;
      }
      return idx;
    }
    function parseHops(aoa) {
      if (!aoa || !aoa.length) return null;
      let headerIdx = -1, idx = null;
      for (let i = 0; i < Math.min(aoa.length, 5); i++) {
        const m = mapColumns(aoa[i] || []);
        if (m.fromApp !== -1 && m.toApp !== -1) { headerIdx = i; idx = m; break; }
      }
      if (headerIdx === -1) return null;
      const get = (row, key) => (idx[key] === -1 ? '' : String(row[idx[key]] ?? '').trim());
      const hops = [];
      for (let r = headerIdx + 1; r < aoa.length; r++) {
        const row = aoa[r] || [];
        const fromApp = get(row, 'fromApp'), toApp = get(row, 'toApp');
        if (!fromApp && !toApp) continue;
        hops.push({ fromApp, toApp, interface: get(row, 'interface'), fromType: get(row, 'fromType'), toType: get(row, 'toType'), fromDb: get(row, 'fromDb'), toDb: get(row, 'toDb'), fromPlat: get(row, 'fromPlat'), toPlat: get(row, 'toPlat') });
      }
      return { hops };
    }

    // ---------- types → shape & labels ----------
    const TYPE_SHAPE = { 'Application': 'rect', 'Strategy/Objective': 'diamond', 'Actor/External': 'stadium', 'Process/Other': 'subroutine', 'Database': 'cylinder', 'Platform': 'hexagon' };
    const typeShape = (t) => TYPE_SHAPE[t] || 'rect';
    const TYPE_ORDER = ['Application', 'Strategy/Objective', 'Actor/External', 'Process/Other'];
    const TYPE_LABEL = { 'Application': 'Applications', 'Strategy/Objective': 'Strategy & Objectives', 'Actor/External': 'Actors / People', 'Process/Other': 'Process / Projects' };

    function collectAppTypes(hops) {
      const t = new Map();
      for (const h of hops) {
        if (h.fromApp && h.fromType && !t.has(h.fromApp)) t.set(h.fromApp, h.fromType);
        if (h.toApp && h.toType && !t.has(h.toApp)) t.set(h.toApp, h.toType);
      }
      return t;
    }
    function buildAppGraph(hops, appTypes, only) {
      const labelToId = new Map(), nodes = new Map(), seen = new Set(), edges = [];
      let missing = 0, self = 0;
      const idFor = (label) => { if (!labelToId.has(label)) { const id = 'n' + labelToId.size; const type = appTypes.get(label) || ''; labelToId.set(label, id); nodes.set(id, { id, label, type, shape: typeShape(type) }); } return labelToId.get(label); };
      for (const h of hops) {
        const from = h.fromApp, to = h.toApp;
        if (only && (appTypes.get(from) || '') !== only) continue;
        if (from) idFor(from); if (to) idFor(to);
        if (!from || !to) { missing++; continue; }
        if (from === to) { self++; continue; }
        const fid = idFor(from), tid = idFor(to);
        const key = fid + ' ' + tid + ' ' + (h.interface || ''); if (seen.has(key)) continue; seen.add(key);
        edges.push({ from: fid, to: tid, label: h.interface || '' });
      }
      return { direction: 'LR', nodes, edges, skipped: { missing, self } };
    }
    function buildProj(hops, fromKey, toKey, type) {
      const labelToId = new Map(), nodes = new Map(), seen = new Set(), edges = [];
      let missing = 0, self = 0;
      const idFor = (label) => { if (!labelToId.has(label)) { const id = 'n' + labelToId.size; labelToId.set(label, id); nodes.set(id, { id, label, type, shape: typeShape(type) }); } return labelToId.get(label); };
      for (const h of hops) {
        const from = h[fromKey], to = h[toKey];
        if (from) idFor(from); if (to) idFor(to);
        if (!from || !to) { missing++; continue; }
        if (from === to) { self++; continue; }
        const fid = idFor(from), tid = idFor(to);
        const key = fid + ' ' + tid + ' ' + (h.interface || ''); if (seen.has(key)) continue; seen.add(key);
        edges.push({ from: fid, to: tid, label: h.interface || '' });
      }
      return { direction: 'LR', nodes, edges, skipped: { missing, self } };
    }
    function buildLayers(hops) {
      const appTypes = collectAppTypes(hops);
      const hasTypes = appTypes.size > 0;
      const layers = [];
      const full = buildAppGraph(hops, appTypes, null);
      if (hasTypes) {
        layers.push({ id: 'full', label: 'Full map', graph: full });
        for (const T of TYPE_ORDER) { const g = buildAppGraph(hops, appTypes, T); if (g.edges.length) layers.push({ id: 'type:' + T, label: TYPE_LABEL[T] || T, graph: g }); }
      } else {
        layers.push({ id: 'full', label: 'Application', graph: full });
      }
      const db = buildProj(hops, 'fromDb', 'toDb', 'Database');
      if (db.nodes.size) layers.push({ id: 'database', label: 'Database', graph: db });
      const tech = buildProj(hops, 'fromPlat', 'toPlat', 'Platform');
      if (tech.nodes.size) layers.push({ id: 'technology', label: 'Technology', graph: tech });
      for (const l of layers) l.code = toMermaid(l.graph);
      return layers;
    }

    // ---------- graph -> Mermaid (typed shapes + scheme classes) ----------
    function escMermaid(s) { return String(s).replace(/"/g, "'").replace(/[\[\]{}()<>|]/g, ' ').replace(/\s+/g, ' ').trim(); }
    const MERMAID_SHAPE = { rect: (l) => `["${l}"]`, cylinder: (l) => `[("${l}")]`, hexagon: (l) => `{{"${l}"}}`, diamond: (l) => `{"${l}"}`, stadium: (l) => `(["${l}"])`, subroutine: (l) => `[["${l}"]]` };
    function toMermaid(graph) {
      const lines = ['flowchart ' + (graph.direction || 'LR')];
      for (const [id, n] of graph.nodes) lines.push(`  ${id}${(MERMAID_SHAPE[n.shape] || MERMAID_SHAPE.rect)(escMermaid(n.label))}`);
      for (const e of graph.edges) { const lbl = e.label ? `|"${escMermaid(e.label)}"|` : ''; lines.push(`  ${e.from} -->${lbl} ${e.to}`); }
      // Per-node `style` directives colour reliably across mermaid versions
      // (classDef/class fills don't always apply with htmlLabels in v11).
      const p = PALETTES[scheme];
      if (p) for (const [id, n] of graph.nodes) { const c = p[n.type]; if (c) lines.push(`  style ${id} fill:${c.fill},stroke:${c.stroke},color:#1a1a1a`); }
      return lines.join('\n');
    }

    // ---------- colour palettes (scheme → type → fill/stroke) ----------
    const PALETTES = {
      archimate: {
        'Application': { fill: '#dae8fc', stroke: '#6c8ebf' },
        'Strategy/Objective': { fill: '#ffe6cc', stroke: '#d79b00' },
        'Actor/External': { fill: '#fff2cc', stroke: '#d6b656' },
        'Process/Other': { fill: '#d5e8d4', stroke: '#82b366' },
        'Database': { fill: '#dae8fc', stroke: '#6c8ebf' },
        'Platform': { fill: '#d5e8d4', stroke: '#82b366' },
      },
      togaf: {
        'Application': { fill: '#cfe2f3', stroke: '#3d85c6' },
        'Strategy/Objective': { fill: '#fce5cd', stroke: '#e69138' },
        'Actor/External': { fill: '#fff2cc', stroke: '#f1c232' },
        'Process/Other': { fill: '#d9ead3', stroke: '#6aa84f' },
        'Database': { fill: '#d0e0e3', stroke: '#45818e' },
        'Platform': { fill: '#d9d2e9', stroke: '#674ea7' },
      },
      azure: {
        'Application': { fill: '#cce4f6', stroke: '#0078d4' },
        'Strategy/Objective': { fill: '#e6e6fa', stroke: '#5c2d91' },
        'Actor/External': { fill: '#e1f0da', stroke: '#107c10' },
        'Process/Other': { fill: '#fff4ce', stroke: '#ffb900' },
        'Database': { fill: '#cce4f6', stroke: '#0078d4' },
        'Platform': { fill: '#deecf9', stroke: '#005ba1' },
      },
    };

    // ---------- graph -> draw.io (typed style + scheme colour) ----------
    const BASE_SHAPE = { rect: 'rounded=0;', cylinder: 'shape=cylinder3;boundedLbl=1;backgroundOutline=1;', hexagon: 'shape=hexagon;', diamond: 'rhombus;', stadium: 'rounded=1;arcSize=40;', subroutine: 'shape=process;' };
    const xmlEscape = (s) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    function styleFor(n) {
      let style = (BASE_SHAPE[n.shape] || BASE_SHAPE.rect) + 'whiteSpace=wrap;html=1;';
      const p = PALETTES[scheme]; const c = p && n.type && p[n.type];
      if (c) style += `fillColor=${c.fill};strokeColor=${c.stroke};`;
      return style;
    }
    function graphCells(graph, pos) {
      const { nodes, edges } = graph; const cells = [];
      for (const [id, n] of nodes) {
        const p = pos.get(id) || { x: 40, y: 40, w: 170, h: 60 };
        cells.push(`        <mxCell id="${id}" value="${xmlEscape(n.label)}" style="${styleFor(n)}" vertex="1" parent="1"><mxGeometry x="${Math.round(p.x)}" y="${Math.round(p.y)}" width="${p.w}" height="${p.h}" as="geometry" /></mxCell>`);
      }
      edges.forEach((e, idx) => {
        if (!nodes.has(e.from) || !nodes.has(e.to)) return;
        cells.push(`        <mxCell id="e_${idx}" value="${xmlEscape(e.label || '')}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="${e.from}" target="${e.to}"><mxGeometry relative="1" as="geometry" /></mxCell>`);
      });
      return cells.join('\n');
    }
    // cycle-safe layered layout
    function layout(graph) {
      const { nodes, edges, direction } = graph;
      const ids = [...nodes.keys()];
      const preds = new Map(ids.map((id) => [id, []]));
      for (const e of edges) { if (nodes.has(e.from) && nodes.has(e.to)) preds.get(e.to).push(e.from); }
      const rank = new Map(), onStack = new Set();
      const rankOf = (id) => { if (rank.has(id)) return rank.get(id); if (onStack.has(id)) return 0; onStack.add(id); let r = 0; for (const p of preds.get(id) || []) r = Math.max(r, rankOf(p) + 1); onStack.delete(id); rank.set(id, r); return r; };
      for (const id of ids) rankOf(id);
      const byRank = new Map();
      for (const id of ids) { const r = rank.get(id); if (!byRank.has(r)) byRank.set(r, []); byRank.get(r).push(id); }
      const NW = 180, NH = 60, GX = 80, GY = 60;
      const horizontal = direction === 'LR' || direction === 'RL';
      const pos = new Map();
      for (const [r, list] of byRank) list.forEach((id, idx) => {
        const along = idx * (horizontal ? (NH + GY) : (NW + GX));
        const across = r * (horizontal ? (NW + GX) : (NH + GY));
        pos.set(id, { x: (horizontal ? across : along) + 40, y: (horizontal ? along : across) + 40, w: NW, h: NH });
      });
      return pos;
    }
    function diagramPage(graph, name, id) {
      return `  <diagram id="${id}" name="${xmlEscape(name)}"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" page="1" pageWidth="1169" pageHeight="826"><root><mxCell id="0" /><mxCell id="1" parent="0" />\n${graphCells(graph, layout(graph))}\n      </root></mxGraphModel></diagram>`;
    }
    function layerDrawio(graph, name) { return `<mxfile host="app.diagrams.net" agent="flow-to-diagram">\n${diagramPage(graph, name, 'layer')}\n</mxfile>\n`; }
    function combinedDrawio() {
      const pages = layerList.filter((l) => l.graph.nodes.size).map((l, i) => diagramPage(l.graph, l.label, 'layer-' + i));
      return `<mxfile host="app.diagrams.net" agent="flow-to-diagram">\n${pages.join('\n')}\n</mxfile>\n`;
    }

    // ---------- file handling ----------
    function selFile(f) {
      $('status').textContent = 'Reading ' + f.name + '…';
      const reader = new FileReader();
      reader.onload = async (ev) => {
        try {
          const XLSX = await loadXlsx();
          workbook = XLSX.read(new Uint8Array(ev.target.result), { type: 'array' });
          const sel = $('sheet'); sel.innerHTML = '';
          workbook.SheetNames.forEach((nm) => { const o = document.createElement('option'); o.value = nm; o.textContent = nm; sel.appendChild(o); });
          const preferred = workbook.SheetNames.find((n) => /hop/i.test(n)) || workbook.SheetNames[0];
          sel.value = preferred; $('sheetWrap').hidden = workbook.SheetNames.length < 2;
          useSheet(preferred);
        } catch (e) { $('status').textContent = 'Error: ' + (e.message || e); }
      };
      reader.onerror = () => { $('status').textContent = 'Could not read the file.'; };
      reader.readAsArrayBuffer(f);
    }
    function useSheet(name) {
      const XLSX = window.XLSX;
      const aoa = XLSX.utils.sheet_to_json(workbook.Sheets[name], { header: 1, blankrows: false, defval: '' });
      const parsed = parseHops(aoa);
      if (!parsed || !parsed.hops.length) {
        $('output').hidden = true; $('summary').hidden = false;
        $('summary').innerHTML = `Couldn't find <code>From Application</code> / <code>To Application</code> columns in sheet “${name}”. Pick another sheet or check the headers.`;
        $('status').textContent = 'No usable rows.';
        return;
      }
      layerList = buildLayers(parsed.hops);
      active = layerList[0].id;
      $('status').textContent = `Parsed ${parsed.hops.length} hop${parsed.hops.length === 1 ? '' : 's'} from “${name}”.`;
      $('summary').hidden = false; $('summary').innerHTML = summaryHtml(parsed.hops.length);
      $('output').hidden = false;
      renderTabs();
      showLayer(active);
    }
    function summaryHtml(n) {
      const parts = layerList.map((l) => `<strong>${l.graph.nodes.size}</strong> ${l.label.toLowerCase()} / <strong>${l.graph.edges.length}</strong> flows`);
      return `<strong>${n}</strong> hops → ` + parts.join(' · ') + '.';
    }

    // ---------- tabs ----------
    function renderTabs() {
      const host = $('tabs'); host.innerHTML = '';
      for (const l of layerList) {
        const b = document.createElement('button');
        b.className = 'tab' + (l.id === active ? ' active' : '');
        b.dataset.layer = l.id;
        b.innerHTML = `${l.label} <span class="badge">${l.graph.edges.length}</span>`;
        b.addEventListener('click', () => showLayer(l.id));
        host.appendChild(b);
      }
    }
    function layerById(id) { return layerList.find((l) => l.id === id); }
    function skippedNote(l) {
      const s = l.graph.skipped, bits = [];
      if (s.missing) bits.push(`${s.missing} hop${s.missing === 1 ? '' : 's'} skipped (one end blank)`);
      if (s.self) bits.push(`${s.self} self-loop${s.self === 1 ? '' : 's'} skipped`);
      return bits.join(' · ');
    }
    function showLayer(id) {
      active = id;
      document.querySelectorAll('.tab').forEach((t) => t.classList.toggle('active', t.dataset.layer === id));
      const l = layerById(id);
      $('code').value = l.code;
      const note = skippedNote(l); $('layerNote').textContent = note || ''; $('layerNote').hidden = !note;
      render();
    }

    async function render() {
      const code = $('code').value.trim(); if (!code) { $('preview').innerHTML = ''; return; }
      const l = layerById(active); if (l) l.code = code;
      try { const mer = await mermaidLib(); const { svg } = await mer.render('m' + Math.random().toString(36).slice(2), code); $('preview').innerHTML = svg; }
      catch (e) { $('preview').innerHTML = `<div class="err">Diagram didn't parse — edit the code and re-render.<br><small>${(e.message || e).toString().replace(/</g, '&lt;').slice(0, 200)}</small></div>`; }
    }

    // ---------- buttons ----------
    function download(content, name, type) { const blob = new Blob([content], { type }); const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = name; a.click(); setTimeout(() => URL.revokeObjectURL(a.href), 15000); }
    function openDrawio(xml) { window.open('https://app.diagrams.net/?title=flow.drawio#R' + encodeURIComponent(xml), '_blank', 'noopener,noreferrer'); }

    function regenAll() {
      // colour scheme changed → rebuild every layer's Mermaid and refresh preview
      for (const l of layerList) l.code = toMermaid(l.graph);
      if (active) showLayer(active);
    }
    $('scheme').addEventListener('change', (e) => { scheme = e.target.value; if (layerList.length) regenAll(); });
    $('render').addEventListener('click', render);
    $('copyM').addEventListener('click', async () => { try { await navigator.clipboard.writeText($('code').value); $('status').textContent = 'Mermaid copied.'; } catch { $('status').textContent = 'Copy failed.'; } });
    $('dlM').addEventListener('click', () => download($('code').value, active.replace(/[^a-z0-9]+/gi, '-') + '.mmd', 'text/plain'));
    $('dlD').addEventListener('click', () => { const l = layerById(active); download(layerDrawio(l.graph, l.label), active.replace(/[^a-z0-9]+/gi, '-') + '.drawio', 'application/xml'); });
    $('openD').addEventListener('click', () => { const l = layerById(active); openDrawio(layerDrawio(l.graph, l.label)); });
    $('dlCombined').addEventListener('click', () => download(combinedDrawio(), 'flow-layers.drawio', 'application/xml'));
    $('openCombined').addEventListener('click', () => openDrawio(combinedDrawio()));

    $('file').addEventListener('change', (e) => { const f = e.target.files?.[0]; if (f) selFile(f); });
    $('sheet').addEventListener('change', (e) => useSheet(e.target.value));
    const dz = $('drop');
    dz.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('drag'); });
    dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
    dz.addEventListener('drop', (e) => { e.preventDefault(); dz.classList.remove('drag'); const f = e.dataTransfer?.files?.[0]; if (f) selFile(f); });
  </script>
</BaseLayout>

<style>
  .tool { max-width: 1000px; margin: 0 auto; }
  .thead { margin-bottom: 18px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; }
