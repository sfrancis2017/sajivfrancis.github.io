---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import YouTube from '@/components/mdx/YouTube.astro';
import Cusdis from '@/components/Cusdis.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import PostNav from '@/components/PostNav.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { tagToSlug, buildPostUrl } from '@/lib/utils';
import { categoryLabel } from '@/lib/categories';
import type { CollectionEntry } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime?: number;
  headings?: Heading[];
  prev?: CollectionEntry<'blog'> | null;
  next?: CollectionEntry<'blog'> | null;
}

const { post, readingTime, headings = [], prev = null, next = null } = Astro.props;
const { title, subtitle, description, pubDate, updatedDate, tags, category, videoUrl, coverImage } = post.data;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });

const venueLabel =
  post.data.publishMode === 'venue-first' && post.data.venueName
    ? `Originally published in ${post.data.venueName}`
    : null;

// Canonical URL for share intents — must be absolute so X / LinkedIn
// crawl the right OG metadata.
const postUrl = new URL(buildPostUrl(post), Astro.site).toString();
const shareText = `${title} — by Sajiv Francis`;
const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(postUrl)}`;
const linkedInShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`;

// ---- Runtime "Download PDF" data island ----------------------------------
// Strip MDX machinery so the raw post body renders cleanly through WeasyPrint.
function stripMdx(b: string) {
  return b
    .replace(/^import\s.*$/gm, '')
    .replace(/^export\s.*$/gm, '')
    .replace(/\{\/\*[\s\S]*?\*\/\}/g, '')
    .replace(/<\/?[A-Z][A-Za-z0-9]*(?:\s[^>]*?)?\/?>/g, '')
    .replace(/\n{3,}/g, '\n\n')
    .trim();
}
const pdfBody = stripMdx(post.body ?? '');
const pdfFileSlug = post.slug.replace(/^\d{4}-\d{2}-\d{2}-/, '');
const pdfSource = {
  markdown: pdfBody,
  template: 'modern',
  slug: pdfFileSlug || 'post',
  meta: {
    title,
    short_title: title,
    subtitle: subtitle || (description && description !== title ? description : ''),
    date: pubDate.toISOString().slice(0, 10),
  },
};
const showPdf = pdfBody.length > 40;
// XSS-safe JSON data island: escape `<` so a literal "</script>" can't close
// the tag early. JSON.parse decodes < back to <.
const pdfSourceJson = JSON.stringify(pdfSource).replace(/</g, '\\u003c');
---

<BaseLayout title={title} description={description} ogImage={coverImage}>
  <ReadingProgress />
  <TableOfContents headings={headings} />

  <Breadcrumbs
    crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Writing', href: '/blog/' },
      { label: title },
    ]}
  />

  <article class="prose dark:prose-invert max-w-none prose-headings:tracking-tight prose-headings:scroll-mt-24 prose-a:text-[var(--color-accent)] prose-a:underline prose-a:underline-offset-2 prose-img:rounded-md prose-img:border prose-img:border-[var(--color-border)] prose-pre:border prose-pre:border-[var(--color-border)] prose-code:before:content-none prose-code:after:content-none">
    <header class="not-prose mb-10 pb-8 border-b border-[var(--color-border)]">
      <div class="flex flex-wrap items-center gap-2 text-sm text-[var(--color-fg-subtle)] uppercase tracking-wider">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {readingTime != null && <span aria-hidden="true">·</span>}
        {readingTime != null && <span>{readingTime} min read</span>}
        {venueLabel && <span aria-hidden="true">·</span>}
        {venueLabel && <span class="normal-case tracking-normal">{venueLabel}</span>}
        {showPdf && <span aria-hidden="true">·</span>}
        {showPdf && (
          <button id="download-pdf-btn" type="button" class="normal-case tracking-normal inline-flex items-center gap-1 hover:text-[var(--color-fg)] no-underline bg-transparent border-0 p-0 cursor-pointer text-[var(--color-fg-subtle)] disabled:opacity-60 disabled:cursor-progress">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            <span class="pdf-btn-label">PDF</span>
          </button>
        )}
      </div>

      <h1 class="mt-4 text-4xl md:text-5xl font-semibold tracking-tight leading-[1.1]">
        {title}
      </h1>

      {
        subtitle && (
          <p class="mt-3 text-xl text-[var(--color-fg-muted)] leading-snug">{subtitle}</p>
        )
      }

      {
        description && (
          <p class="mt-4 text-base text-[var(--color-fg-muted)]">{description}</p>
        )
      }

      {
        category && (
          <p class="mt-5">
            <a
              href={`/blog/category/${category}/`}
              class="inline-block px-2.5 py-0.5 text-xs uppercase tracking-wider border border-[var(--color-border)] rounded-sm text-[var(--color-fg)] hover:border-[var(--color-fg-muted)] no-underline"
            >
              {categoryLabel(category)}
            </a>
          </p>
        )
      }

      {
        tags.length > 0 && (
          <ul class="mt-5 flex flex-wrap gap-2 text-xs text-[var(--color-fg-subtle)]">
            {tags.map((tag) => (
              <li>
                <a
                  href={`/blog/tag/${tagToSlug(tag)}/`}
                  class="px-2 py-0.5 border border-[var(--color-border)] rounded-sm hover:border-[var(--color-fg-muted)] no-underline"
                >
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      coverImage && (
        <figure class="not-prose mb-10 -mt-2">
          <img
            src={coverImage}
            alt={post.data.coverAlt ?? ''}
            class="w-full aspect-[2/1] object-cover rounded-md border border-[var(--color-border)]"
            loading="eager"
            decoding="async"
          />
          {post.data.coverAlt && (
            <figcaption class="mt-2 text-xs text-[var(--color-fg-subtle)] italic">
              {post.data.coverAlt}
            </figcaption>
          )}
        </figure>
      )
    }

    {
      videoUrl && (
        <div class="not-prose mb-8">
          <YouTube url={videoUrl} title={title} />
        </div>
      )
    }

    <!-- Annotation target: RecogitoJS attaches to this body wrapper only
         (not the header/footer), so reader notes anchor to the post text. -->
    <div data-annotate>
      <slot />
    </div>

    {
      updatedDate && (
        <p class="mt-12 pt-6 border-t border-[var(--color-border)] text-sm text-[var(--color-fg-subtle)] not-prose">
          Updated {formatDate(updatedDate)}.
        </p>
      )
    }

    <PostNav prev={prev} next={next} />

    <section class="mt-12 pt-8 border-t border-[var(--color-border)] not-prose print-hide" aria-label="Share this post">
      <div class="flex items-center gap-3 flex-wrap">
        <span class="text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] font-semibold">
          Share this →
        </span>
        <a
          href={twitterShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg-muted)] text-[var(--color-fg)] no-underline hover:no-underline"
          aria-label="Share on X"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          Post on X
        </a>
        <a
          href={linkedInShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg-muted)] text-[var(--color-fg)] no-underline hover:no-underline"
          aria-label="Share on LinkedIn"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
          LinkedIn
        </a>
        <button
          type="button"
          data-share-copy={postUrl}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg-muted)] text-[var(--color-fg)] cursor-pointer"
          aria-label="Copy link"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
          <span data-share-copy-label>Copy link</span>
        </button>
      </div>
    </section>

    <footer class="mt-12 pt-8 border-t border-[var(--color-border)] not-prose flex items-center justify-between gap-4">
      <a href="/blog/" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] no-underline">
        ← All writing
      </a>
      <button
        type="button"
        data-print-trigger
        class="print-hide text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] underline-offset-2 hover:underline inline-flex items-center gap-1.5"
        aria-label="Print or save as PDF"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="6 9 6 2 18 2 18 9" />
          <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
          <rect x="6" y="14" width="12" height="8" />
        </svg>
        Print / PDF
      </button>
    </footer>
  </article>

  <Cusdis
    pageId={post.slug}
    pageUrl={postUrl}
    pageTitle={title}
  />

  {showPdf && (
    <script id="pdf-source" type="application/json" is:inline set:html={pdfSourceJson} />
  )}
</BaseLayout>

<script>
  import { initPdfExport } from '@/scripts/pdf-export.js';
  initPdfExport();
  document.addEventListener('astro:page-load', initPdfExport);
</script>

<script>
  document
    .querySelector('[data-print-trigger]')
    ?.addEventListener('click', () => window.print());

  // Copy-link share button
  const copyBtn = document.querySelector<HTMLButtonElement>('[data-share-copy]');
  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.dataset.shareCopy;
    const label = copyBtn.querySelector<HTMLElement>('[data-share-copy-label]');
    if (!url) return;
    try {
      await navigator.clipboard.writeText(url);
      const original = label?.textContent ?? 'Copy link';
      if (label) label.textContent = '✓ Copied';
      setTimeout(() => {
        if (label) label.textContent = original;
      }, 1500);
    } catch {
      // Clipboard API can fail under some permissions — show URL in a prompt
      window.prompt('Copy this URL:', url);
    }
  });
</script>

<script>
  // Lazy-render Mermaid diagrams. The mermaid bundle (~600KB) is only
  // imported when a post actually contains a ```mermaid block, so
  // diagram-free posts pay zero cost.
  //
  // Astro renders fenced code through Shiki, which emits
  // `<pre data-language="mermaid">...</pre>` — the language goes on the
  // <pre> as a data attribute, not as `class="language-mermaid"` on the
  // inner <code>. We select on the data attribute and grab the raw
  // text via .textContent (strips Shiki's syntax-highlight spans).
  const initialBlocks = document.querySelectorAll(
    'pre[data-language="mermaid"]'
  );

  if (initialBlocks.length > 0) {
    const { default: mermaid } = await import('mermaid');

    const isDark = () =>
      document.documentElement.dataset.theme === 'dark';

    function configure() {
      mermaid.initialize({
        startOnLoad: false,
        theme: isDark() ? 'dark' : 'default',
        // 'loose' (not 'strict') so node labels render. In strict mode Mermaid
        // runs the finished SVG through DOMPurify, which strips the XHTML inside
        // each htmlLabels <foreignObject> — the diagram lays out but every node
        // comes out blank. Blog diagrams are authored by us (trusted .mdx, never
        // visitor input), so 'loose' is safe and matches pdf-export.js + the chat.
        securityLevel: 'loose',
        fontFamily: 'Inter, ui-sans-serif, system-ui, sans-serif',
      });
    }

    // Recover the diagram source. For an already-rendered diagram we stored the
    // exact source on `data-source`. For the raw Shiki <pre>, we must NOT use
    // `.textContent`: Shiki wraps every line in a `<span class="line">`, and the
    // newlines that separate them are not guaranteed to survive as text nodes in
    // every build — when they don't, `.textContent` collapses the whole diagram
    // onto one line and Mermaid throws "Parse error on line 1" (e.g.
    // `flowchart LR classDef ...`). Rebuilding from the line spans, joined with
    // "\n", reconstructs the source verbatim regardless of inter-span whitespace.
    function extractMermaidSource(el: HTMLElement): string {
      const stored = el.getAttribute('data-source');
      if (stored !== null) return stored;
      const lines = el.querySelectorAll('.line');
      if (lines.length > 0) {
        return Array.from(lines, (l) => l.textContent ?? '').join('\n');
      }
      return el.textContent ?? '';
    }

    // iOS WebKit can't render Mermaid's cytoscape-based mindmaps (blank on every
    // iPhone browser, in every mermaid version — it's a WebKit/cytoscape limit,
    // not a version bug), but dagre flowcharts render fine. So on phones we
    // convert a mindmap's indentation hierarchy into a left-to-right flowchart
    // with wrapped labels — narrow enough to fit the screen and scroll vertically
    // instead of the wide sprawl. Desktop keeps the authored mindmap; one source
    // of truth in the post.
    function wrapLabel(s: string, max = 18): string {
      const words = s.split(' ');
      const lines: string[] = [];
      let cur = '';
      for (const w of words) {
        if (cur && (cur + ' ' + w).length > max) { lines.push(cur); cur = w; }
        else cur = cur ? cur + ' ' + w : w;
      }
      if (cur) lines.push(cur);
      return lines.join('<br>');
    }
    function mindmapToFlowchart(src: string): string | null {
      const rows = src.split('\n');
      let seen = false;
      const nodes: { indent: number; label: string; id: string }[] = [];
      for (const row of rows) {
        if (!seen) { if (/^\s*mindmap\b/.test(row)) seen = true; continue; }
        if (!row.trim()) continue;
        const indent = row.match(/^[ \t]*/)![0].replace(/\t/g, '  ').length;
        let label = row.trim();
        const shaped = label.match(/^[A-Za-z0-9_]*\s*[([{]+([^)\]}]+)[)\]}]+\s*$/);
        if (shaped) label = shaped[1];
        label = label.replace(/<br\s*\/?>/gi, ' ').replace(/"/g, '').replace(/\s+/g, ' ').trim().slice(0, 90);
        if (label) nodes.push({ indent, label, id: 'M' + nodes.length });
      }
      if (nodes.length < 2) return null;
      const out = ['flowchart LR'];
      const stack: { indent: number; id: string }[] = [];
      for (const n of nodes) {
        while (stack.length && stack[stack.length - 1].indent >= n.indent) stack.pop();
        const parent = stack.length ? stack[stack.length - 1] : null;
        out.push(`  ${n.id}["${wrapLabel(n.label)}"]`);
        if (parent) out.push(`  ${parent.id} --> ${n.id}`);
        stack.push({ indent: n.indent, id: n.id });
      }
      return out.join('\n');
    }

    async function renderAll() {
      const targets = document.querySelectorAll<HTMLElement>(
        'pre[data-language="mermaid"], .mermaid-rendered'
      );
      const isMobile = window.matchMedia('(max-width: 640px)').matches;
      for (const el of targets) {
        const raw = extractMermaidSource(el);
        // Desktop: authored mindmap. Mobile: equivalent LR flowchart (renders on iOS).
        let source = raw;
        if (isMobile && /^\s*mindmap\b/.test(raw)) {
          const conv = mindmapToFlowchart(raw);
          if (conv) source = conv;
        }
        const id = 'mermaid-' + Math.random().toString(36).slice(2, 10);
        try {
          const { svg } = await mermaid.render(id, source);
          const wrapper = document.createElement('div');
          wrapper.className = 'mermaid-rendered';
          wrapper.setAttribute('data-source', source);
          wrapper.innerHTML = svg;
          // Append an expand button. Dense architecture diagrams scale
          // down too far to read on the post page; clicking opens a
          // fullscreen modal with the SVG at natural size + pan/zoom.
          const expandBtn = document.createElement('button');
          expandBtn.type = 'button';
          expandBtn.className = 'mermaid-expand';
          expandBtn.setAttribute('aria-label', 'Expand diagram');
          expandBtn.title = 'Expand diagram';
          expandBtn.innerHTML =
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>';
          expandBtn.addEventListener('click', () => openMermaidModal(wrapper));
          wrapper.appendChild(expandBtn);
          el.replaceWith(wrapper);
        } catch (err) {
          console.warn('Mermaid render failed:', err);
        }
      }
    }

    // ---- Fullscreen expand modal ---------------------------------------
    // One modal shared across every diagram on the page. Cloning the SVG
    // (rather than moving it) means the inline copy stays in place.
    function ensureMermaidModal(): HTMLElement {
      let modal = document.getElementById('mermaid-modal');
      if (modal) return modal;
      modal = document.createElement('div');
      modal.id = 'mermaid-modal';
      modal.className = 'mermaid-modal';
      modal.setAttribute('role', 'dialog');
      modal.setAttribute('aria-modal', 'true');
      modal.setAttribute('aria-label', 'Diagram fullscreen view');
      modal.hidden = true;
      modal.innerHTML = `
        <div class="mermaid-modal-backdrop" data-close></div>
        <div class="mermaid-modal-panel">
          <button type="button" class="mermaid-modal-close" data-close aria-label="Close">×</button>
          <div class="mermaid-modal-svg"></div>
        </div>
      `;
      document.body.appendChild(modal);
      modal.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.dataset && target.dataset.close !== undefined) closeMermaidModal();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal!.hidden) closeMermaidModal();
      });
      return modal;
    }

    function openMermaidModal(source: HTMLElement) {
      const modal = ensureMermaidModal();
      const slot = modal.querySelector('.mermaid-modal-svg') as HTMLElement;
      const svg = source.querySelector('svg');
      if (!svg) return;
      slot.innerHTML = '';
      const clone = svg.cloneNode(true) as SVGElement;
      // Strip width/height caps so the SVG renders at intrinsic size
      // inside the modal's scrollable container.
      clone.removeAttribute('width');
      clone.removeAttribute('height');
      clone.removeAttribute('style');
      slot.appendChild(clone);
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function closeMermaidModal() {
      const modal = document.getElementById('mermaid-modal');
      if (!modal) return;
      modal.hidden = true;
      document.body.style.overflow = '';
    }

    // Wait for the page webfont (Inter) before rendering. Mermaid measures text
    // to lay out diagrams; measuring before the font loads gives wrong metrics
    // and corrupts layout — worst for mindmaps, whose cytoscape layout is highly
    // text-size-sensitive. On desktop the font is usually cached so it slips
    // through; on mobile it loads slower, which is why the mindmap rendered on
    // laptop but not phone. Best-effort: never block rendering for long.
    if (document.fonts && document.fonts.ready) {
      try {
        await Promise.race([
          document.fonts.ready,
          new Promise((r) => setTimeout(r, 3000)),
        ]);
      } catch {}
    }

    configure();
    await renderAll();

    // Re-render diagrams when the user toggles theme so colors match
    new MutationObserver((muts) => {
      if (muts.some((m) => m.attributeName === 'data-theme')) {
        configure();
        renderAll();
      }
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }
</script>

<script>
  // Lazy-render Plotly charts embedded as ```plotly fenced blocks.
  //
  // Shiki has no "plotly" grammar, so Astro renders the fence as a plain
  // `<pre data-language="plaintext">` — the JSON figure spec sits in the DOM
  // but nothing draws it. We DETECT BY CONTENT rather than language tag:
  // any <pre> whose text parses to a Plotly figure (an object with a `data`
  // array) is a chart. Plotly (~1MB) is only fetched if a post has one, so
  // chart-free posts pay nothing.
  type PlotlySpec = { data: unknown[]; layout?: Record<string, unknown> };

  const candidates: { pre: HTMLElement; spec: PlotlySpec }[] = [];
  for (const pre of document.querySelectorAll<HTMLElement>('pre')) {
    if (pre.dataset.language === 'mermaid') continue;
    const raw = (pre.textContent || '').trim();
    if (raw[0] !== '{' && raw[0] !== '[') continue;
    try {
      const spec = JSON.parse(raw);
      if (spec && Array.isArray(spec.data)) candidates.push({ pre, spec });
    } catch {
      /* not JSON — leave the code block alone */
    }
  }

  if (candidates.length > 0) {
    // Swap each raw-JSON <pre> for a placeholder immediately, so the JSON
    // never lingers on screen, then fill once Plotly loads.
    const slots = candidates.map(({ pre, spec }) => {
      const div = document.createElement('div');
      div.className = 'plotly-rendered';
      div.setAttribute('aria-busy', 'true');
      pre.replaceWith(div);
      return { div, spec };
    });

    const loadPlotly = (): Promise<any> => {
      const w = window as any;
      if (w.Plotly) return Promise.resolve(w.Plotly);
      return new Promise((resolve, reject) => {
        const s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/plotly.js-dist-min@2.35.2/plotly.min.js';
        s.onload = () => resolve(w.Plotly);
        s.onerror = () => reject(new Error('Plotly failed to load'));
        document.head.appendChild(s);
      });
    };

    // Title fitting that keeps the FULL header visible on mobile: shrink the
    // font with width, AND wrap long titles onto balanced multiple lines
    // (automargin then reserves the vertical room) instead of clipping them.
    const titleSize = (w: number): number =>
      w < 380 ? 11 : w < 520 ? 12.5 : w < 680 ? 14 : 16;
    const wrapTitle = (text: string, w: number, fontSize: number): string => {
      if (!text) return text;
      const maxChars = Math.max(14, Math.floor((w * 0.9) / (fontSize * 0.55)));
      if (text.length <= maxChars) return text;
      const nLines = Math.ceil(text.length / maxChars);
      const target = Math.ceil(text.length / nLines); // balance the lines
      const lines: string[] = [];
      let cur = '';
      for (const word of text.split(/\s+/)) {
        if (cur && (cur + ' ' + word).length > target) {
          lines.push(cur);
          cur = word;
        } else {
          cur = cur ? cur + ' ' + word : word;
        }
      }
      if (cur) lines.push(cur);
      return lines.join('<br>');
    };

    loadPlotly()
      .then((Plotly) => {
        for (const { div, spec } of slots) {
          // Drop the loading state BEFORE rendering so Plotly measures the
          // full block width. A grid/centered placeholder mis-measures on
          // mobile and the chart overflows the viewport.
          div.removeAttribute('aria-busy');
          const layout: any = Object.assign({ autosize: true }, spec.layout || {});
          // Let axes auto-expand their margins so long category labels fit on
          // narrow screens instead of overflowing / being clipped.
          layout.xaxis = Object.assign({ automargin: true }, layout.xaxis || {});
          layout.yaxis = Object.assign({ automargin: true }, layout.yaxis || {});
          // Normalise the title so the header can't clip on mobile: object
          // form, automargin (reserves vertical room), centered, responsive
          // font, and word-wrapped text.
          const t = layout.title;
          const title: any =
            typeof t === 'string' ? { text: t } : Object.assign({}, t || {});
          const originalTitle: string = title.text || '';
          const w0 = div.clientWidth || 680;
          const fs0 = titleSize(w0);
          title.automargin = true;
          title.xref = 'paper';
          title.x = 0.5;
          title.xanchor = 'center';
          title.font = Object.assign({}, title.font || {}, { size: fs0 });
          title.text = wrapTitle(originalTitle, w0, fs0);
          layout.title = title;
          // Hide legends below the mobile breakpoint (they crowd/overlap the
          // plot, worst on bar charts); restore the author's intent above it.
          const MOBILE_BP = 640;
          const dleg = layout.showlegend !== false;
          layout.showlegend = w0 > MOBILE_BP ? dleg : false;
          try {
            Plotly.newPlot(div, spec.data, layout, {
              responsive: true,
              displayModeBar: false,
            });
            // Container-based responsiveness: redraw + re-fit/re-wrap the title
            // whenever the card width changes (rotation, narrow viewports).
            new ResizeObserver(() => {
              try {
                Plotly.Plots.resize(div);
                const w = div.clientWidth;
                const fs = titleSize(w);
                Plotly.relayout(div, {
                  'title.font.size': fs,
                  'title.text': wrapTitle(originalTitle, w, fs),
                  showlegend: w > MOBILE_BP ? dleg : false,
                });
              } catch {
                /* chart removed */
              }
            }).observe(div);
          } catch (err) {
            console.warn('Plotly render failed:', err);
          }
        }
      })
      .catch((err) => console.warn(err));
  }
</script>
