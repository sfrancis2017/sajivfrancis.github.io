---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Writing"
  description="Essays and articles on enterprise architecture, AI, and the future of practice."
>
  <header class="mb-12">
    <h1 class="text-4xl font-semibold tracking-tight">Writing</h1>
    <p class="mt-3 text-[var(--color-fg-muted)]">
      Essays and articles on enterprise architecture, AI, and the future of
      practice. <a href="/rss.xml" class="underline">RSS</a>.
    </p>
  </header>

  {
    posts.length === 0 ? (
      <p class="text-[var(--color-fg-muted)]">
        Posts are being migrated from the previous site. Coming soon.
      </p>
    ) : (
      <ul class="space-y-10">
        {posts.map((post) => (
          <li class="border-b border-[var(--color-border)] pb-10 last:border-b-0">
            <article>
              <p class="text-sm text-[var(--color-fg-subtle)] uppercase tracking-wider">
                {formatDate(post.data.pubDate)}
                {post.data.publishMode === 'venue-first' && post.data.venueName && (
                  <span class="ml-2"> · Originally published in {post.data.venueName}</span>
                )}
              </p>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight">
                <a
                  href={`/blog/${post.slug}/`}
                  class="text-[var(--color-fg)] no-underline hover:underline"
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-2 text-[var(--color-fg-muted)]">
                {post.data.description}
              </p>
              {post.data.tags.length > 0 && (
                <ul class="mt-3 flex flex-wrap gap-2 text-xs text-[var(--color-fg-subtle)]">
                  {post.data.tags.map((tag) => (
                    <li class="px-2 py-0.5 border border-[var(--color-border)] rounded-sm">
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
            </article>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
