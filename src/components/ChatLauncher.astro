---
// Floating chat launcher: bottom-right button → modal with iframe to
// chat.sajivfrancis.com. Anonymous visitors get public mode automatically;
// owner-mode bearer token (if set on the chat origin) auto-applies there.
//
// Hidden on /chat/* since that page already embeds the chat directly.

const hide = Astro.url.pathname.startsWith('/chat');
---

{
  !hide && (
    <>
      <button
        type="button"
        id="chat-launcher-button"
        aria-label="Open chat"
        title="Chat with Sajiv"
        class="fixed bottom-6 right-6 z-30 h-14 w-14 rounded-full bg-[var(--color-fg)] text-[var(--color-bg)] shadow-lg hover:opacity-90 transition-opacity flex items-center justify-center"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
      </button>

      <div
        id="chat-launcher-modal"
        role="dialog"
        aria-modal="true"
        aria-label="Chat with Sajiv"
        hidden
        class="fixed inset-0 z-50"
      >
        <div
          id="chat-launcher-backdrop"
          class="absolute inset-0 bg-black/40"
        />
        <div
          id="chat-launcher-panel"
          class="chat-panel absolute inset-0 md:inset-auto md:bottom-6 md:right-6 md:w-[420px] md:h-[640px] md:max-h-[calc(100vh-3rem)] bg-[var(--color-bg)] md:rounded-xl shadow-2xl border border-[var(--color-border)] flex flex-col overflow-hidden"
        >
          <div
            id="chat-launcher-resize"
            role="separator"
            aria-label="Drag to resize chat height"
            aria-orientation="horizontal"
            class="hidden md:block absolute top-0 left-2 right-2 h-2 cursor-ns-resize z-10"
          />
          <div
            id="chat-launcher-resize-x"
            role="separator"
            aria-label="Drag to resize chat width"
            aria-orientation="vertical"
            class="hidden md:block absolute top-2 bottom-0 left-0 w-2 cursor-ew-resize z-10"
          />
          <div
            id="chat-launcher-resize-xy"
            role="separator"
            aria-label="Drag to resize chat"
            class="hidden md:block absolute top-0 left-0 h-3 w-3 cursor-nwse-resize z-20"
          />
          <div class="flex items-center justify-between px-4 py-3 border-b border-[var(--color-border)]">
            <span class="text-sm font-medium text-[var(--color-fg)]">
              Chat with Sajiv
            </span>
            <div class="flex items-center gap-3">
              <button
                type="button"
                id="chat-launcher-expand"
                aria-label="Expand chat"
                class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors hidden md:inline-flex"
              >
                <svg
                  class="icon-expand"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="15 3 21 3 21 9" />
                  <polyline points="9 21 3 21 3 15" />
                  <line x1="21" y1="3" x2="14" y2="10" />
                  <line x1="3" y1="21" x2="10" y2="14" />
                </svg>
                <svg
                  class="icon-collapse hidden"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="4 14 10 14 10 20" />
                  <polyline points="20 10 14 10 14 4" />
                  <line x1="14" y1="10" x2="21" y2="3" />
                  <line x1="3" y1="21" x2="10" y2="14" />
                </svg>
              </button>
              <button
                type="button"
                id="chat-launcher-close"
                aria-label="Close chat"
                class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <line x1="18" y1="6" x2="6" y2="18" />
                  <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
              </button>
            </div>
          </div>
          <iframe
            id="chat-launcher-iframe"
            title="Chat with Sajiv"
            allow="microphone"
            class="flex-1 w-full border-0"
          />
        </div>
      </div>

      <style is:global>
        /* Expanded state: panel fills the viewport (overrides bottom-right
           panel sizing). Mobile is already full-screen, so this only matters
           on md+ screens. */
        #chat-launcher-panel.expanded {
          inset: 0 !important;
          width: 100% !important;
          height: 100% !important;
          max-height: 100% !important;
          border-radius: 0 !important;
        }

        /* Edge grab handles for resizing the docked panel. Each shows a faint
           pill on hover/drag so it's discoverable. The panel is anchored
           bottom-right, so the top edge controls height, the left edge controls
           width, and the top-left corner controls both. Hidden when expanded
           full-screen (no point resizing a maximized panel). */
        #chat-launcher-resize::after {
          content: '';
          position: absolute;
          top: 3px;
          left: 50%;
          transform: translateX(-50%);
          width: 36px;
          height: 3px;
          border-radius: 999px;
          background: var(--color-border);
          opacity: 0;
          transition: opacity 0.15s ease;
        }
        #chat-launcher-resize-x::after {
          content: '';
          position: absolute;
          left: 3px;
          top: 50%;
          transform: translateY(-50%);
          height: 36px;
          width: 3px;
          border-radius: 999px;
          background: var(--color-border);
          opacity: 0;
          transition: opacity 0.15s ease;
        }
        #chat-launcher-resize:hover::after,
        #chat-launcher-panel.resizing #chat-launcher-resize::after,
        #chat-launcher-resize-x:hover::after,
        #chat-launcher-panel.resizing #chat-launcher-resize-x::after {
          opacity: 1;
        }
        #chat-launcher-panel.expanded #chat-launcher-resize,
        #chat-launcher-panel.expanded #chat-launcher-resize-x,
        #chat-launcher-panel.expanded #chat-launcher-resize-xy {
          display: none !important;
        }
        /* While dragging, don't let the iframe swallow pointer events. */
        #chat-launcher-panel.resizing #chat-launcher-iframe {
          pointer-events: none;
        }

        /* While the chat is open, hide the floating owner badge. It shares the
           bottom-right corner with the launcher and — on laptop, where the panel
           is a small docked card rather than full-screen — renders over the chat
           interface. Hiding it for the duration of the session removes the
           overlap on every breakpoint. is:global so this rule can reach the
           OwnerBadge component's scoped element. */
        body.chat-launcher-open #owner-badge {
          display: none !important;
        }
      </style>

      <script>
        const button = document.getElementById('chat-launcher-button')!;
        const modal = document.getElementById(
          'chat-launcher-modal'
        ) as HTMLElement;
        const backdrop = document.getElementById('chat-launcher-backdrop')!;
        const closeBtn = document.getElementById('chat-launcher-close')!;
        const expandBtn = document.getElementById('chat-launcher-expand')!;
        const panel = document.getElementById('chat-launcher-panel')!;
        const iframe = document.getElementById(
          'chat-launcher-iframe'
        ) as HTMLIFrameElement;
        const iconExpand = expandBtn.querySelector('.icon-expand')!;
        const iconCollapse = expandBtn.querySelector('.icon-collapse')!;
        const resizeHandle = document.getElementById('chat-launcher-resize')!;
        const resizeHandleX = document.getElementById('chat-launcher-resize-x')!;
        const resizeHandleXY = document.getElementById(
          'chat-launcher-resize-xy'
        )!;

        let mounted = false;
        let lastScrollY = 0;

        function openLauncher() {
          if (!mounted) {
            iframe.src = 'https://chat.sajivfrancis.com';
            mounted = true;
          }
          applyStoredSize();
          lastScrollY = window.scrollY;
          modal.hidden = false;
          document.body.style.overflow = 'hidden';
          document.body.classList.add('chat-launcher-open');
          closeBtn.focus();
        }

        function closeLauncher() {
          modal.hidden = true;
          document.body.style.overflow = '';
          document.body.classList.remove('chat-launcher-open');
          button.focus();
          // Restore scroll position (overflow:hidden can shift on some browsers)
          window.scrollTo(0, lastScrollY);
        }

        function toggleExpand() {
          const expanded = panel.classList.toggle('expanded');
          iconExpand.classList.toggle('hidden', expanded);
          iconCollapse.classList.toggle('hidden', !expanded);
          expandBtn.setAttribute(
            'aria-label',
            expanded ? 'Collapse chat' : 'Expand chat'
          );
        }

        // Drag-resize of the docked panel. The panel is anchored bottom-right,
        // so growing its height extends it upward and growing its width extends
        // it leftward. Top edge = height, left edge = width, corner = both.
        // The chosen size is persisted in localStorage and reapplied on open.
        const MIN_H = 360;
        const MIN_W = 320;
        const H_KEY = 'chat-launcher-h';
        const W_KEY = 'chat-launcher-w';
        const isDesktop = () =>
          window.matchMedia('(min-width: 768px)').matches;

        function maxPanelHeight() {
          // Mirror md:max-h-[calc(100vh-3rem)] — 3rem ≈ 48px of margin.
          return window.innerHeight - 48;
        }
        function maxPanelWidth() {
          return window.innerWidth - 48;
        }

        function applyStoredSize() {
          // Inline sizes would override the full-screen mobile layout, so only
          // apply them on desktop; clear them otherwise.
          if (!isDesktop()) {
            panel.style.height = '';
            panel.style.width = '';
            return;
          }
          const h = parseInt(localStorage.getItem(H_KEY) || '', 10);
          const w = parseInt(localStorage.getItem(W_KEY) || '', 10);
          if (h) {
            panel.style.height =
              Math.max(MIN_H, Math.min(h, maxPanelHeight())) + 'px';
          }
          if (w) {
            panel.style.width =
              Math.max(MIN_W, Math.min(w, maxPanelWidth())) + 'px';
          }
        }

        let dragStartX = 0;
        let dragStartY = 0;
        let dragStartH = 0;
        let dragStartW = 0;
        let dragAxis = ''; // 'y' | 'x' | 'xy'

        function onResizeMove(e: PointerEvent) {
          if (dragAxis === 'y' || dragAxis === 'xy') {
            const dy = dragStartY - e.clientY; // drag up → taller
            const h = Math.max(
              MIN_H,
              Math.min(dragStartH + dy, maxPanelHeight())
            );
            panel.style.height = h + 'px';
          }
          if (dragAxis === 'x' || dragAxis === 'xy') {
            const dx = dragStartX - e.clientX; // drag left → wider
            const w = Math.max(
              MIN_W,
              Math.min(dragStartW + dx, maxPanelWidth())
            );
            panel.style.width = w + 'px';
          }
        }

        function onResizeEnd() {
          panel.classList.remove('resizing');
          window.removeEventListener('pointermove', onResizeMove);
          window.removeEventListener('pointerup', onResizeEnd);
          const rect = panel.getBoundingClientRect();
          if (dragAxis === 'y' || dragAxis === 'xy') {
            localStorage.setItem(H_KEY, String(Math.round(rect.height)));
          }
          if (dragAxis === 'x' || dragAxis === 'xy') {
            localStorage.setItem(W_KEY, String(Math.round(rect.width)));
          }
        }

        function startResize(axis: string, e: PointerEvent) {
          // Only the docked (non-expanded) panel is resizable.
          if (panel.classList.contains('expanded')) return;
          e.preventDefault();
          dragAxis = axis;
          dragStartX = e.clientX;
          dragStartY = e.clientY;
          const rect = panel.getBoundingClientRect();
          dragStartH = rect.height;
          dragStartW = rect.width;
          panel.classList.add('resizing');
          window.addEventListener('pointermove', onResizeMove);
          window.addEventListener('pointerup', onResizeEnd);
        }

        resizeHandle.addEventListener('pointerdown', (e) =>
          startResize('y', e as PointerEvent)
        );
        resizeHandleX.addEventListener('pointerdown', (e) =>
          startResize('x', e as PointerEvent)
        );
        resizeHandleXY.addEventListener('pointerdown', (e) =>
          startResize('xy', e as PointerEvent)
        );

        button.addEventListener('click', openLauncher);
        backdrop.addEventListener('click', closeLauncher);
        closeBtn.addEventListener('click', closeLauncher);
        expandBtn.addEventListener('click', toggleExpand);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !modal.hidden) closeLauncher();
        });
      </script>
    </>
  )
}
