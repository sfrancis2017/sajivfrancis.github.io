---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildPostUrl, formatDate } from '@/lib/utils';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="Writing"
  description="Essays and articles on enterprise architecture, AI, and the future of practice."
>
  <header class="mb-12">
    <h1 class="text-4xl font-semibold tracking-tight">Writing</h1>
    <p class="mt-3 text-[var(--color-fg-muted)]">
      Essays and articles on enterprise architecture, AI, and the future of
      practice. <a href="/rss.xml" class="underline">RSS</a>.
    </p>
  </header>

  {
    posts.length === 0 ? (
      <p class="text-[var(--color-fg-muted)]">No posts yet.</p>
    ) : (
      <ul class="space-y-12">
        {posts.map((post) => (
          <li class="border-b border-[var(--color-border)] pb-12 last:border-b-0">
            <article class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-6">
              {post.data.coverImage && (
                <a href={buildPostUrl(post)} class="block">
                  <img
                    src={post.data.coverImage}
                    alt={post.data.coverAlt ?? ''}
                    loading="lazy"
                    class="w-full sm:w-[200px] aspect-[3/2] object-cover rounded-md border border-[var(--color-border)]"
                  />
                </a>
              )}
              <div class={post.data.coverImage ? '' : 'sm:col-span-2'}>
                <p class="text-sm text-[var(--color-fg-subtle)] uppercase tracking-wider">
                  {formatDate(post.data.pubDate)}
                  {post.data.publishMode === 'venue-first' && post.data.venueName && (
                    <span class="ml-2 normal-case tracking-normal">
                      · Originally published in {post.data.venueName}
                    </span>
                  )}
                </p>
                <h2 class="mt-2 text-2xl font-semibold tracking-tight">
                  <a href={buildPostUrl(post)} class="text-[var(--color-fg)] no-underline hover:underline">
                    {post.data.title}
                  </a>
                </h2>
                {post.data.subtitle && (
                  <p class="mt-1 text-base text-[var(--color-fg-muted)] italic">
                    {post.data.subtitle}
                  </p>
                )}
                <p class="mt-2 text-[var(--color-fg-muted)]">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <ul class="mt-3 flex flex-wrap gap-2 text-xs text-[var(--color-fg-subtle)]">
                    {post.data.tags.slice(0, 6).map((tag) => (
                      <li class="px-2 py-0.5 border border-[var(--color-border)] rounded-sm">
                        {tag}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
