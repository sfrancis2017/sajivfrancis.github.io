---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildPostUrl, formatDate } from '@/lib/utils';
import { CATEGORIES, categoryLabel } from '@/lib/categories';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  // One page per category that actually has posts.
  return CATEGORIES.map((c) => {
    const posts = allPosts.filter((p) => p.data.category === c.value);
    return { params: { category: c.value }, props: { category: c.value, posts } };
  }).filter((entry) => entry.props.posts.length > 0);
}

interface Props {
  category: string;
  posts: CollectionEntry<'blog'>[];
}

const { category, posts } = Astro.props;
const label = categoryLabel(category);
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${label} — Writing`} description={`Writing categorized under ${label}.`}>
  <header class="mb-10">
    <p class="text-sm uppercase tracking-widest text-[var(--color-fg-subtle)]">Category</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight">{label}</h1>
    <p class="mt-3 text-[var(--color-fg-muted)]">
      {sorted.length} post{sorted.length === 1 ? '' : 's'} ·{' '}
      <a href="/blog/" class="underline">all writing</a>
    </p>
  </header>

  <ul class="space-y-8">
    {
      sorted.map((post) => (
        <li class="border-b border-[var(--color-border)] pb-8 last:border-b-0">
          <article>
            <p class="text-sm text-[var(--color-fg-subtle)] uppercase tracking-wider">
              {formatDate(post.data.pubDate)}
            </p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight">
              <a href={buildPostUrl(post)} class="text-[var(--color-fg)] no-underline hover:underline">
                {post.data.title}
              </a>
            </h2>
            <p class="mt-2 text-[var(--color-fg-muted)]">{post.data.description}</p>
          </article>
        </li>
      ))
    }
  </ul>
</BaseLayout>
