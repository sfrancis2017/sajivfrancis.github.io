---
// /chat/ now redirects to chat.sajivfrancis.com.
// The standalone chat handles both owner mode (token in localStorage) and
// public mode (rate-limited, visibility-filtered). The previous embedded
// version on this page predated public mode and is no longer needed.
const target = 'https://chat.sajivfrancis.com';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting to chat.sajivfrancis.com…</title>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>
      Redirecting to <a href={target}>{target}</a>…
    </p>
  </body>
</html>
