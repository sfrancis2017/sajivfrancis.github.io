---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroVideo from '@/components/HeroVideo.astro';

// Phase 0 about teaser — paste the CDN URL from the video pipeline here.
const heroVideo = 'https://sajiv-videos.sfo3.cdn.digitaloceanspaces.com/videos/about/1781500742740.mp4';
---

<BaseLayout
  title="About"
  description="About Sajiv Francis — Enterprise Architect leading AI programs at a Fortune 100 technology company. Indo-Canadian living in Arizona."
>
  <!-- Cap the hero video at the landing page's width (max-w-3xl) so it doesn't
       balloon inside this page's wider max-w-6xl editorial column. -->
  <HeroVideo src={heroVideo} class="max-w-3xl mb-8" />

  <!-- About hero + Now sit over a BOUNDED portrait underlay: the image is a
       right-anchored backdrop on just this region, with a theme-aware scrim so
       the left-column text stays readable. Everything below flows without it,
       so the portrait can't stretch across the whole page. -->
  <div class="about-underlay">
    <section class="about-hero">
      <p class="about-eyebrow">About</p>
      <h1 class="about-name">Sajiv Francis</h1>
      <p class="about-role">
        Enterprise Architect — solution architecture, AI, digital
        transformations, and program delivery.
      </p>
      <p class="about-lede">
        Indo-Canadian, living in Arizona. I do this work inside a
        Fortune 100 technology company by day, and write here on the
        side about what changes when the practice of architecture
        meets new AI tools.
      </p>
    </section>

    <article class="prose dark:prose-invert max-w-none about-now">
      <h2>Now <span class="not-prose about-now-date">— May 2026</span></h2>
      <ul>
        <li>
          Trying to work out what agentic architectures actually look
          like in real enterprise stacks — beyond the demo videos.
        </li>
        <li>
          Building tooling for my own work in public: RAG over my notes,
          AI-grounded writing, automated white papers.
        </li>
        <li>
          Following SAP S/4HANA's evolution — especially where AI starts
          being useful inside it, not bolted on.
        </li>
      </ul>
    </article>
  </div>

  <article class="prose dark:prose-invert max-w-none about-content">
    <h2>Background</h2>
    <p>
      Eight years of building at the intersection of AI and enterprise
      systems — from a 2018 grad-school location tool for Connecticut
      seniors, to an NLP-powered adaptive learning system in 2019
      (predating mainstream RAG by four years), to enterprise data
      orchestration, to leading AI programs inside one
      of the world's largest technology companies.
    </p>

    <h2>Why this work</h2>
    <p>
      I came into enterprise architecture sideways — through digital transformation projects in SAP & software
      engineering, then through trying to make AI useful inside
      organizations. What I care about now is the
      seam where new model capabilities meet decades-old enterprise
      systems, and how architects translate one to the other without
      breaking either.
    </p>
  </article>

  <article class="prose dark:prose-invert max-w-none about-content">
    <h2>Life outside work</h2>
    <p>Married, two kids. Most weekends are theirs.</p>
    <p>
      When time allows: I ride a Harley, collect stamps (a habit my
      grandfather used to do, decades ago, that I've never quite outgrown)
      and I also pretend to follow Formula 1 and MotoGP as closely as I
      once did.
    </p>

    <p>
      And there's almost always instrumental jazz on while I work — here's
      the rotation, if you'd like it playing too:
    </p>

    <section class="radio not-prose" data-playing="0" aria-label="Instrumental jazz radio">
      <div class="radio-top">
        <button class="radio-play" id="radio-play" type="button" aria-label="Play">
          <svg class="ic-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
          <svg class="ic-pause" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 5h4v14H6zm8 0h4v14h-4z"/></svg>
        </button>
        <div class="radio-meta">
          <p class="radio-kicker">On rotation
            <span class="radio-eq" id="radio-eq" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
          </p>
          <p class="radio-name" id="radio-name">—</p>
          <p class="radio-desc" id="radio-desc">instrumental jazz</p>
        </div>
        <input class="radio-vol" id="radio-vol" type="range" min="0" max="1" step="0.01" value="0.8" aria-label="Volume" />
      </div>
      <div class="radio-chips" id="radio-chips"></div>
      <p class="radio-foot">
        <a id="radio-home" href="#" target="_blank" rel="noopener noreferrer">station site ↗</a>
        <span aria-hidden="true">·</span>
        <span>stations via <a href="https://www.radio-browser.info" target="_blank" rel="noopener noreferrer">radio-browser</a></span>
      </p>
      <audio id="radio-audio" preload="none"></audio>
    </section>

    <h2>Education &amp; communities</h2>
    <div class="not-prose about-edu-grid">
      <div>
        <h3 class="about-edu-heading">Education</h3>
        <ul class="about-edu-list">
          <li>M.S. Software Engineering — <a href="https://www.fairfield.edu" target="_blank" rel="noopener noreferrer">Fairfield University</a></li>
          <li>Applied Data Science — <a href="https://www.engineering.columbia.edu" target="_blank" rel="noopener noreferrer">Columbia Engineering</a></li>
          <li>AI-Driven Leadership — <a href="https://online.stanford.edu" target="_blank" rel="noopener noreferrer">Stanford</a></li>
        </ul>
      </div>
      <div>
        <h3 class="about-edu-heading">Communities</h3>
        <ul class="about-edu-list">
          <li>Association of Enterprise Architects (AEA)</li>
          <li>ASUG (Americas' SAP Users' Group)</li>
          <li>The Open Group — TOGAF certified member</li>
          <li>Arizona Science &amp; Engineering Fair (judge)</li>
        </ul>
      </div>
    </div>

    <h2>Writing</h2>
    <p>
      I write about the future of architecture practice at the
      intersection of AI and organizational design — for practitioners,
      not just academics. Recent pieces are on the
      <a href="/blog/">writing</a> page.
    </p>

    <section id="contact" class="not-prose about-contact-strip" aria-label="Keep in touch">
      <p class="about-contact-kicker">Keep in touch</p>
      <h2 class="about-contact-title">Get new writing &amp; docs by email</h2>
      <p class="about-contact-copy">
        I’ll send a short note when I publish something new — nothing else.
        One click to confirm, one click to unsubscribe, any time.
      </p>

      <form
        class="about-contact-form"
        id="about-contact-form"
        novalidate
      >
        <input
          class="about-contact-input"
          type="email"
          name="email"
          placeholder="you@company.com"
          autocomplete="email"
          required
          aria-label="Email address"
        />
        <input
          class="about-contact-honeypot"
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />
        <button class="about-contact-btn" type="submit">Stay in touch</button>
      </form>

      <p id="about-contact-status" class="about-contact-status" aria-live="polite"></p>

      <p class="about-contact-meta">
        Prefer direct contact?
        <a href="mailto:admin@sajivfrancis.com">admin@sajivfrancis.com</a>
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  /* ----------------------------------------------------------------------
     Hero — ianenders-style editorial layout.

     Desktop: a relative-positioned section that lets the cutout image
     bleed past the right page gutter to the viewport edge. The image is
     applied as a background on an absolutely-positioned element so it
     sits behind/beside the text without affecting flow.

     Mobile: the absolutely-positioned image is hidden; an <img> tag
     stacks above the text instead. Cleaner stacking and accessible alt.
     ---------------------------------------------------------------------- */
  /* Bounded portrait underlay behind the About hero + Now only. The cutout
     portrait is anchored to the right and sized to the region's height (never
     stretched across the whole column); a theme-aware scrim fades from opaque
     on the left (text) to light on the right (image) for readability. */
  .about-underlay {
    position: relative;
    /* Match the hero video's width (max-w-3xl = 48rem) so the box aligns with the
       video frame above instead of running into the wider max-w-6xl column. */
    max-width: 48rem;
    margin-bottom: 3rem;
    padding: 1.75rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    overflow: hidden;
    background-image: url('/img/authors/sajivfrancis-about.png');
    background-repeat: no-repeat;
    background-position: right center;
    background-size: contain;
  }
  .about-underlay::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: linear-gradient(
      to right,
      color-mix(in oklab, var(--color-bg) 93%, transparent) 0%,
      color-mix(in oklab, var(--color-bg) 82%, transparent) 52%,
      color-mix(in oklab, var(--color-bg) 55%, transparent) 100%
    );
  }
  .about-hero,
  .about-now {
    position: relative;
    z-index: 1;
    max-width: 32rem;
  }
  .about-hero {
    margin-bottom: 1.25rem;
  }
  .about-eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-fg-muted);
    margin: 0 0 0.6rem;
    font-weight: 600;
  }
  .about-name {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0 0 0.6rem;
  }
  .about-role {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    color: var(--color-fg);
    margin: 0 0 1.2rem;
    line-height: 1.4;
  }
  .about-lede {
    font-size: 1rem;
    color: var(--color-fg-muted);
    line-height: 1.55;
    margin: 0;
    max-width: 28rem;
  }

  /* Mobile: keep it an underlay, but fill the whole card (cover + centered)
     so the portrait can never be half-cut, with a top-to-bottom scrim so the
     full-width text stays readable over it. */
  @media (max-width: 760px) {
    .about-underlay {
      background-size: cover;
      background-position: center top;
    }
    .about-underlay::before {
      background: linear-gradient(
        to bottom,
        color-mix(in oklab, var(--color-bg) 74%, transparent) 0%,
        color-mix(in oklab, var(--color-bg) 88%, transparent) 60%,
        color-mix(in oklab, var(--color-bg) 95%, transparent) 100%
      );
    }
    .about-hero,
    .about-now {
      max-width: 100%;
    }
  }

  /* ----------------------------------------------------------------------
     Content section below the portrait wrapper — left-anchored so it
     sits in the same column as the prose above. No `margin: 0 auto`,
     because centering breaks the visual continuity with the upper
     left-aligned column. Slightly wider max-width (40rem vs 32rem)
     since there's no image competing for room.
     ---------------------------------------------------------------------- */
  .about-content {
    max-width: 40rem;
    margin: 0;
  }
  .about-now-date {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-fg-muted);
    margin-left: 0.4rem;
    vertical-align: middle;
  }

  /* Education + communities two-column grid */
  .about-edu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 2.5rem;
    margin: 0.8rem 0 1.5rem;
  }
  @media (max-width: 600px) {
    .about-edu-grid { grid-template-columns: 1fr; }
  }
  .about-edu-heading {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    color: var(--color-fg-muted);
    margin: 0 0 0.5rem;
  }
  .about-edu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.95rem;
  }

  .about-contact-strip {
    margin-top: 2.2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem;
    background:
      radial-gradient(circle at 86% 12%, color-mix(in srgb, var(--color-accent) 16%, transparent) 0%, transparent 42%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 92%, var(--color-accent) 8%) 0%, var(--color-bg) 100%);
  }
  .about-contact-kicker {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }
  .about-contact-title {
    margin: 0.35rem 0 0;
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .about-contact-copy {
    margin: 0.5rem 0 0;
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--color-fg-muted);
  }
  .about-contact-form {
    margin-top: 0.8rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .about-contact-input {
    flex: 1;
    min-width: 220px;
    border: 1px solid var(--color-border-strong);
    border-radius: 0.5rem;
    background: var(--color-bg);
    color: var(--color-fg);
    font: inherit;
    font-size: 0.92rem;
    line-height: 1.2;
    padding: 0.52rem 0.68rem;
  }
  .about-contact-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .about-contact-btn {
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    background: var(--color-bg-elevated, var(--color-bg));
    color: var(--color-fg);
    font: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
    padding: 0.6rem 0.95rem;
    cursor: pointer;
    transition: color 160ms ease, border-color 160ms ease, transform 160ms ease;
  }
  .about-contact-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .about-contact-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
  }
  .about-contact-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .about-contact-status {
    margin: 0.55rem 0 0;
    min-height: 1.1rem;
    font-size: 0.78rem;
    color: var(--color-fg-muted);
  }
  .about-contact-status.is-error {
    color: var(--color-accent);
  }
  .about-contact-status.is-success {
    color: #2e7d32;
  }
  .about-contact-meta {
    margin: 0.6rem 0 0;
    font-size: 0.78rem;
    color: var(--color-fg-muted);
  }

  /* ----------------------------------------------------------------------
     Instrumental-jazz radio widget. Pure client-side: an <audio> element
     playing curated HTTPS streams; stations resolved by UUID from
     radio-browser on demand (hardcoded URL fallback). Theme-aware via the
     site CSS vars; mirrors the contact-strip card chrome.
     ---------------------------------------------------------------------- */
  .radio {
    --radio-teal: #16e6c4;    /* fluorescent teal */
    --radio-teal-2: #0bb9a8;  /* deeper teal for the radiant depth */
    /* No max-width — fill the 40rem content column, matching the
       "keep in touch" strip's width. */
    margin: 1.25rem 0 0.5rem;
    border: 1px solid color-mix(in srgb, var(--radio-teal) 50%, var(--color-border));
    border-radius: 0.75rem;
    padding: 0.9rem 1rem;
    background:
      radial-gradient(130% 150% at 88% 6%, color-mix(in srgb, var(--radio-teal) 32%, transparent) 0%, transparent 55%),
      radial-gradient(120% 130% at 6% 118%, color-mix(in srgb, var(--radio-teal-2) 24%, transparent) 0%, transparent 52%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 84%, var(--radio-teal) 16%) 0%, var(--color-bg) 100%);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--radio-teal) 20%, transparent),
      0 10px 34px -14px color-mix(in srgb, var(--radio-teal) 50%, transparent);
  }
  /* Gentle "on air" glow pulse while a station is playing. */
  .radio[data-playing="1"] { animation: radioglow 2.6s ease-in-out infinite; }
  @keyframes radioglow {
    0%, 100% { box-shadow: 0 0 0 1px color-mix(in srgb, var(--radio-teal) 22%, transparent), 0 10px 32px -14px color-mix(in srgb, var(--radio-teal) 45%, transparent); }
    50%      { box-shadow: 0 0 0 1px color-mix(in srgb, var(--radio-teal) 42%, transparent), 0 12px 46px -10px color-mix(in srgb, var(--radio-teal) 74%, transparent); }
  }
  .radio-top { display: flex; align-items: center; gap: 0.8rem; }
  .radio-play {
    flex: none;
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--radio-teal) 65%, #000);
    background: linear-gradient(145deg, var(--radio-teal), var(--radio-teal-2));
    color: #042422;
    display: grid;
    place-items: center;
    cursor: pointer;
    box-shadow: 0 2px 12px -3px color-mix(in srgb, var(--radio-teal) 60%, transparent);
    transition: transform 140ms ease, box-shadow 140ms ease;
  }
  .radio-play:hover { transform: translateY(-1px); box-shadow: 0 4px 18px -3px color-mix(in srgb, var(--radio-teal) 75%, transparent); }
  .radio-play svg { width: 1.3rem; height: 1.3rem; }
  .radio-play .ic-pause { display: none; }
  .radio[data-playing="1"] .radio-play .ic-play { display: none; }
  .radio[data-playing="1"] .radio-play .ic-pause { display: block; }
  .radio-meta { flex: 1; min-width: 0; }
  .radio-kicker {
    margin: 0;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-weight: 600;
    color: var(--color-fg-muted);
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .radio-name {
    margin: 0.12rem 0 0;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .radio-desc { margin: 0.05rem 0 0; font-size: 0.8rem; color: var(--color-fg-muted); }
  .radio-vol { flex: none; width: 5.5rem; accent-color: var(--radio-teal); cursor: pointer; }
  .radio-eq { display: inline-flex; align-items: flex-end; gap: 2px; height: 0.7rem; opacity: 0.3; }
  .radio-eq i { width: 2px; height: 28%; background: var(--radio-teal); border-radius: 1px; box-shadow: 0 0 6px color-mix(in srgb, var(--radio-teal) 70%, transparent); }
  .radio[data-playing="1"] .radio-eq { opacity: 1; }
  .radio[data-playing="1"] .radio-eq i { animation: radioeq 0.9s ease-in-out infinite; }
  .radio[data-playing="1"] .radio-eq i:nth-child(2) { animation-delay: 0.15s; }
  .radio[data-playing="1"] .radio-eq i:nth-child(3) { animation-delay: 0.3s; }
  .radio[data-playing="1"] .radio-eq i:nth-child(4) { animation-delay: 0.45s; }
  @keyframes radioeq { 0%, 100% { height: 22%; } 50% { height: 100%; } }
  .radio-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.85rem; }
  .radio-chip {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-fg-muted);
    font: inherit;
    font-size: 0.78rem;
    padding: 0.32rem 0.7rem;
    cursor: pointer;
    transition: color 140ms ease, border-color 140ms ease;
  }
  .radio-chip:hover { color: var(--color-fg); border-color: var(--radio-teal); }
  .radio-chip[aria-current="true"] {
    color: #042422;
    border-color: var(--radio-teal);
    background: linear-gradient(145deg, var(--radio-teal), var(--radio-teal-2));
    font-weight: 600;
    box-shadow: 0 0 12px -3px color-mix(in srgb, var(--radio-teal) 65%, transparent);
  }
  .radio-foot {
    margin: 0.7rem 0 0;
    font-size: 0.72rem;
    color: var(--color-fg-muted);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .radio-foot a { color: var(--color-fg-muted); text-decoration: underline; }
  .radio-foot a:hover { color: var(--radio-teal); }
  @media (max-width: 520px) { .radio-vol { width: 4rem; } }
  @media (prefers-reduced-motion: reduce) {
    .radio[data-playing="1"] .radio-eq i,
    .radio[data-playing="1"] { animation: none; }
  }
</style>

<script is:inline>
  (() => {
    const form = document.getElementById('about-contact-form');
    if (!form) return;

    const statusEl = document.getElementById('about-contact-status');
    const emailInput = form.querySelector('input[name="email"]');
    const websiteInput = form.querySelector('input[name="website"]');
    const submitBtn = form.querySelector('.about-contact-btn');
    // Newsletter subscribe (double opt-in) — same pipeline as the site-wide
    // widget. Sends a branded confirmation email; nobody is added until they
    // click confirm.
    const endpoint = 'https://chat.sajivfrancis.com/newsletter/subscribe';

    const setStatus = (message, tone) => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.classList.remove('is-error', 'is-success');
      if (tone) statusEl.classList.add(tone);
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const email = (emailInput?.value || '').trim();
      const website = (websiteInput?.value || '').trim();

      if (!email) {
        setStatus('Enter an email address first.', 'is-error');
        return;
      }

      setStatus('Subscribing...');
      if (submitBtn) submitBtn.disabled = true;

      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          // honeypot 'website' maps to the worker's 'hp'; source tags origin.
          body: JSON.stringify({ email, hp: website, source: 'about' }),
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok || !payload.ok) {
          throw new Error(payload.error || `HTTP ${response.status}`);
        }

        form.reset();
        setStatus(
          payload.already
            ? 'You’re already subscribed — thanks!'
            : 'Almost there — check your inbox to confirm your subscription.',
          'is-success',
        );
      } catch (err) {
        setStatus('Could not subscribe right now. Please email admin@sajivfrancis.com.', 'is-error');
        console.error('[about-contact] subscribe failed', err);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  })();
</script>

<script is:inline>
  // Instrumental-jazz radio. Curated by stationuuid; the fresh stream URL is
  // resolved from radio-browser on play (hardcoded HTTPS URL as fallback, so it
  // works even if the API is down). Pure browser playback — no backend.
  (() => {
    const root = document.querySelector('.radio');
    if (!root) return;

    // Curated, verified HTTPS + MP3/AAC (no mixed-content, no HLS dependency).
    const STATIONS = [
      { uuid: '960c7c81-0601-11e8-ae97-52543be04c81', name: 'Secret Agent',  desc: 'Lounge & spy jazz',     url: 'https://ice6.somafm.com/secretagent-128-mp3',          home: 'https://somafm.com/secretagent/' },
      { uuid: 'ea8059be-d119-4de3-b27b-0d9bd6aedb17', name: 'Adroit Jazz',   desc: 'Bebop & big band',       url: 'https://icecast.walmradio.com:8443/jazz',              home: 'https://walmradio.com/jazz' },
      { uuid: '7ada8a81-5ae1-418c-8f18-51d2f38d86a4', name: 'Bossa Jazz',    desc: 'Instrumental bossa nova', url: 'https://centova5.transmissaodigital.com:20104/live',    home: 'https://bossajazzbrasil.com/' },
      { uuid: '4a018de7-b452-4412-b86f-86254c5d53be', name: 'ABC Lounge',    desc: 'Lounge & smooth jazz',   url: 'https://eu1.fastcast4u.com/proxy/kpmxz?mp=/1',          home: 'https://www.abc-lounge.com/' },
      { uuid: '962aa032-0601-11e8-ae97-52543be04c81', name: 'Groove Salad',  desc: 'Downtempo & chill',      url: 'https://ice5.somafm.com/groovesalad-128-aac',          home: 'https://somafm.com/groovesalad/' },
    ];
    const API = 'https://de1.api.radio-browser.info';
    const $ = (id) => document.getElementById(id);
    const audio = $('radio-audio'), nameEl = $('radio-name'), descEl = $('radio-desc'),
          chipsEl = $('radio-chips'), homeEl = $('radio-home'), volEl = $('radio-vol'), playBtn = $('radio-play');

    let idx = 0;

    // Restore last station + volume.
    try { const u = localStorage.getItem('radio-station'); const i = STATIONS.findIndex((s) => s.uuid === u); if (i >= 0) idx = i; } catch (e) {}
    let vol = 0.8; try { const sv = parseFloat(localStorage.getItem('radio-vol')); if (!isNaN(sv)) vol = sv; } catch (e) {}
    audio.volume = vol; volEl.value = String(vol);

    // Station chips.
    STATIONS.forEach((s, i) => {
      const b = document.createElement('button');
      b.type = 'button'; b.className = 'radio-chip'; b.textContent = s.name;
      b.addEventListener('click', () => select(i, true));
      chipsEl.appendChild(b); s._chip = b;
    });

    const setState = (t) => { descEl.textContent = t; };
    const setPlaying = (p) => { root.dataset.playing = p ? '1' : '0'; playBtn.setAttribute('aria-label', p ? 'Pause' : 'Play'); };
    function setMeta() {
      const s = STATIONS[idx];
      nameEl.textContent = s.name; descEl.textContent = s.desc; homeEl.href = s.home;
      STATIONS.forEach((x) => x._chip.setAttribute('aria-current', x === s ? 'true' : 'false'));
    }

    // Resolve the freshest stream URL (cached); fall back to the baked HTTPS URL.
    async function resolve(s) {
      if (s._url) return s._url;
      try {
        const r = await fetch(API + '/json/stations/byuuid/' + s.uuid);
        const a = await r.json();
        const u = a && a[0] && a[0].url_resolved;
        if (u && u.indexOf('https://') === 0) { s._url = u; return u; }
      } catch (e) { /* API down → fallback */ }
      return s.url;
    }
    // Politely register a play with radio-browser (helps station rankings).
    const registerPlay = (s) => { try { fetch(API + '/json/url/' + s.uuid); } catch (e) {} };

    async function start() {
      const s = STATIONS[idx];
      setState('Connecting…');
      const url = await resolve(s);
      audio.src = url;
      try { await audio.play(); s._retried = false; registerPlay(s); }
      catch (e) { setPlaying(false); setState('Tap ▶ to start'); }
    }
    async function select(i, autoplay) {
      idx = i; setMeta();
      try { localStorage.setItem('radio-station', STATIONS[i].uuid); } catch (e) {}
      if (autoplay || !audio.paused) await start();
    }

    playBtn.addEventListener('click', () => { if (audio.paused) start(); else audio.pause(); });
    volEl.addEventListener('input', () => { audio.volume = parseFloat(volEl.value); try { localStorage.setItem('radio-vol', volEl.value); } catch (e) {} });

    audio.addEventListener('playing', () => { setPlaying(true); setState(STATIONS[idx].desc); });
    audio.addEventListener('pause', () => setPlaying(false));
    audio.addEventListener('waiting', () => setState('Buffering…'));
    audio.addEventListener('error', async () => {
      const s = STATIONS[idx];
      if (!s._retried) { s._retried = true; s._url = null; const url = await resolve(s); audio.src = url; audio.play().catch(() => {}); }
      else { setPlaying(false); setState('Station offline — try another'); }
    });

    setMeta();
  })();
</script>
