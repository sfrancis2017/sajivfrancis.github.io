---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="The page you're looking for doesn't exist.">
  <article class="text-center py-12">
    <p class="text-sm uppercase tracking-widest text-[var(--color-fg-subtle)]">404</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight">Page Not Found</h1>
    <p class="mt-4 text-[var(--color-fg-muted)]">
      The page you're looking for doesn't exist — or the link is from an older
      version of the site.
    </p>
    <p class="mt-8">
      <a href="/" class="underline">Return home</a>
    </p>
  </article>
</BaseLayout>
