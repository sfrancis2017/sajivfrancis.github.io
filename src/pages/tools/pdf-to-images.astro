---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="PDF to Images" description="Export each page of a PDF as a PNG or JPG image in your browser." mainClass="max-w-4xl">
  <article class="tool">
    <header class="thead">
      <p class="kick">Tools · Convert</p>
      <h1>PDF → Images</h1>
      <p class="sub">Export each page as a high-resolution PNG or JPG. Nothing is uploaded.</p>
      <a class="back" href="/tools/">Back to all tools</a>
    </header>

    <div class="drop" id="drop"><input type="file" id="file" accept=".pdf,application/pdf" /><div class="dl">Select a PDF</div><div class="ds">Processing runs locally in your browser.</div></div>

    <div class="panel" id="settings" style="display:none;">
      <h2>Settings</h2>
      <div class="grid">
        <label class="f"><span>Format</span><select id="format"><option value="png" selected>PNG</option><option value="jpeg">JPG</option></select></label>
        <label class="f"><span>Resolution</span><select id="scale"><option value="1.5">Screen (1.5×)</option><option value="2" selected>High (2×)</option><option value="3">Print (3×)</option></select></label>
        <label class="f" id="qf" style="display:none;"><span>JPG quality</span><input type="range" id="quality" min="50" max="100" value="88" /></label>
      </div>
    </div>

    <div class="status" id="status">Select a PDF to begin.</div>
    <button class="btn primary" id="go" disabled>Convert to images</button>
    <div class="summary" id="summary"><div class="st" id="stitle">Ready</div><div class="sm" id="smeta"></div><div class="row"><button class="btn primary" id="zip">Download ZIP</button><button class="btn" id="indiv">Download individually</button></div></div>
  </article>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script is:inline>
    const $ = (id) => document.getElementById(id);
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    let file = null, outputs = [];
    const fmt = (n) => (n / 1024 / 1024).toFixed(1) + ' MB';

    $('format').addEventListener('change', () => { $('qf').style.display = $('format').value === 'jpeg' ? '' : 'none'; });
    $('file').addEventListener('change', (e) => { const f = e.target.files?.[0]; if (f) sel(f); });
    const dz = $('drop');
    dz.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('drag'); });
    dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
    dz.addEventListener('drop', (e) => { e.preventDefault(); dz.classList.remove('drag'); const f = e.dataTransfer?.files?.[0]; if (f) sel(f); });
    function sel(f) { file = f; outputs = []; $('settings').style.display = ''; $('go').disabled = false; $('summary').classList.remove('on'); $('status').textContent = 'Selected: ' + f.name; }

    $('go').addEventListener('click', async () => {
      if (!file) return; $('go').disabled = true;
      const format = $('format').value, scale = +$('scale').value, q = +$('quality').value / 100;
      const mime = format === 'jpeg' ? 'image/jpeg' : 'image/png', ext = format === 'jpeg' ? 'jpg' : 'png';
      const base = file.name.replace(/\.pdf$/i, '');
      try {
        const doc = await pdfjsLib.getDocument({ data: new Uint8Array(await file.arrayBuffer()) }).promise;
        outputs = [];
        for (let p = 1; p <= doc.numPages; p++) {
          $('status').textContent = `Rendering page ${p} / ${doc.numPages}…`;
          const page = await doc.getPage(p);
          const vp = page.getViewport({ scale });
          const cv = document.createElement('canvas'); cv.width = vp.width; cv.height = vp.height;
          const ctx = cv.getContext('2d');
          if (format === 'jpeg') { ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, cv.width, cv.height); }
          await page.render({ canvasContext: ctx, viewport: vp }).promise;
          const blob = await new Promise((r) => cv.toBlob(r, mime, format === 'jpeg' ? q : undefined));
          outputs.push({ name: `${base}_page-${String(p).padStart(3, '0')}.${ext}`, blob });
        }
        const total = outputs.reduce((a, b) => a + b.blob.size, 0);
        $('stitle').textContent = `${outputs.length} images ready`;
        $('smeta').textContent = `${outputs.length} pages · ${fmt(total)} total`;
        $('summary').classList.add('on'); $('status').textContent = 'Done.';
      } catch (err) { $('status').textContent = 'Error: ' + (err.message || err); } finally { $('go').disabled = false; }
    });
    $('zip').addEventListener('click', async () => {
      if (!outputs.length) return;
      const zip = new JSZip(); outputs.forEach((o) => zip.file(o.name, o.blob));
      const blob = await zip.generateAsync({ type: 'blob' });
      const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'pdf_images.zip'; a.click();
      setTimeout(() => URL.revokeObjectURL(a.href), 20000);
    });
    $('indiv').addEventListener('click', async () => {
      for (let i = 0; i < outputs.length; i++) { const a = document.createElement('a'); a.href = URL.createObjectURL(outputs[i].blob); a.download = outputs[i].name; a.click(); setTimeout(() => URL.revokeObjectURL(a.href), 15000); if (i < outputs.length - 1) await new Promise((r) => setTimeout(r, 600)); }
    });
  </script>
</BaseLayout>

<style>
  .tool { max-width: 700px; margin: 0 auto; }
  .thead { margin-bottom: 14px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; }
  .kick { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-subtle); font-weight: 600; }
  .thead h1 { margin-top: 4px; font-size: 28px; line-height: 1.15; }
  .sub { margin-top: 8px; font-size: 14px; color: var(--color-fg-muted); }
  .back { display: inline-block; margin-top: 10px; color: var(--color-fg-muted); text-decoration: none; font-size: 12px; border: 1px solid var(--color-border); border-radius: 8px; padding: 6px 10px; }
  .back:hover { color: var(--color-fg); border-color: var(--color-accent); }
  .drop { border: 2px dashed var(--color-border); border-radius: 12px; padding: 22px; text-align: center; position: relative; margin-bottom: 12px; cursor: pointer; background: var(--color-bg-elevated); }
  .drop.drag { border-color: var(--color-accent); } .drop input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .dl { font-size: 14px; font-weight: 600; } .ds { font-size: 12px; color: var(--color-fg-muted); }
  .panel { background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: 12px; padding: 14px; margin-bottom: 12px; }
  .panel h2 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-fg-muted); margin-bottom: 10px; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .f { display: flex; flex-direction: column; gap: 5px; } .f span { font-size: 12px; color: var(--color-fg-muted); }
  .f input, .f select { background: var(--color-bg); border: 1px solid var(--color-border); color: var(--color-fg); border-radius: 8px; padding: 8px 10px; font-size: 13px; }
  .status { min-height: 20px; font-size: 12px; color: var(--color-fg-muted); margin-bottom: 8px; }
  .btn { border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-fg); border-radius: 8px; padding: 9px 12px; font-size: 13px; cursor: pointer; }
  .btn:hover { border-color: var(--color-accent); } .primary { background: var(--color-accent); border-color: var(--color-accent); color: var(--color-accent-fg); font-weight: 600; } .primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .summary { display: none; background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: 12px; padding: 12px; margin-top: 12px; } .summary.on { display: block; }
  .st { color: #2f7a4d; font-weight: 600; font-size: 14px; margin-bottom: 6px; } :root[data-theme=dark] .st { color: #78d69c; }
  .sm { font-family: var(--font-mono); font-size: 12px; color: var(--color-fg-muted); margin-bottom: 10px; } .row { display: flex; gap: 8px; flex-wrap: wrap; }
  @media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>
