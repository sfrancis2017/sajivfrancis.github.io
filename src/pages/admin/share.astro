---
// Old URL for the compose tool. Renamed to /margins/. This page
// preserves any query params and redirects forward so any existing
// news-card deep links or external bookmarks continue to work.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0;url=/margins/" />
    <link rel="canonical" href="/margins/" />
    <title>Redirecting to Margins…</title>
    <script is:inline>
      // Preserve query params (?url=...&title=...&source=...) on the way
      // through. JS replaces the entry so the back button skips this hop.
      var qs = window.location.search || '';
      window.location.replace('/margins/' + qs);
    </script>
  </head>
  <body>
    <p>
      Moved to <a href="/margins/">/margins/</a>…
    </p>
  </body>
</html>
