---
interface Props {
  src: string;
  alt?: string;
  caption?: string;
  link?: string;
  video?: boolean;
}

const { src, alt = '', caption, link, video = false } = Astro.props;
---

<figure class="my-8">
  {
    video ? (
      <video
        src={src}
        controls
        muted
        playsinline
        preload="metadata"
        class="w-full rounded-md border border-[var(--color-border)]"
      />
    ) : link ? (
      <a href={link} target="_blank" rel="noopener noreferrer">
        <img
          src={src}
          alt={alt}
          loading="lazy"
          class="w-full rounded-md border border-[var(--color-border)]"
        />
      </a>
    ) : (
      <img
        src={src}
        alt={alt}
        loading="lazy"
        class="w-full rounded-md border border-[var(--color-border)]"
      />
    )
  }
  {
    caption && (
      <figcaption class="mt-3 text-sm text-[var(--color-fg-subtle)] text-center">
        {caption}
      </figcaption>
    )
  }
</figure>
