---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="PDF Compressor"
  description="Compress and optionally split PDFs locally in your browser."
  mainClass="max-w-4xl"
>
  <article class="pdf-toolkit">
    <section class="tool-header">
      <div class="logo">
        <div class="logo-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="12" y1="18" x2="12" y2="12"></line>
            <line x1="9" y1="15" x2="15" y2="15"></line>
          </svg>
        </div>
        <div>
          <h1>PDF Toolkit</h1>
          <div class="subtitle">Compress and split PDFs locally in your browser</div>
        </div>
      </div>
      <div class="header-actions">
        <a class="home-link" href="/tools/">All tools</a>
        <button class="install-btn" id="open-install" type="button">Add to Home</button>
      </div>
    </section>

    <div class="modal-overlay" id="install-modal" aria-hidden="true">
      <div class="modal-sheet">
        <div class="modal-title">
          Add to iPhone Home Screen
          <button class="modal-close" id="close-install" type="button">✕</button>
        </div>
        <div class="install-steps">
          <div class="install-step"><div class="step-num">1</div><div class="step-text">Open this page in <strong>Safari</strong>.</div></div>
          <div class="install-step"><div class="step-num">2</div><div class="step-text">Tap the <strong>Share</strong> icon.</div></div>
          <div class="install-step"><div class="step-num">3</div><div class="step-text">Choose <strong>Add to Home Screen</strong>.</div></div>
          <div class="install-step"><div class="step-num">4</div><div class="step-text">Tap <strong>Add</strong>.</div></div>
        </div>
      </div>
    </div>

    <div class="drop-zone" id="drop-zone">
      <input type="file" id="file-input" accept=".pdf,application/pdf" multiple />
      <div class="drop-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="17 8 12 3 7 8"></polyline>
          <line x1="12" y1="3" x2="12" y2="15"></line>
        </svg>
      </div>
      <div class="drop-label">Tap to select PDFs</div>
      <div class="drop-sub">Multiple files OK · <span>nothing leaves your device</span></div>
    </div>

    <section class="settings-panel" id="settings-panel">
      <div class="settings-title">Compression settings</div>
      <div class="settings-grid">
        <label class="setting-field">
          <span>Target size (MB)</span>
          <input type="number" id="target-size-mb" min="1" max="200" step="1" value="25" />
        </label>
        <label class="setting-field">
          <span>Quality profile</span>
          <select id="quality-profile">
            <option value="fidelity" selected>High fidelity</option>
            <option value="balanced">Balanced</option>
            <option value="aggressive">Aggressive</option>
          </select>
        </label>
        <label class="setting-field">
          <span>If still too large</span>
          <select id="oversize-action">
            <option value="keep-smallest" selected>Keep smallest version</option>
            <option value="split-parts">Split into multiple PDFs</option>
          </select>
        </label>
        <label class="setting-field">
          <span>Split part max (MB)</span>
          <input type="number" id="split-size-mb" min="1" max="200" step="1" value="15" />
        </label>
      </div>
      <p class="settings-help">Tip: use High fidelity first. If a file still cannot reach your target, select Split into multiple PDFs.</p>
    </section>

    <div id="results-panel">
      <div class="results-title"><span id="results-title-text">Ready to download</span></div>
      <div class="results-stats" id="results-stats"></div>
      <div class="dl-actions">
        <button class="dl-zip-btn" id="dl-zip-btn" onclick="downloadZip()">Download ZIP</button>
        <button class="dl-ind-btn" onclick="downloadAllIndividual()">Download individually</button>
      </div>
    </div>

    <div id="file-list"></div>
    <div id="empty-hint">Add PDFs above to get started.</div>

    <div class="actions-bar" id="actions-bar">
      <div class="actions-inner">
        <button class="btn-primary" id="compress-btn" onclick="startCompression()">
          <span id="compress-label">Compress All</span>
          <div class="spinner" id="btn-spinner"></div>
        </button>
      </div>
    </div>
  </article>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script is:inline>
    pdfjsLib.GlobalWorkerOptions.workerSrc =
      'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    const TARGET_BYTES = 25 * 1024 * 1024;
    const LOAD_TIMEOUT_MS = 120_000;
    const YIELD_EVERY = 6;

    const QUALITY_PROFILES = {
      fidelity: [
        { quality: 0.90, scale: 1.70, label: 'Very High (122 DPI)' },
        { quality: 0.84, scale: 1.45, label: 'High (104 DPI)' },
        { quality: 0.76, scale: 1.20, label: 'Medium (86 DPI)' },
        { quality: 0.68, scale: 1.00, label: 'Standard (72 DPI)' },
      ],
      balanced: [
        { quality: 0.82, scale: 1.40, label: 'High (101 DPI)' },
        { quality: 0.72, scale: 1.15, label: 'Medium (83 DPI)' },
        { quality: 0.62, scale: 0.95, label: 'Standard (68 DPI)' },
        { quality: 0.52, scale: 0.80, label: 'Low (58 DPI)' },
      ],
      aggressive: [
        { quality: 0.72, scale: 1.10, label: 'Medium (79 DPI)' },
        { quality: 0.62, scale: 0.92, label: 'Standard (66 DPI)' },
        { quality: 0.52, scale: 0.78, label: 'Low (56 DPI)' },
        { quality: 0.42, scale: 0.66, label: 'Minimum (48 DPI)' },
      ],
    };

    let targetBytes = TARGET_BYTES;
    let splitTargetBytes = 15 * 1024 * 1024;
    let qualityProfile = 'fidelity';
    let oversizeAction = 'keep-smallest';

    let wakeLock = null;
    async function acquireWakeLock() {
      if ('wakeLock' in navigator) try { wakeLock = await navigator.wakeLock.request('screen'); } catch (_) {}
    }
    async function releaseWakeLock() {
      if (wakeLock) { try { await wakeLock.release(); } catch (_) {} wakeLock = null; }
    }

    let entries = [], nextId = 0, isRunning = false;
    const $ = id => document.getElementById(id);
    const fmtSize = b => (b >= 1_048_576 ? (b / 1_048_576).toFixed(1) + ' MB' : (b / 1024).toFixed(0) + ' KB');

    function applySettings() {
      const targetMb = Number($('target-size-mb').value) || 25;
      const splitMb = Number($('split-size-mb').value) || Math.max(5, targetMb - 5);
      targetBytes = Math.max(1, Math.min(200, targetMb)) * 1024 * 1024;
      splitTargetBytes = Math.max(1, Math.min(200, splitMb)) * 1024 * 1024;
      qualityProfile = $('quality-profile').value || 'fidelity';
      oversizeAction = $('oversize-action').value || 'keep-smallest';
    }

    function getQualityLadder() {
      return QUALITY_PROFILES[qualityProfile] || QUALITY_PROFILES.fidelity;
    }

    function outputSize(entry) {
      return (entry.outputs || []).reduce((acc, out) => acc + out.blob.size, 0);
    }

    function setBadge(id, cls, text) {
      const b = $(`badge-${id}`); b.className = `status-badge badge-${cls}`; b.textContent = text;
    }

    function setProgress(id, pct, text) {
      $(`prog-wrap-${id}`).classList.add('visible');
      $(`prog-text-${id}`).textContent = text;
      $(`prog-fill-${id}`).style.width = pct + '%';
    }

    function hideProgress(id) { $(`prog-wrap-${id}`).classList.remove('visible'); }

    function renderCard(entry) {
      const { id, file } = entry;
      const card = document.createElement('div');
      card.className = 'file-card';
      card.id = `card-${id}`;
      card.innerHTML = `
        <div class="file-top">
          <div class="file-name-wrap">
            <div class="file-name" title="${file.name}">${file.name}</div>
            <div class="file-meta">
              <span class="size-orig">${fmtSize(file.size)}</span>
              <span class="arr" id="arrow-${id}" style="display:none">→</span>
              <span class="size-final" id="final-${id}"></span>
              <span class="status-badge badge-pending" id="badge-${id}">queued</span>
            </div>
          </div>
          <button class="remove-btn" onclick="removeEntry(${id})">✕</button>
        </div>
        <div class="progress-wrap" id="prog-wrap-${id}">
          <div class="progress-text" id="prog-text-${id}"></div>
          <div class="progress-bar-bg"><div class="progress-bar-fill" id="prog-fill-${id}"></div></div>
        </div>
        <button class="dl-card-btn" id="dl-card-${id}" onclick="downloadEntry(${id})">Download</button>`;
      $('file-list').appendChild(card);
    }

    function addFiles(fileList) {
      const existing = new Set(entries.map(e => e.file.name + e.file.size));
      for (const f of fileList) {
        if (!f.name.toLowerCase().endsWith('.pdf') && f.type !== 'application/pdf') continue;
        if (existing.has(f.name + f.size)) continue;
        const id = ++nextId;
        entries.push({ id, file: f, status: 'queued', outputs: [] });
        renderCard(entries.at(-1));
        existing.add(f.name + f.size);
      }
      updateUI();
    }

    window.removeEntry = function removeEntry(id) {
      if (isRunning) return;
      entries = entries.filter(e => e.id !== id);
      $(`card-${id}`)?.remove();
      updateUI();
    };

    async function loadPdfWithTimeout(data, fileSize, id) {
      let elapsed = 0;
      const heartbeat = setInterval(() => {
        elapsed++;
        setBadge(id, 'working', `parsing ${fmtSize(fileSize)}... ${elapsed}s`);
        setProgress(id, 0, `Reading PDF structure - ${elapsed}s elapsed`);
      }, 1000);

      try {
        const loadTask = pdfjsLib.getDocument({ data, disableRange: true, disableStream: true });
        const timeout = new Promise((_, reject) => setTimeout(() => reject(new Error('timeout')), LOAD_TIMEOUT_MS));
        return await Promise.race([loadTask.promise, timeout]);
      } finally {
        clearInterval(heartbeat);
      }
    }

    function setSingleOutput(entry, suffix, blob) {
      const base = entry.file.name.replace(/\.pdf$/i, '');
      entry.outputs = [{ name: `${base}${suffix}.pdf`, blob }];
    }

    async function splitBlobIntoParts(pdfBlob, baseName, maxPartBytes) {
      const srcBytes = new Uint8Array(await pdfBlob.arrayBuffer());
      const srcDoc = await PDFLib.PDFDocument.load(srcBytes);
      const pageCount = srcDoc.getPageCount();
      const outputs = [];
      let start = 0;

      while (start < pageCount) {
        let end = start;
        let bestBytes = null;
        while (end < pageCount) {
          const candidate = await PDFLib.PDFDocument.create();
          const indices = [];
          for (let idx = start; idx <= end; idx++) indices.push(idx);
          const pages = await candidate.copyPages(srcDoc, indices);
          for (const p of pages) candidate.addPage(p);
          const bytes = await candidate.save();
          if (bytes.length <= maxPartBytes) {
            bestBytes = bytes;
            end++;
            continue;
          }
          if (end === start) { bestBytes = bytes; end++; }
          break;
        }
        if (!bestBytes) break;
        const partNum = outputs.length + 1;
        outputs.push({ name: `${baseName}_part-${String(partNum).padStart(2, '0')}.pdf`, blob: new Blob([bestBytes], { type: 'application/pdf' }) });
        start = end;
      }
      return outputs;
    }

    async function compressSingle(entry) {
      const { id, file } = entry;
      entry.outputs = [];
      setBadge(id, 'working', 'reading...');
      setProgress(id, 0, 'Reading file from storage...');
      $(`card-${id}`).classList.add('processing');

      let arrayBuffer;
      try { arrayBuffer = await file.arrayBuffer(); } catch (_) { markError(id, entry, 'file read error'); return; }
      const originalSize = arrayBuffer.byteLength;

      if (originalSize <= targetBytes) {
        setSingleOutput(entry, '_kept', new Blob([arrayBuffer], { type: 'application/pdf' }));
        entry.status = 'skipped';
        hideProgress(id);
        setBadge(id, 'skip', `under ${Math.round(targetBytes / 1024 / 1024)} MB - kept`);
        finishCard(id, 'done-ok');
        $(`dl-card-${id}`).classList.add('visible');
        return;
      }

      let pdfjsDoc;
      try {
        pdfjsDoc = await loadPdfWithTimeout(new Uint8Array(arrayBuffer), originalSize, id);
      } catch (e) {
        markError(id, entry, e.message === 'timeout' ? 'parse timeout' : 'PDF load failed');
        return;
      } finally {
        arrayBuffer = null;
      }

      const numPages = pdfjsDoc.numPages;
      let lastBytes = null;
      let lastLabel = null;

      try {
        for (const { quality, scale, label } of getQualityLadder()) {
          setBadge(id, 'working', label);
          setProgress(id, 0, `${label} - starting (${numPages} pages)`);
          const pdfDoc = await PDFLib.PDFDocument.create();
          let failed = false;

          for (let i = 1; i <= numPages; i++) {
            setProgress(id, Math.round((i / numPages) * 100), `${label} - ${i} / ${numPages}`);
            if (i % YIELD_EVERY === 0) await new Promise(r => setTimeout(r, 0));

            try {
              const page = await pdfjsDoc.getPage(i);
              const viewport = page.getViewport({ scale });
              const canvas = document.createElement('canvas');
              canvas.width = Math.floor(viewport.width);
              canvas.height = Math.floor(viewport.height);
              await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;

              const dataUrl = canvas.toDataURL('image/jpeg', quality);
              const pw = canvas.width, ph = canvas.height;
              canvas.width = 0; canvas.height = 0;

              const raw = atob(dataUrl.split(',')[1]);
              const imgBytes = new Uint8Array(raw.length);
              for (let j = 0; j < raw.length; j++) imgBytes[j] = raw.charCodeAt(j);

              const jpg = await pdfDoc.embedJpg(imgBytes);
              pdfDoc.addPage([pw, ph]).drawImage(jpg, { x: 0, y: 0, width: pw, height: ph });
            } catch (_) {
              failed = true;
              break;
            }
          }

          if (failed) continue;
          const pdfBytes = await pdfDoc.save();
          lastBytes = pdfBytes;
          lastLabel = label;

          if (pdfBytes.length <= targetBytes) {
            setSingleOutput(entry, '_compressed', new Blob([pdfBytes], { type: 'application/pdf' }));
            entry.status = 'compressed';
            const pct = Math.round((1 - pdfBytes.length / originalSize) * 100);
            hideProgress(id);
            $(`arrow-${id}`).style.display = '';
            const fs = $(`final-${id}`);
            fs.textContent = fmtSize(pdfBytes.length);
            fs.classList.add('reduced');
            setBadge(id, 'ok', `-${pct}% - ${label}`);
            finishCard(id, 'done-ok');
            $(`dl-card-${id}`).classList.add('visible');
            return;
          }
        }
      } finally {
        try { pdfjsDoc.destroy(); } catch (_) {}
      }

      if (lastBytes) {
        const smallestBlob = new Blob([lastBytes], { type: 'application/pdf' });
        if (oversizeAction === 'split-parts') {
          try {
            setBadge(id, 'working', 'splitting...');
            setProgress(id, 100, 'Creating smaller parts...');
            const baseName = file.name.replace(/\.pdf$/i, '') + '_compressed';
            const parts = await splitBlobIntoParts(smallestBlob, baseName, splitTargetBytes);
            if (parts.length > 1) {
              entry.outputs = parts;
              entry.status = 'split';
              hideProgress(id);
              $(`arrow-${id}`).style.display = '';
              $(`final-${id}`).textContent = `${parts.length} parts`;
              setBadge(id, 'ok', `split into ${parts.length}`);
              finishCard(id, 'done-ok');
              $(`dl-card-${id}`).classList.add('visible');
              return;
            }
          } catch (_) {}
        }

        setSingleOutput(entry, '_compressed', smallestBlob);
        entry.status = 'partial';
        const pct = Math.round((1 - lastBytes.length / originalSize) * 100);
        hideProgress(id);
        $(`arrow-${id}`).style.display = '';
        $(`final-${id}`).textContent = fmtSize(lastBytes.length) + ' !';
        setBadge(id, 'warn', `still large (-${pct}%)${lastLabel ? ` - ${lastLabel}` : ''}`);
        finishCard(id, 'done-warn');
        $(`dl-card-${id}`).classList.add('visible');
      } else {
        markError(id, entry, 'compression failed');
      }
    }

    function finishCard(id, cls) {
      const c = $(`card-${id}`);
      c.classList.remove('processing');
      c.classList.add(cls);
    }

    function markError(id, entry, msg) {
      entry.status = 'error';
      hideProgress(id);
      setBadge(id, 'err', msg);
      finishCard(id, 'done-err');
    }

    window.startCompression = async function startCompression() {
      if (isRunning || !entries.length) return;
      applySettings();
      isRunning = true;
      const btn = $('compress-btn'), spinner = $('btn-spinner'), lbl = $('compress-label');
      btn.disabled = true;
      spinner.classList.add('visible');
      lbl.textContent = 'Working...';
      $('results-panel').classList.remove('visible');

      await acquireWakeLock();
      for (const entry of entries.filter(e => ['queued', 'error', 'partial'].includes(e.status))) {
        await compressSingle(entry);
        await new Promise(r => setTimeout(r, 350));
      }
      await releaseWakeLock();

      isRunning = false;
      btn.disabled = false;
      spinner.classList.remove('visible');
      lbl.textContent = 'Compress All';
      showResultsPanel();
    };

    function showResultsPanel() {
      const done = entries.filter(e => (e.outputs || []).length > 0);
      if (!done.length) return;

      const compressed = done.filter(e => e.status === 'compressed');
      const skipped = done.filter(e => e.status === 'skipped');
      const partial = done.filter(e => e.status === 'partial');
      const split = done.filter(e => e.status === 'split');
      const saved = done.reduce((a, e) => a + Math.max(0, e.file.size - outputSize(e)), 0);

      const parts = [];
      if (compressed.length) parts.push(`<span>${compressed.length}</span> compressed`);
      if (skipped.length) parts.push(`<span>${skipped.length}</span> already OK`);
      if (partial.length) parts.push(`<span>${partial.length}</span> still large`);
      if (split.length) parts.push(`<span>${split.length}</span> split`);
      if (saved > 0) parts.push(`<span>${fmtSize(saved)}</span> saved`);

      $('results-title-text').textContent = `${done.length} file${done.length > 1 ? 's' : ''} ready`;
      $('results-stats').innerHTML = parts.join(' · ');
      $('dl-zip-btn').style.display = done.length === 1 ? 'none' : '';
      $('results-panel').classList.add('visible');
      $('results-panel').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    window.downloadEntry = function downloadEntry(id) {
      const e = entries.find(x => x.id === id);
      if (!e || !e.outputs || !e.outputs.length) return;

      if (e.outputs.length === 1) {
        const out = e.outputs[0];
        const a = document.createElement('a');
        a.href = URL.createObjectURL(out.blob);
        a.download = out.name;
        a.click();
        setTimeout(() => URL.revokeObjectURL(a.href), 15000);
        return;
      }

      const zip = new JSZip();
      for (const out of e.outputs) zip.file(out.name, out.blob);
      zip.generateAsync({ type: 'blob', compression: 'DEFLATE', compressionOptions: { level: 1 } }).then((blob) => {
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = e.file.name.replace(/\.pdf$/i, '') + '_parts.zip';
        a.click();
        setTimeout(() => URL.revokeObjectURL(a.href), 20000);
      });
    };

    function collectAllOutputs() {
      const collected = [];
      for (const e of entries) {
        if (!e.outputs) continue;
        for (const out of e.outputs) collected.push(out);
      }
      return collected;
    }

    window.downloadAllIndividual = async function downloadAllIndividual() {
      const outputs = collectAllOutputs();
      for (let i = 0; i < outputs.length; i++) {
        const a = document.createElement('a');
        a.href = URL.createObjectURL(outputs[i].blob);
        a.download = outputs[i].name;
        a.click();
        setTimeout(() => URL.revokeObjectURL(a.href), 15000);
        if (i < outputs.length - 1) await new Promise(r => setTimeout(r, 700));
      }
    };

    window.downloadZip = async function downloadZip() {
      const outputs = collectAllOutputs();
      if (!outputs.length) return;
      if (outputs.length === 1) {
        const a = document.createElement('a');
        a.href = URL.createObjectURL(outputs[0].blob);
        a.download = outputs[0].name;
        a.click();
        setTimeout(() => URL.revokeObjectURL(a.href), 15000);
        return;
      }

      const btn = $('dl-zip-btn');
      const orig = btn.textContent;
      btn.textContent = 'Building ZIP...';
      btn.disabled = true;

      try {
        const zip = new JSZip();
        for (const out of outputs) zip.file(out.name, out.blob);
        const blob = await zip.generateAsync({ type: 'blob', compression: 'DEFLATE', compressionOptions: { level: 1 } });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'pdf_toolkit_outputs.zip';
        a.click();
        setTimeout(() => URL.revokeObjectURL(a.href), 20000);
      } finally {
        btn.textContent = orig;
        btn.disabled = false;
      }
    };

    function updateUI() {
      const hasFiles = entries.length > 0;
      $('actions-bar').classList.toggle('visible', hasFiles);
      $('empty-hint').style.display = hasFiles ? 'none' : '';
      if (!hasFiles) $('results-panel').classList.remove('visible');
      const q = entries.filter(e => e.status === 'queued').length;
      $('compress-label').textContent = q > 0 ? `Compress ${q} File${q > 1 ? 's' : ''}` : 'Compress All';
    }

    $('file-input').addEventListener('change', function () { addFiles(this.files); this.value = ''; });

    const dz = $('drop-zone');
    dz.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('drag-over'); });
    dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
    dz.addEventListener('drop', (e) => { e.preventDefault(); dz.classList.remove('drag-over'); addFiles(e.dataTransfer.files); });

    const installModal = $('install-modal');
    $('open-install').addEventListener('click', () => {
      installModal.classList.add('open');
      installModal.setAttribute('aria-hidden', 'false');
    });
    $('close-install').addEventListener('click', () => {
      installModal.classList.remove('open');
      installModal.setAttribute('aria-hidden', 'true');
    });
    installModal.addEventListener('click', (event) => {
      if (event.target === installModal) {
        installModal.classList.remove('open');
        installModal.setAttribute('aria-hidden', 'true');
      }
    });

    updateUI();
  </script>
</BaseLayout>

<style>
  :root {
    --bg: var(--color-bg);
    --surface: var(--color-bg-elevated);
    --surface2: color-mix(in oklab, var(--color-bg-elevated) 88%, var(--color-bg));
    --border: var(--color-border);
    --text: var(--color-fg);
    --muted: var(--color-fg-muted);
    --accent: var(--color-accent);
    --sans: var(--font-sans);
    --mono: var(--font-mono);

