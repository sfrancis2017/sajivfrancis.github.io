---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EAExplorer from '@/components/lab/EAExplorer/index.tsx';
---

<BaseLayout
  title="EA Architecture Explorer"
  description="Pick an industry, toggle the systems you use, and get three AI-recommended enterprise reference architectures — primary plus two alternates — with diagrams, integration patterns, and a phased roadmap."
  mainClass="max-w-6xl"
>
  {/* Wrap in <article> so the global print stylesheet (which hides
       `main > *:not(article)` for blog posts) doesn't suppress this
       page during PDF export. */}
  <article>
    <header class="mb-8 print-hide">
      <p class="text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] font-semibold">
        Lab · EA Architecture Explorer
      </p>
      <h1 class="mt-2 text-3xl md:text-4xl font-semibold tracking-tight leading-tight">
        Build a reference architecture in two clicks.
      </h1>
      <p class="mt-3 text-base md:text-lg text-[var(--color-fg-muted)] leading-snug max-w-2xl">
        Pick an industry, toggle the systems you use (or want to evaluate), and
        get three AI-recommended enterprise architectures — primary plus a
        cloud-native alternate and a cost-optimised alternate — each with
        diagrams, integration patterns, tradeoffs, and a phased roadmap.
        Exportable as PDF.
      </p>
    </header>

    <EAExplorer client:only="react" />
  </article>
</BaseLayout>
